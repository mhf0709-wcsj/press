.container {
  padding: 24rpx;
  background-color: var(--background-color, #F4F5F7);
  min-height: 100vh;
}

.search-bar {
  display: flex;
  margin-bottom: 24rpx;
  gap: 16rpx;
  align-items: center;
}

.scan-btn {
  width: 72rpx;
  height: 72rpx;
  background: #fff;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.scan-icon {
  width: 40rpx;
  height: 40rpx;
}

.search-input {
  flex: 1;
  background: #fff;
  border-radius: 12rpx;
  padding: 0 24rpx;
  height: 72rpx;
  font-size: 28rpx;
}

.search-btn {
  width: 140rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  background: var(--primary-color, #1A5CFF);
  color: #fff;
  margin: 0;
  padding: 0;
  border-radius: 12rpx;
}

.device-list {
  height: calc(100vh - 120rpx);
}

.device-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.device-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  border-bottom: 1rpx solid #eee;
  padding-bottom: 16rpx;
}

.device-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.status-badge {
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.status-active {
  background: #E8F5E9;
  color: #4CAF50;
}

.status-scrap {
  background: #FFEBEE;
  color: #F44336;
}

.status-other {
  background: #FFF3E0;
  color: #FF9800;
}

.device-body .info-row {
  display: flex;
  margin-bottom: 12rpx;
  font-size: 26rpx;
}

.device-body .label {
  color: #666;
  width: 140rpx;
}

.device-body .value {
  color: #333;
  flex: 1;
}

.device-footer {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed #eee;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.qr-text {
  font-size: 24rpx;
  color: #999;
}

.qr-icon {
  width: 32rpx;
  height: 32rpx;
}

.fab-btn {
  position: fixed;
  bottom: 60rpx;
  right: 40rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: var(--primary-color, #1A5CFF);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 16rpx rgba(26, 92, 255, 0.3);
  z-index: 100;
}

.fab-btn text {
  font-size: 60rpx;
  font-weight: 300;
  margin-top: -8rpx;
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}