<view class="page-shell device-list-page">
  <view class="content-wrapper device-list-wrapper">
    <view class="device-list-hero panel">
      <view class="panel-section">
        <text class="eyebrow">压力表库</text>
        <view class="page-title">压力表列表</view>
        <view class="page-subtitle">搜索压力表、扫码识别并快速进入详情页。</view>
      </view>
    </view>

    <view class="device-search panel">
      <view class="panel-section device-search-section">
        <view class="search-row">
          <view class="scan-pill" bindtap="scanQrCode">扫码</view>
          <input class="search-input" placeholder="搜索压力表或识别码" bindinput="onSearchInput" bindconfirm="onSearch" value="{{searchKeyword}}" />
          <button class="search-button" bindtap="onSearch">搜索</button>
        </view>
      </view>
    </view>

    <view class="device-list-stack" wx:if="{{devices.length > 0}}">
      <view class="device-item panel" wx:for="{{devices}}" wx:key="_id" bindtap="goToDetail" data-id="{{item._id}}">
        <view class="panel-section">
          <view class="device-item-head"><text class="device-item-title">{{item.deviceName}}</text><text class="device-status status-other">{{item.status || '-'}}</text></view>
          <view class="device-item-row"><text class="device-item-label">设备编号</text><text class="device-item-value">{{item.deviceNo}}</text></view>
          <view class="device-item-row"><text class="device-item-label">出厂编号</text><text class="device-item-value">{{item.factoryNo || '-'}}</text></view>
          <view class="device-item-row"><text class="device-item-label">建档时间</text><text class="device-item-value">{{item.createTime}}</text></view>
          <view class="device-item-foot"><text class="device-item-qr">识别码 {{item.qrCode}}</text><text class="device-item-copy" catchtap="copyQr" data-qr="{{item.qrCode}}">复制</text></view>
        </view>
      </view>
    </view>

    <view class="panel empty-panel" wx:else>
      <view class="panel-section empty-section">
        <view class="section-title">暂无压力表</view>
        <view class="section-note">请先在设备档案下新建或绑定压力表。</view>
      </view>
    </view>
  </view>

  <view class="floating-create" bindtap="createNewDevice">+</view>
</view>