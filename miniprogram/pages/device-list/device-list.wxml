<view class="page-shell device-list-page" bindtap="closeSwipe">
  <view class="content-wrapper device-list-wrapper">
    <view class="device-list-hero panel">
      <view class="panel-section">
        <text class="eyebrow">压力表库</text>
        <view class="page-title">{{pageTitle}}</view>
      </view>
    </view>

    <view class="device-search panel">
      <view class="panel-section device-search-section">
        <view class="search-row">
          <input
            class="search-input"
            placeholder="名称或出厂编号"
            bindinput="onSearchInput"
            bindconfirm="onSearch"
            value="{{searchKeyword}}"
          />
          <button class="search-button" bindtap="onSearch">搜索</button>
        </view>
      </view>
    </view>

    <view class="device-list-stack" wx:if="{{devices.length > 0}}">
      <view class="swipe-row" wx:for="{{devices}}" wx:key="_id">
        <view class="swipe-delete-wrap {{swipeOpenId === item._id ? 'open' : ''}}">
          <view class="swipe-delete" catchtap="onDeleteDevice" data-id="{{item._id}}">
            <text>{{deletingId === item._id ? '删除中' : '删除'}}</text>
          </view>
        </view>

        <view
          class="swipe-card {{swipeOpenId === item._id ? 'open' : ''}}"
          bindtap="goToDetail"
          catchtouchstart="onTouchStart"
          catchtouchend="onTouchEnd"
          data-id="{{item._id}}"
        >
          <view class="device-item panel">
            <view class="panel-section">
              <view class="device-item-head">
                <text class="device-item-title">{{item.deviceName || '压力表'}}</text>
                <text class="device-status {{item.status === '在用' ? 'status-active' : (item.status === '报废' ? 'status-scrap' : 'status-other')}}">{{item.status || '-'}}</text>
              </view>
              <view class="device-item-row">
                <text class="device-item-label">压力表编号</text>
                <text class="device-item-value">{{item.deviceNo || '-'}}</text>
              </view>
              <view class="device-item-row">
                <text class="device-item-label">出厂编号</text>
                <text class="device-item-value">{{item.factoryNo || '-'}}</text>
              </view>
              <view class="device-item-row">
                <text class="device-item-label">所属设备</text>
                <text class="device-item-value">{{item.equipmentName || '-'}}</text>
              </view>
              <view class="device-item-row">
                <text class="device-item-label">建档时间</text>
                <text class="device-item-value">{{item.createTime || '-'}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="panel empty-panel" wx:else>
      <view class="panel-section empty-section">
        <view class="section-title">暂无压力表</view>
      </view>
    </view>
  </view>

  <view class="floating-create" bindtap="createNewDevice">+</view>
</view>
