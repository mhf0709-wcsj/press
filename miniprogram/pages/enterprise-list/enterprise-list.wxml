<view class="page-shell enterprise-page">
  <scroll-view scroll-y class="enterprise-scroll">
    <view class="content-wrapper enterprise-wrapper">
      <view class="panel hero-panel">
        <view class="panel-section">
          <view class="eyebrow">{{text.heroTopline}}</view>
          <view class="page-title hero-title">{{mode === 'risk' ? text.riskTitle : text.heroTitle}}</view>
          <view class="page-subtitle">{{mode === 'risk' ? text.riskDesc : text.heroDesc}}</view>
        </view>
      </view>

      <view class="panel">
        <view class="panel-section">
          <view class="list-block" wx:if="{{enterpriseList.length}}">
            <view
              class="list-cell enterprise-cell"
              wx:for="{{enterpriseList}}"
              wx:key="_id"
              bindtap="previewEnterprise"
              data-name="{{item.companyName}}"
            >
              <view class="cell-main">
                <text class="cell-title">{{item.companyName}}</text>
                <text class="cell-subtitle">{{text.fields.legalPerson}} {{item.legalPerson || '-'}}</text>
                <text class="cell-subtitle">{{text.fields.phone}} {{item.phone || '-'}}</text>
                <text class="cell-subtitle">{{text.fields.createTime}} {{item.createTimeStr || '-'}}</text>
              </view>
              <view class="cell-side">
                <text class="district-tag">{{item.district || text.noDistrict}}</text>
                <text class="risk-tag danger" wx:if="{{mode === 'risk' && item.expiredCount > 0}}">{{item.expiredCount}} 过期</text>
                <text class="risk-tag warning" wx:if="{{mode === 'risk' && item.expiringCount > 0}}">{{item.expiringCount}} 即将到期</text>
              </view>
            </view>
          </view>

          <view class="empty-state" wx:if="{{!enterpriseList.length && !loading}}">
            <text class="empty-text">{{mode === 'risk' ? text.emptyRisk : text.empty}}</text>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
