<!-- 设备详情与台账页 -->
<view class="container">
  <view class="header-card">
    <view class="header-row">
      <view class="header-left">
        <view class="device-title">{{device.deviceName || '新设备'}}</view>
        <view class="device-qr" wx:if="{{device.qrCode}}">一表一码: {{device.qrCode}}</view>
      </view>
      <view class="qr-btn" bindtap="showQRCode" wx:if="{{mode !== 'create'}}">
        <image src="../../images/icons/share.svg" class="qr-icon"></image>
        <text>设备码</text>
      </view>
    </view>
  </view>

  <view class="form-card">
    <view class="form-title">基础信息</view>

    <view class="form-item" wx:if="{{device.equipmentName}}">
      <text class="label">所属设备</text>
      <text class="picker">{{device.equipmentName}}</text>
    </view>
    
    <view class="form-item">
      <text class="label">设备编号<text class="required">*</text></text>
      <input class="input" value="{{device.deviceNo}}" bindinput="onInput" data-field="deviceNo" placeholder="请输入或自动生成" />
    </view>
    
    <view class="form-item">
      <text class="label">设备名称<text class="required">*</text></text>
      <input class="input" value="{{device.deviceName}}" bindinput="onInput" data-field="deviceName" placeholder="例如: 耐震压力表" />
    </view>
    
    <view class="form-item">
      <text class="label">出厂编号</text>
      <input class="input" value="{{device.factoryNo}}" bindinput="onInput" data-field="factoryNo" placeholder="请输入出厂编号" />
    </view>
    
    <view class="form-item">
      <text class="label">制造单位</text>
      <input class="input" value="{{device.manufacturer}}" bindinput="onInput" data-field="manufacturer" placeholder="请输入制造单位" />
    </view>
    
    <view class="form-item">
      <text class="label">规格型号</text>
      <input class="input" value="{{device.modelSpec}}" bindinput="onInput" data-field="modelSpec" placeholder="请输入规格型号" />
    </view>
  </view>

  <view class="form-card">
    <view class="form-title">状态与位置 (AI动态追踪)</view>
    
    <view class="form-item">
      <text class="label">当前状态</text>
      <picker mode="selector" range="{{statusOptions}}" bindchange="onStatusChange">
        <view class="picker {{!device.status ? 'placeholder' : ''}}">
          {{device.status || '请选择状态'}}
        </view>
      </picker>
    </view>
    
    <view class="form-item">
      <text class="label">安装位置</text>
      <input class="input" value="{{device.installLocation}}" bindinput="onInput" data-field="installLocation" placeholder="如: 1号锅炉车间" />
    </view>
  </view>

  <view class="form-card" wx:if="{{mode !== 'create'}}">
    <view class="form-title">存档压力表数据</view>
    <view class="record-list" wx:if="{{archiveRecords.length > 0}}">
      <view class="record-item" wx:for="{{archiveRecords}}" wx:key="_id" bindtap="goRecordDetail" data-id="{{item._id}}">
        <view class="record-main">
          <text class="record-no">{{item.factoryNo || item.deviceNo || '未填写出厂编号'}}</text>
          <text class="record-cert">证书：{{item.certNo || '-'}}</text>
        </view>
        <view class="record-extra">
          <text class="record-date">检定：{{item.verificationDate || '-'}}</text>
          <text class="record-photo" wx:if="{{item.fileID || item.installPhotoFileID}}">📷有照片</text>
          <text class="record-source">{{item.ocrSource === 'baidu' || item.ocrSource === 'ai_extract' ? 'AI识别' : '手动填报'}}</text>
          <text class="record-arrow">›</text>
        </view>
      </view>
    </view>
    <view class="empty-record" wx:else>
      <text>暂无存档压力表数据</text>
    </view>
  </view>

  <view class="form-card" wx:if="{{logs && logs.length > 0}}">
    <view class="form-title">生命周期轨迹</view>
    <view class="timeline">
      <view class="timeline-item" wx:for="{{logs}}" wx:key="_id">
        <view class="timeline-dot"></view>
        <view class="timeline-content">
          <view class="timeline-header">
            <text class="action">{{item.action}}</text>
            <text class="time">{{item.createTime}}</text>
          </view>
          <view class="timeline-body">
            <text class="operator">操作人: {{item.operator}}</text>
            <text class="remark" wx:if="{{item.remark}}">备注: {{item.remark}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="footer-btn">
    <button class="save-btn" bindtap="saveDevice">保存压力表档案</button>
  </view>
</view>
