.container {
  padding: 24rpx;
  background-color: var(--background-color, #F4F5F7);
  min-height: 100vh;
  padding-bottom: 120rpx;
  box-sizing: border-box;
  width: 100%;
  display: block;
}

.header-card {
  background: var(--primary-color, #1A5CFF);
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  color: #fff;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(26, 92, 255, 0.2);
  position: relative;
  width: 100%;
  box-sizing: border-box;
}

.header-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  align-items: flex-start;
}

.header-left {
  flex: 1;
  min-width: 0;
}

.qr-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255,255,255,0.2);
  padding: 10rpx 20rpx;
  border-radius: 12rpx;
}

.qr-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 4rpx;
}

.qr-btn text {
  font-size: 22rpx;
  color: #fff;
}

.device-title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.device-qr {
  font-size: 26rpx;
  opacity: 0.9;
  background: rgba(255,255,255,0.2);
  display: block;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  word-break: break-all;
  white-space: normal;
  width: 100%;
  box-sizing: border-box;
}

.form-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03);
  width: 100%;
  box-sizing: border-box;
}

.form-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 8rpx solid var(--primary-color, #1A5CFF);
}

.form-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  width: 160rpx;
  font-size: 28rpx;
  color: #666;
}

.required {
  color: #F44336;
  margin-left: 4rpx;
}

.input, .picker {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  text-align: left;
  width: 100%;
  min-width: 0;
  box-sizing: border-box;
}

.input {
  height: 76rpx;
  line-height: 76rpx;
  padding: 0 24rpx;
  border: 2rpx solid #E5E7EB;
  border-radius: 16rpx;
  background: #fff;
}

.picker {
  min-height: 76rpx;
  line-height: 76rpx;
}

.placeholder {
  color: #CCC;
}

/* 轨迹时间线样式 */
.timeline {
  padding-left: 20rpx;
  margin-top: 20rpx;
}

.timeline-item {
  position: relative;
  padding-bottom: 30rpx;
  padding-left: 40rpx;
  border-left: 2rpx solid #E0E0E0;
}

.timeline-item:last-child {
  border-left-color: transparent;
}

.timeline-dot {
  position: absolute;
  left: -11rpx;
  top: 8rpx;
  width: 20rpx;
  height: 20rpx;
  background: var(--primary-color, #1A5CFF);
  border-radius: 50%;
  border: 4rpx solid #fff;
  box-shadow: 0 0 0 2rpx var(--primary-color, #1A5CFF);
}

.timeline-content {
  background: #F8F9FA;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
}

.timeline-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.action {
  font-weight: bold;
  color: #333;
  font-size: 28rpx;
}

.time {
  font-size: 24rpx;
  color: #999;
}

.timeline-body {
  display: flex;
  flex-direction: column;
  font-size: 26rpx;
  color: #666;
  gap: 6rpx;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.record-item {
  border: 1rpx solid #E5E7EB;
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.record-main {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.record-no {
  font-size: 30rpx;
  color: #111827;
  font-weight: 600;
}

.record-cert {
  font-size: 24rpx;
  color: #6B7280;
}

.record-extra {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.record-date,
.record-source {
  font-size: 22rpx;
  color: #6B7280;
}

.record-photo {
  font-size: 22rpx;
  color: #1D4ED8;
}

.record-arrow {
  font-size: 34rpx;
  color: #9CA3AF;
}

.empty-record {
  color: #9CA3AF;
  font-size: 26rpx;
  padding: 8rpx 0;
}

.footer-btn {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: 20rpx 40rpx;
  background: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.05);
  box-sizing: border-box;
  z-index: 100;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: var(--primary-color, #1A5CFF);
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
}
