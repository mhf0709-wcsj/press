.device-page { min-height: 100vh; }
.device-wrapper { padding-bottom: 168rpx; }
.device-hero, .device-card { margin-bottom: 24rpx; }
.device-title { margin-top: 18rpx; }
.device-hero-action { margin-top: 24rpx; display: inline-flex; min-height: 80rpx; padding: 0 24rpx; align-items: center; border-radius: 999rpx; background: var(--color-brand-soft); color: var(--color-brand); font-size: var(--font-size-callout); font-weight: var(--font-weight-semibold); }
.detail-row { display: flex; align-items: center; gap: 18rpx; min-height: 96rpx; padding: 8rpx 0; border-bottom: 1rpx solid rgba(17,24,39,0.06); }
.detail-row.no-border { border-bottom: none; }
.detail-label { width: 156rpx; flex-shrink: 0; font-size: var(--font-size-footnote); color: var(--color-text-secondary); }
.detail-input, .detail-static, .detail-picker { flex: 1; min-width: 0; }
.detail-input { height: 80rpx; text-align: right; font-size: var(--font-size-body); color: var(--color-text-main); }
.detail-static { text-align: right; font-size: var(--font-size-body); color: var(--color-text-main); }
.detail-picker { display: flex; justify-content: flex-end; align-items: center; gap: 12rpx; }
.detail-picker-value { font-size: var(--font-size-body); color: var(--color-text-main); }
.detail-picker-arrow, .record-arrow { font-size: 30rpx; color: var(--color-text-tertiary); }
.record-list { margin-top: 20rpx; }
.record-item { display: flex; justify-content: space-between; gap: 16rpx; padding: 20rpx 0; border-bottom: 1rpx solid rgba(17,24,39,0.06); }
.record-item:last-child { border-bottom: none; }
.record-copy { min-width: 0; flex: 1; }
.record-title { display: block; font-size: var(--font-size-callout); font-weight: var(--font-weight-semibold); color: var(--color-text-main); }
.record-sub { display: block; margin-top: 8rpx; font-size: var(--font-size-caption); color: var(--color-text-secondary); }
.record-side { display: flex; flex-direction: column; align-items: flex-end; gap: 8rpx; }
.record-meta { font-size: var(--font-size-caption); color: var(--color-text-tertiary); }
.empty-note { margin-top: 18rpx; font-size: var(--font-size-footnote); color: var(--color-text-tertiary); }
.timeline { margin-top: 18rpx; }
.timeline-item { position: relative; padding-left: 32rpx; padding-bottom: 24rpx; border-left: 1rpx solid rgba(17,24,39,0.08); }
.timeline-item:last-child { border-left-color: transparent; }
.timeline-dot { position: absolute; left: -8rpx; top: 8rpx; width: 16rpx; height: 16rpx; border-radius: 50%; background: var(--color-brand); }
.timeline-content { padding: 18rpx 20rpx; border-radius: var(--radius-md); background: rgba(247,248,251,0.96); }
.timeline-head { display: flex; justify-content: space-between; gap: 12rpx; }
.timeline-action { font-size: var(--font-size-footnote); font-weight: var(--font-weight-semibold); color: var(--color-text-main); }
.timeline-time, .timeline-meta { font-size: var(--font-size-caption); color: var(--color-text-secondary); }
.timeline-body { display: flex; flex-direction: column; gap: 8rpx; margin-top: 10rpx; }
.device-bottom-bar { position: fixed; left: 24rpx; right: 24rpx; bottom: 24rpx; padding: 16rpx; padding-bottom: calc(16rpx + env(safe-area-inset-bottom)); border-radius: 36rpx; background: rgba(255,255,255,0.88); border: 1rpx solid rgba(17,24,39,0.06); box-shadow: var(--shadow-md); backdrop-filter: blur(24rpx); }
.bottom-primary { width: 100%; min-height: 88rpx; border: none; border-radius: 999rpx; background: var(--color-brand); color: var(--color-text-white); font-size: var(--font-size-callout); font-weight: var(--font-weight-semibold); }
.bottom-primary::after { border: none; }
