.equipment-page { min-height: 100vh; }
.equipment-wrapper { padding-bottom: 168rpx; }
.equipment-hero, .equipment-dashboard, .equipment-card { margin-bottom: 24rpx; }
.equipment-title { margin-top: 18rpx; }
.equipment-hero-actions { display: flex; gap: 16rpx; margin-top: 28rpx; }
.hero-ghost, .hero-primary, .bottom-primary, .mini-action { border: none; border-radius: 999rpx; }
.hero-ghost::after, .hero-primary::after, .bottom-primary::after, .mini-action::after { border: none; }
.hero-ghost, .hero-primary { min-height: 84rpx; padding: 0 28rpx; font-size: var(--font-size-callout); font-weight: var(--font-weight-semibold); }
.hero-ghost { background: rgba(242,245,250,0.96); color: var(--color-text-main); }
.hero-primary { background: var(--color-brand); color: var(--color-text-white); }
.dashboard-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16rpx; margin-top: 20rpx; }
.dashboard-item { padding: 24rpx; border-radius: var(--radius-md); background: rgba(247,248,251,0.96); }
.dashboard-number { display: block; font-size: var(--font-size-title2); font-weight: var(--font-weight-bold); color: var(--color-text-main); }
.dashboard-label { display: block; margin-top: 8rpx; font-size: var(--font-size-footnote); color: var(--color-text-secondary); }
.dashboard-item.danger { background: var(--color-danger-soft); }
.dashboard-item.warning { background: var(--color-warning-soft); }
.dashboard-item.success { background: var(--color-accent-soft); }
.detail-row { display: flex; align-items: center; gap: 18rpx; min-height: 96rpx; padding: 8rpx 0; border-bottom: 1rpx solid rgba(17,24,39,0.06); }
.detail-row.no-border { border-bottom: none; }
.detail-label { width: 156rpx; flex-shrink: 0; font-size: var(--font-size-footnote); color: var(--color-text-secondary); }
.detail-value { flex: 1; min-width: 0; }
.detail-input { width: 100%; height: 80rpx; text-align: right; font-size: var(--font-size-body); color: var(--color-text-main); }
.detail-static { display: block; text-align: right; font-size: var(--font-size-body); color: var(--color-text-main); word-break: break-all; }
.gauge-list { margin-top: 20rpx; }
.gauge-item { display: flex; justify-content: space-between; gap: 16rpx; padding: 22rpx 0; border-bottom: 1rpx solid rgba(17,24,39,0.06); }
.gauge-item:last-child { border-bottom: none; }
.gauge-item.highlight { margin: 0 -12rpx; padding: 22rpx 12rpx; border-radius: var(--radius-md); background: var(--color-brand-soft); border-bottom: none; }
.gauge-copy { flex: 1; min-width: 0; }
.gauge-name { display: block; font-size: var(--font-size-title3); font-weight: var(--font-weight-semibold); color: var(--color-text-main); }
.gauge-meta { display: block; margin-top: 8rpx; font-size: var(--font-size-caption); color: var(--color-text-secondary); }
.gauge-meta-row { display: flex; flex-wrap: wrap; gap: 10rpx; margin-top: 10rpx; align-items: center; }
.gauge-meta-light { font-size: var(--font-size-caption); color: var(--color-text-tertiary); }
.gauge-pill { font-size: var(--font-size-caption); padding: 8rpx 14rpx; border-radius: 999rpx; background: rgba(242,245,250,0.96); color: var(--color-text-secondary); }
.gauge-pill.normal, .gauge-pill.pass { background: var(--color-accent-soft); color: var(--color-accent); }
.gauge-pill.expiring { background: var(--color-warning-soft); color: var(--color-warning); }
.gauge-pill.expired, .gauge-pill.fail { background: var(--color-danger-soft); color: var(--color-danger); }
.gauge-side { display: flex; flex-direction: column; align-items: flex-end; gap: 10rpx; }
.mini-action { min-width: 100rpx; min-height: 56rpx; background: rgba(242,245,250,0.96); color: var(--color-brand); font-size: var(--font-size-caption); }
.gauge-tag { font-size: var(--font-size-caption); color: var(--color-brand); background: var(--color-brand-soft); padding: 8rpx 14rpx; border-radius: 999rpx; }
.gauge-arrow { color: var(--color-text-tertiary); font-size: 32rpx; }
.empty-panel .empty-section { text-align: center; padding-top: 48rpx; padding-bottom: 48rpx; }
.equipment-bottom-bar { position: fixed; left: 24rpx; right: 24rpx; bottom: 24rpx; padding: 16rpx; padding-bottom: calc(16rpx + env(safe-area-inset-bottom)); border-radius: 36rpx; background: rgba(255,255,255,0.88); border: 1rpx solid rgba(17,24,39,0.06); box-shadow: var(--shadow-md); backdrop-filter: blur(24rpx); }
.bottom-primary { width: 100%; min-height: 88rpx; background: var(--color-brand); color: var(--color-text-white); font-size: var(--font-size-callout); font-weight: var(--font-weight-semibold); }
