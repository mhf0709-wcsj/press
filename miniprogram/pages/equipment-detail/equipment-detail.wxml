<view class="container">
  <view class="header-card card">
    <view class="header-main">
      <text class="title">{{equipment.equipmentName || '设备档案'}}</text>
      <text class="sub">设备编号：{{equipment.equipmentNo || '-'}}</text>
    </view>
    <view class="header-actions">
      <button class="btn secondary" bindtap="showEquipmentCode" wx:if="{{equipmentId}}">设备码</button>
      <button class="btn primary" bindtap="createGauge" wx:if="{{equipmentId && !isAdminView}}">新增压力表</button>
    </view>
  </view>

  <view class="card" wx:if="{{equipmentId}}">
    <view class="card-title">监管概览</view>
    <view class="stats">
      <view class="stat">
        <text class="num">{{dashboard.totalGauges}}</text>
        <text class="label">压力表总数</text>
      </view>
      <view class="stat danger">
        <text class="num">{{dashboard.expired}}</text>
        <text class="label">逾期</text>
      </view>
      <view class="stat warn">
        <text class="num">{{dashboard.expiring}}</text>
        <text class="label">临期</text>
      </view>
      <view class="stat ok">
        <text class="num">{{dashboard.normal}}</text>
        <text class="label">正常</text>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="card-title">基础信息</view>
    <view class="kv">
      <text class="k">设备名称</text>
      <view class="v">
        <text class="value-text" wx:if="{{isAdminView}}">{{equipment.equipmentName || '-'}}</text>
        <input class="input" wx:else value="{{equipment.equipmentName}}" bindinput="onInput" data-field="equipmentName" placeholder="请输入设备名称" />
      </view>
    </view>
    <view class="kv">
      <text class="k">设备编号</text>
      <view class="v">
        <text class="value-text" wx:if="{{isAdminView}}">{{equipment.equipmentNo || '-'}}</text>
        <input class="input" wx:else value="{{equipment.equipmentNo}}" bindinput="onInput" data-field="equipmentNo" placeholder="请输入设备编号" />
      </view>
    </view>
    <view class="kv">
      <text class="k">安装位置</text>
      <view class="v">
        <text class="value-text" wx:if="{{isAdminView}}">{{equipment.location || '-'}}</text>
        <input class="input" wx:else value="{{equipment.location}}" bindinput="onInput" data-field="location" placeholder="如：1号车间A线" />
      </view>
    </view>
    <view class="kv" wx:if="{{equipment.enterpriseName}}">
      <text class="k">企业</text>
      <view class="v">
        <text class="value-text">{{equipment.enterpriseName}}</text>
      </view>
    </view>
    <view class="kv" wx:if="{{equipment.district}}">
      <text class="k">辖区</text>
      <view class="v">
        <text class="value-text">{{equipment.district}}</text>
      </view>
    </view>
    <view class="kv" wx:if="{{equipment.createTime}}">
      <text class="k">备案时间</text>
      <view class="v">
        <text class="value-text">{{equipment.createTime}}</text>
      </view>
    </view>
  </view>

  <view class="card" wx:if="{{gauges.length > 0}}">
    <view class="card-title">已绑定压力表</view>
    <view class="list">
      <view id="gauge-{{item._id}}" class="item {{highlightGaugeId === item._id ? 'highlight' : ''}}" wx:for="{{gauges}}" wx:key="_id" bindtap="onGaugeTap" data-id="{{item._id}}">
        <view class="item-left">
          <text class="name">{{item.deviceName}}</text>
          <text class="meta">出厂编号：{{item.factoryNo || '-'}}</text>
          <view class="meta-row">
            <text class="pill {{item.expiryStatus}}">{{item.expiryStatusText}}</text>
            <text class="meta2">到期：{{item.lastRecord.expiryDate || '-'}}</text>
            <text class="meta2" wx:if="{{item.daysToExpiry !== null}}">剩余{{item.daysToExpiry}}天</text>
          </view>
          <view class="meta-row">
            <text class="meta2">最近检定：{{item.lastRecord.verificationDate || '-'}}</text>
            <text class="pill {{item.lastRecord.conclusion === '合格' ? 'pass' : item.lastRecord.conclusion === '不合格' ? 'fail' : ''}}" wx:if="{{item.lastRecord}}">{{item.lastRecord.conclusion || '-'}}</text>
          </view>
        </view>
        <view class="item-right">
          <view class="actions">
            <button class="mini-btn" size="mini" catchtap="previewGaugeCode" data-id="{{item._id}}">码</button>
          </view>
          <text class="tag">{{item.status || '在用'}}</text>
          <text class="arrow">›</text>
        </view>
      </view>
    </view>
  </view>

  <view class="card empty" wx:if="{{equipmentId && gauges.length === 0}}">
    <text class="empty-title">暂无绑定压力表</text>
    <text class="empty-desc">{{isAdminView ? '企业尚未绑定压力表或未产生检定记录' : '点击“新增压力表”开始录入并生成压力表码'}}</text>
  </view>

  <view class="footer" wx:if="{{!isAdminView}}">
    <button class="btn primary full" bindtap="saveEquipment" loading="{{saving}}">保存设备档案</button>
  </view>
</view>
