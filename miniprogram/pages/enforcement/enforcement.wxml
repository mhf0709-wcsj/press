<view class="page-shell enforcement-page">
  <scroll-view scroll-y class="enforcement-scroll">
    <view class="content-wrapper enforcement-wrapper">
      <view class="panel hero-panel">
        <view class="panel-section">
          <view class="eyebrow">{{text.heroTopline}}</view>
          <view class="page-title hero-title">{{text.heroTitle}}</view>
          <view class="page-subtitle">{{text.heroDesc}}</view>
          <view class="hero-actions">
            <view class="primary-button hero-action" bindtap="scanDevice">
              <text>{{text.verifyAction}}</text>
            </view>
            <view class="soft-button hero-action" bindtap="takeEvidence">
              <text>{{text.evidenceAction}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="panel" wx:if="{{verifyResult}}">
        <view class="panel-section">
          <text class="section-title">{{text.verifyTitle}}</text>
          <view class="kv-list">
            <view class="kv-row">
              <text class="kv-key">{{text.fields.status}}</text>
              <text class="kv-value status {{statusClass}}">{{verifyResult.verify.status}}</text>
            </view>
            <view class="kv-row">
              <text class="kv-key">{{text.fields.deviceName}}</text>
              <text class="kv-value">{{verifyResult.device.deviceName}}</text>
            </view>
            <view class="kv-row">
              <text class="kv-key">{{text.fields.factoryNo}}</text>
              <text class="kv-value">{{verifyResult.device.factoryNo}}</text>
            </view>
            <view class="kv-row">
              <text class="kv-key">{{text.fields.expiryDate}}</text>
              <text class="kv-value">{{verifyResult.lastRecord.expiryDate || '-'}}</text>
            </view>
            <view class="kv-row">
              <text class="kv-key">{{text.fields.conclusion}}</text>
              <text class="kv-value">{{verifyResult.lastRecord.conclusion || '-'}}</text>
            </view>
            <view class="kv-row" wx:if="{{verifyResult.verify.daysToExpiry !== null}}">
              <text class="kv-key">{{text.fields.daysToExpiry}}</text>
              <text class="kv-value">{{verifyResult.verify.daysToExpiry}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="panel" wx:if="{{evidenceImages.length > 0}}">
        <view class="panel-section">
          <text class="section-title">{{text.evidenceTitle}}</text>
          <view class="thumbs">
            <view class="thumb" wx:for="{{evidenceImages}}" wx:key="path">
              <image class="img" src="{{item.path}}" mode="aspectFill" bindtap="previewEvidence" data-index="{{index}}" />
            </view>
          </view>

          <textarea
            class="remark"
            placeholder="{{text.placeholder}}"
            value="{{remark}}"
            bindinput="onRemarkInput"
            maxlength="300"
          />

          <view class="primary-button submit-action" bindtap="submitEvidence">
            <text>{{text.evidenceAction}}</text>
          </view>

          <view class="hash-box" wx:if="{{lastCaseHash}}">
            <text class="hash-label">{{text.hashLabel}}</text>
            <text class="hash-value">{{lastCaseHash}}</text>
          </view>
        </view>
      </view>

      <view class="panel" wx:if="{{cases.length > 0}}">
        <view class="panel-section">
          <text class="section-title">{{text.historyTitle}}</text>
          <view class="history-list">
            <view class="list-cell history-cell" wx:for="{{cases}}" wx:key="_id">
              <view>
                <text class="cell-title">{{item.verifyStatus || '-'}}</text>
                <text class="cell-subtitle">{{item.createTime}}</text>
              </view>
              <text class="hash-mini">{{item.caseHash}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
