.container {
  padding: 32rpx;
  min-height: 100vh;
  box-sizing: border-box;
  display: block;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 18rpx;
}

.header-card {
  background: linear-gradient(135deg, #111827 0%, #1D4ED8 100%);
  color: #fff;
}

.header-top .title {
  font-size: 40rpx;
  font-weight: 700;
  display: block;
}

.header-top .sub {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.78);
  margin-top: 10rpx;
  display: block;
}

.header-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.btn {
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  padding: 0 28rpx;
  margin: 0;
}

.btn.primary {
  background: #fff;
  color: #1D4ED8;
}

.btn.secondary {
  background: rgba(255, 255, 255, 0.18);
  color: #fff;
}

.kv {
  display: flex;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 2rpx solid #EEF2F7;
}

.kv:last-child {
  border-bottom: none;
}

.k {
  color: #6B7280;
  font-size: 28rpx;
}

.v {
  color: #111827;
  font-size: 28rpx;
  max-width: 460rpx;
  text-align: right;
}

.status {
  font-weight: 700;
}

.status.normal { color: #16A34A; }
.status.expiring { color: #F59E0B; }
.status.expired { color: #DC2626; }
.status.unknown { color: #6B7280; }

.thumbs {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 18rpx;
}

.thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #F3F4F6;
}

.img {
  width: 100%;
  height: 100%;
}

.form {
  margin-top: 18rpx;
}

.remark {
  width: 100%;
  min-height: 160rpx;
  padding: 18rpx;
  box-sizing: border-box;
  border-radius: 16rpx;
  background: #F8FAFC;
  font-size: 28rpx;
}

.hash {
  margin-top: 16rpx;
  padding: 16rpx;
  border-radius: 16rpx;
  background: #F8FAFC;
  color: #475569;
  font-size: 24rpx;
}

.case-item {
  padding: 18rpx 0;
  border-bottom: 2rpx solid #EEF2F7;
}

.case-item:last-child {
  border-bottom: none;
}

.case-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.case-status {
  font-size: 28rpx;
  font-weight: 700;
  color: #111827;
}

.case-time {
  font-size: 24rpx;
  color: #94A3B8;
}

.case-hash {
  margin-top: 10rpx;
}

.mono {
  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace;
  font-size: 22rpx;
  color: #64748B;
  word-break: break-all;
}
