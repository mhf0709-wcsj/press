.enforcement-scroll {
  height: 100vh;
}

.enforcement-wrapper {
  padding-top: var(--space-5);
  padding-bottom: var(--space-8);
}

.hero-panel {
  margin-bottom: var(--space-5);
}

.hero-title {
  margin-top: var(--space-4);
}

.hero-actions {
  display: flex;
  gap: var(--space-3);
  margin-top: var(--space-5);
}

.hero-action {
  flex: 1;
}

.kv-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-top: var(--space-4);
}

.kv-row {
  display: flex;
  justify-content: space-between;
  gap: var(--space-4);
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(17, 24, 39, 0.06);
}

.kv-row:last-child {
  border-bottom: none;
}

.kv-key {
  font-size: var(--font-size-footnote);
  color: var(--color-text-secondary);
}

.kv-value {
  max-width: 420rpx;
  text-align: right;
  font-size: var(--font-size-footnote);
  color: var(--color-text-main);
}

.status {
  font-weight: var(--font-weight-semibold);
}

.status.normal {
  color: #15803d;
}

.status.expiring {
  color: #b45309;
}

.status.expired {
  color: #b91c1c;
}

.status.unknown {
  color: var(--color-text-secondary);
}

.thumbs {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-3);
  margin-top: var(--space-4);
}

.thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
  background: rgba(17, 24, 39, 0.04);
}

.img {
  width: 100%;
  height: 100%;
}

.remark {
  width: 100%;
  min-height: 160rpx;
  margin-top: var(--space-4);
  padding: 18rpx 20rpx;
  box-sizing: border-box;
  border-radius: var(--radius-lg);
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(17, 24, 39, 0.06);
  font-size: var(--font-size-body);
  color: var(--color-text-main);
}

.submit-action {
  margin-top: var(--space-4);
}

.hash-box {
  margin-top: var(--space-4);
  padding: 18rpx 20rpx;
  border-radius: var(--radius-lg);
  background: rgba(17, 24, 39, 0.04);
}

.hash-label {
  display: block;
  font-size: var(--font-size-caption);
  color: var(--color-text-secondary);
}

.hash-value,
.hash-mini {
  display: block;
  margin-top: 8rpx;
  font-size: var(--font-size-caption);
  line-height: 1.6;
  color: var(--color-text-main);
  word-break: break-all;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
  margin-top: var(--space-4);
}

.history-cell {
  align-items: flex-start;
  min-height: 124rpx;
}
