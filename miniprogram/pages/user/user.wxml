<view class="page-shell profile-page">
  <view class="content-wrapper profile-wrapper">
    <view class="profile-card panel">
      <view class="panel-section">
        <view class="profile-head" wx:if="{{enterpriseUser}}">
          <view class="profile-avatar">{{enterpriseUser.companyName.slice(0, 1)}}</view>
          <view class="profile-copy">
            <view class="page-title profile-title">{{enterpriseUser.companyName}}</view>
            <view class="page-subtitle">{{text.legalPerson}}: {{enterpriseUser.legalPerson}}</view>
          </view>
        </view>

        <view class="profile-head profile-guest" wx:else bindtap="goToLogin">
          <view class="profile-avatar">ID</view>
          <view class="profile-copy">
            <view class="page-title profile-title">{{text.signedOut}}</view>
            <view class="page-subtitle">{{text.tapToLogin}}</view>
          </view>
        </view>
      </view>
    </view>

    <view class="profile-section panel" wx:if="{{enterpriseUser}}">
      <view class="panel-section">
        <view class="section-title">{{text.companyInfo}}</view>
        <view class="profile-info-list">
          <view class="list-cell">
            <view class="profile-info-copy">
              <view class="cell-subtitle">{{text.companyName}}</view>
              <view class="cell-title">{{enterpriseUser.companyName}}</view>
            </view>
          </view>
          <view class="list-cell">
            <view class="profile-info-copy">
              <view class="cell-subtitle">{{text.creditCode}}</view>
              <view class="cell-title profile-code">{{enterpriseUser.creditCode}}</view>
            </view>
          </view>
          <view class="list-cell">
            <view class="profile-info-copy">
              <view class="cell-subtitle">{{text.phone}}</view>
              <view class="cell-title">{{enterpriseUser.phone}}</view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="profile-section panel">
      <view class="panel-section">
        <view class="section-title" wx:if="{{enterpriseUser}}">{{text.reminderSettings}}</view>
        <view class="profile-menu-list">
          <view class="list-cell" bindtap="subscribeAlert" wx:if="{{enterpriseUser}}">
            <view class="profile-info-copy">
              <view class="cell-title">{{text.subscribe}}</view>
              <view class="cell-subtitle">{{alertSettings && alertSettings.wxSubscribed ? text.subscribeHintOn : text.subscribeHintOff}}</view>
            </view>
            <view class="cell-meta">{{alertSettings && alertSettings.wxSubscribed ? text.subscribeOn : text.subscribeOff}}</view>
          </view>
          <view class="list-cell" wx:if="{{enterpriseUser && alertSettings && alertSettings.lastSubscribeTime}}">
            <view class="profile-info-copy">
              <view class="cell-subtitle">{{text.lastSubscribeTime}}</view>
              <view class="cell-title">{{alertSettings.lastSubscribeTime}}</view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="profile-section panel">
      <view class="panel-section">
        <view class="section-title" wx:if="{{enterpriseUser}}">{{text.assets}}</view>
        <view class="profile-menu-list">
          <view class="list-cell" bindtap="goToEquipmentLibrary" wx:if="{{enterpriseUser}}">
            <view class="cell-title">{{text.archive}}</view>
            <view class="cell-meta">></view>
          </view>
          <view class="list-cell" bindtap="goToGaugeLibrary" wx:if="{{enterpriseUser}}">
            <view class="cell-title">{{text.gauges}}</view>
            <view class="cell-meta">></view>
          </view>
          <view class="list-cell" bindtap="clearCache">
            <view class="cell-title">{{text.clearCache}}</view>
            <view class="cell-meta">></view>
          </view>
          <view class="list-cell" bindtap="logout" wx:if="{{enterpriseUser}}">
            <view class="cell-title profile-danger">{{text.logout}}</view>
            <view class="cell-meta">></view>
          </view>
        </view>
      </view>
    </view>

    <view class="profile-version">{{text.version}}</view>
  </view>
</view>
