.profile-wrapper {
  padding-top: var(--space-5);
  padding-bottom: var(--space-8);
}

.profile-card,
.profile-section {
  margin-bottom: var(--space-5);
}

.profile-head {
  display: flex;
  align-items: center;
  gap: var(--space-5);
}

.profile-guest:active {
  opacity: 0.88;
}

.profile-avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 52rpx;
  background: linear-gradient(180deg, #ffffff 0%, #eaf3ff 100%);
  color: var(--color-brand);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-title2);
  font-weight: var(--font-weight-bold);
  box-shadow: inset 0 0 0 1rpx rgba(0, 122, 255, 0.08);
}

.profile-copy {
  flex: 1;
  min-width: 0;
}

.profile-title {
  font-size: var(--font-size-title2);
}

.profile-info-list,
.profile-menu-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
  margin-top: var(--space-5);
}

.profile-info-copy {
  flex: 1;
  min-width: 0;
}

.profile-code {
  font-size: var(--font-size-body);
}

.profile-danger {
  color: var(--color-danger);
}

.profile-version {
  text-align: center;
  color: var(--color-text-tertiary);
  font-size: var(--font-size-caption);
  padding-bottom: calc(var(--space-7) + env(safe-area-inset-bottom));
}
