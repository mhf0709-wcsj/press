.admin-workbench-scroll {
  height: 100vh;
}

.admin-workbench-wrapper {
  padding-top: var(--space-5);
  padding-bottom: 160rpx;
}

.hero-panel {
  margin-bottom: var(--space-5);
}

.hero-title {
  margin-top: var(--space-4);
}

.mode-switch {
  display: flex;
  gap: 8rpx;
  padding: 6rpx;
  border-radius: var(--radius-pill);
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(17, 24, 39, 0.06);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.6);
}

.mode-pill {
  flex: 1;
  min-height: 64rpx;
  border-radius: var(--radius-pill);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-caption);
  color: var(--color-text-secondary);
  font-weight: var(--font-weight-medium);
  transition: background var(--transition-fast), color var(--transition-fast), box-shadow var(--transition-fast);
}

.mode-pill.active {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(234, 243, 255, 0.96));
  color: var(--color-brand);
  font-weight: var(--font-weight-semibold);
  box-shadow: 0 8rpx 20rpx rgba(0, 122, 255, 0.12);
}

.mode-pill:not(.active):active {
  background: rgba(17, 24, 39, 0.04);
}

.admin-bottom-switch {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  padding: 14rpx;
  padding-bottom: calc(14rpx + env(safe-area-inset-bottom));
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(17, 24, 39, 0.06);
  box-shadow: var(--shadow-md);
  backdrop-filter: blur(24rpx);
  z-index: 20;
}

.entry-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
  margin-top: var(--space-4);
}

.entry-cell {
  min-height: 96rpx;
}

.entry-arrow {
  font-size: 28rpx;
  color: var(--color-text-muted);
}
