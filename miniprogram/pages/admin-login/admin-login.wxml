<view class="page-shell admin-page">
  <view class="admin-shell">
    <view class="admin-card">
      <view class="admin-brand">
        <view class="brand-mark">A</view>
        <view class="brand-name">{{text.brandName}}</view>
      </view>

      <view class="admin-copy">
        <view class="admin-title">{{text.title}}</view>
        <view class="admin-desc" wx:if="{{text.desc}}">{{text.desc}}</view>
      </view>

      <view class="admin-form">
        <view class="field-block">
          <view class="field-label">{{text.usernameLabel}}</view>
          <input
            class="field-input"
            placeholder="{{text.usernamePlaceholder}}"
            value="{{username}}"
            bindinput="onInputUsername"
            placeholder-class="input-placeholder"
          />
        </view>

        <view class="field-block">
          <view class="field-label">{{text.passwordLabel}}</view>
          <input
            class="field-input"
            password
            placeholder="{{text.passwordPlaceholder}}"
            value="{{password}}"
            bindinput="onInputPassword"
            placeholder-class="input-placeholder"
          />
        </view>
      </view>

      <button
        class="btn-primary-solid admin-submit {{loading ? 'is-loading' : ''}}"
        bindtap="handleLogin"
        disabled="{{loading}}"
      >
        <text>{{loading ? text.submitting : text.submit}}</text>
      </button>

      <view class="admin-actions">
        <button class="btn-ghost-link admin-entry" bindtap="goToEnterprise">{{text.backToEnterprise}}</button>
      </view>
    </view>
  </view>
</view>

<privacy />
