.admin-page {
  min-height: 100vh;
}

.admin-wrapper {
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-height: 100vh;
  padding-top: 56rpx;
  padding-bottom: 56rpx;
}

.admin-hero {
  margin-bottom: 26rpx;
  padding: 12rpx 8rpx 0;
}

.admin-badge {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(15, 26, 46, 0.9);
  color: var(--color-text-white);
  font-size: var(--font-size-xs);
  letter-spacing: 1rpx;
}

.admin-title {
  margin-top: 24rpx;
  font-size: 52rpx;
  line-height: 1.14;
  font-weight: var(--font-weight-bold);
  color: var(--color-text-main);
}

.admin-desc {
  margin-top: 16rpx;
  font-size: var(--font-size-base);
  line-height: 1.7;
  color: var(--color-text-secondary);
}

.admin-panel {
  width: 100%;
}

.panel-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.admin-pill {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(15, 26, 46, 0.08);
  color: #22324f;
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-medium);
}

.input-placeholder {
  color: var(--color-text-muted);
}

.admin-submit {
  width: 100%;
  margin-top: 20rpx;
}

.admin-submit.is-loading {
  opacity: 0.78;
}

.admin-tips {
  margin-top: 28rpx;
}

.tip-card {
  padding: 20rpx 22rpx;
  border-radius: 20rpx;
  background: var(--color-bg-subtle);
}

.tip-label {
  display: block;
  font-size: var(--font-size-xs);
  color: var(--color-text-muted);
}

.tip-value {
  display: block;
  margin-top: 8rpx;
  font-size: var(--font-size-sm);
  color: var(--color-text-main);
  font-weight: var(--font-weight-medium);
}

.admin-footer {
  display: flex;
  justify-content: center;
  margin-top: 24rpx;
}
