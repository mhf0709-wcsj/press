.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #722ed1 0%, #531dab 100%);
  padding: 60rpx 40rpx;
  box-sizing: border-box;
}

.header {
  text-align: center;
  margin-bottom: 80rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.form {
  background: #fff;
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.1);
}

.form-item {
  margin-bottom: 40rpx;
}

.label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.input {
  height: 88rpx;
  border: 2rpx solid #e5e5e5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  background: #f8f8f8;
  transition: all 0.3s;
}

.input:focus {
  border-color: #722ed1;
  background: #fff;
}

.login-btn {
  width: 100%;
  height: 88rpx;
  background: #722ed1;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: none;
  margin-top: 20rpx;
}

.login-btn[disabled] {
  background: #b37feb;
}

.back-link {
  text-align: center;
  margin-top: 40rpx;
  font-size: 26rpx;
}

.link {
  color: #722ed1;
}
