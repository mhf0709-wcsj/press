.admin-page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(221, 227, 240, 0.84), transparent 34%),
    radial-gradient(circle at bottom right, rgba(236, 240, 247, 0.94), transparent 36%),
    #f7f9fc;
}

.admin-shell {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 72rpx 40rpx 48rpx;
}

.admin-card {
  width: 100%;
  max-width: 680rpx;
  padding: 52rpx 42rpx 38rpx;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(214, 222, 235, 0.9);
  box-shadow: 0 22rpx 70rpx rgba(28, 48, 86, 0.08);
}

.admin-brand {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.brand-mark {
  width: 76rpx;
  height: 76rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #22324f 0%, #111c2f 100%);
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 700;
  box-shadow: 0 12rpx 28rpx rgba(17, 28, 47, 0.2);
}

.brand-name {
  font-size: 24rpx;
  line-height: 1;
  color: #5f6368;
}

.admin-copy {
  margin-top: 34rpx;
}

.admin-title {
  font-size: 58rpx;
  line-height: 1.12;
  font-weight: 700;
  color: #202124;
}

.admin-desc {
  margin-top: 14rpx;
  font-size: 28rpx;
  color: #5f6368;
}

.admin-form {
  margin-top: 36rpx;
}

.field-block + .field-block {
  margin-top: 22rpx;
}

.field-label {
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: #3c4043;
  font-weight: 500;
}

.field-input {
  width: 100%;
  min-height: 96rpx;
  padding: 0 26rpx;
  border-radius: 22rpx;
  border: 2rpx solid #dadce0;
  background: #ffffff;
  font-size: 28rpx;
  color: #202124;
  box-sizing: border-box;
}

.input-placeholder {
  color: #9aa0a6;
}

.admin-submit {
  width: 100%;
  margin-top: 32rpx;
  border-radius: 999rpx;
}

.admin-submit.is-loading {
  opacity: 0.82;
}

.admin-actions {
  margin-top: 28rpx;
  display: flex;
  justify-content: center;
}

.admin-entry {
  min-height: auto;
  padding: 0;
  color: #3c4043;
  font-size: 24rpx;
}
