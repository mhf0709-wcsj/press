<view class="camera-page">
  <view class="camera-header">
    <view class="camera-back" bindtap="goBack">返回</view>
    <view class="camera-title">{{activeTab === 'manual' ? '手动建档' : '确认并保存'}}</view>
    <view class="camera-placeholder"></view>
  </view>

  <scroll-view scroll-y class="camera-scroll">
    <view class="camera-content">
      <view class="camera-card" wx:if="{{aiInsight}}">
        <view class="camera-card-title">AI 识别结果</view>
      </view>

      <view class="camera-card">
        <view class="camera-card-title">基础信息</view>
        <view class="camera-field">
          <text class="camera-label">证书编号</text>
          <input class="camera-input" value="{{formData.certNo}}" bindinput="onInput" data-field="certNo" placeholder="请输入证书编号" />
        </view>
        <view class="camera-field">
          <text class="camera-label">出厂编号</text>
          <input class="camera-input" value="{{formData.factoryNo}}" bindinput="onInput" data-field="factoryNo" placeholder="请输入出厂编号" />
        </view>
        <view class="camera-field">
          <text class="camera-label">送检单位</text>
          <input class="camera-input" value="{{formData.sendUnit}}" bindinput="onInput" data-field="sendUnit" placeholder="请输入送检单位" />
        </view>
        <view class="camera-field">
          <text class="camera-label">仪表名称</text>
          <input class="camera-input" value="{{formData.instrumentName}}" bindinput="onInput" data-field="instrumentName" placeholder="请输入仪表名称" />
        </view>
        <view class="camera-field">
          <text class="camera-label">型号规格</text>
          <input class="camera-input" value="{{formData.modelSpec}}" bindinput="onInput" data-field="modelSpec" placeholder="请输入型号规格" />
        </view>
        <view class="camera-field no-border">
          <text class="camera-label">制造单位</text>
          <input class="camera-input" value="{{formData.manufacturer}}" bindinput="onInput" data-field="manufacturer" placeholder="请输入制造单位" />
        </view>
      </view>

      <view class="camera-card">
        <view class="camera-card-title">检定信息</view>
        <view class="camera-field">
          <text class="camera-label">检定依据</text>
          <input class="camera-input" value="{{formData.verificationStd}}" bindinput="onInput" data-field="verificationStd" placeholder="例如 JJG52-2013" />
        </view>
        <picker mode="selector" range="{{['合格', '不合格']}}" value="{{conclusionIndex}}" bindchange="onConclusionChange">
          <view class="camera-field">
            <text class="camera-label">检定结论</text>
            <view class="camera-picker">
              <text class="camera-picker-text">{{formData.conclusion || '请选择'}}</text>
              <text class="camera-arrow">></text>
            </view>
          </view>
        </picker>
        <picker mode="date" value="{{formData.verificationDate}}" bindchange="onDateChange">
          <view class="camera-field">
            <text class="camera-label">检定日期</text>
            <view class="camera-picker">
              <text class="camera-picker-text">{{formData.verificationDate || '请选择'}}</text>
              <text class="camera-arrow">></text>
            </view>
          </view>
        </picker>
        <view class="camera-field no-border">
          <text class="camera-label">到期日期</text>
          <text class="camera-static camera-static-text">{{expiryDateText || '自动计算'}}</text>
        </view>
      </view>

      <view class="camera-card">
        <view class="camera-card-title">关联信息</view>
        <picker mode="selector" range="{{districtOptions}}" value="{{districtIndex}}" bindchange="onDistrictChange">
          <view class="camera-field">
            <text class="camera-label">辖区</text>
            <view class="camera-picker">
              <text class="camera-picker-text">{{formData.district || '请选择'}}</text>
              <text class="camera-arrow">></text>
            </view>
          </view>
        </picker>
        <picker mode="selector" range="{{equipments}}" range-key="equipmentName" value="{{equipmentIndex}}" bindchange="onEquipmentChange">
          <view class="camera-field">
            <text class="camera-label">所属设备</text>
            <view class="camera-picker">
              <text class="camera-picker-text">{{selectedEquipmentName || '请选择'}}</text>
              <text class="camera-arrow">></text>
            </view>
          </view>
        </picker>
        <picker mode="selector" range="{{gaugeStatusOptions}}" value="{{gaugeStatusIndex}}" bindchange="onGaugeStatusChange">
          <view class="camera-field no-border">
            <text class="camera-label">压力表状态</text>
            <view class="camera-picker">
              <text class="camera-picker-text">{{gaugeStatus}}</text>
              <text class="camera-arrow">></text>
            </view>
          </view>
        </picker>
      </view>

      <view class="camera-card">
        <view class="camera-card-title">证书照片</view>
        <view class="camera-upload" bindtap="uploadImage" wx:if="{{!imagePath}}">
          <view class="camera-upload-empty">上传证书照片</view>
        </view>
        <view class="camera-upload" bindtap="previewImage" wx:else>
          <image src="{{imagePath}}" mode="aspectFill" class="camera-image" />
        </view>
      </view>

      <view class="camera-card">
        <view class="camera-card-title">安装照片</view>
        <view class="camera-upload" bindtap="uploadInstallPhoto" wx:if="{{!installPhotoPath}}">
          <view class="camera-upload-empty">{{gaugeStatusIndex === 0 ? '上传安装照片（必传）' : '上传安装照片（选传）'}}</view>
        </view>
        <view class="camera-upload" bindtap="previewInstallPhoto" wx:else>
          <image src="{{installPhotoPath}}" mode="aspectFill" class="camera-image" />
        </view>
      </view>

      <view class="camera-spacer"></view>
    </view>
  </scroll-view>

  <view class="camera-footer">
    <button class="camera-reset" bindtap="resetForm">重置</button>
    <button class="camera-save" bindtap="saveRecord" loading="{{saving}}">{{saving ? '保存中...' : '确认存档'}}</button>
  </view>

  <privacy />
</view>
