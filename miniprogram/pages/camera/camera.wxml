<view class="container">
  <!-- 大标题区域 -->
  <view class="header-section">
    <view class="header-content">
      <text class="large-title">数据填报</text>
      
    </view>
  </view>

  <!-- Tab切换 -->
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 'ocr' ? 'active' : ''}}" bindtap="switchTab" data-tab="ocr">
      <text class="tab-icon">📷</text>
      <text class="tab-text">拍照识别</text>
    </view>
    <view class="tab-item {{activeTab === 'manual' ? 'active' : ''}}" bindtap="switchTab" data-tab="manual">
      <text class="tab-icon">✏️</text>
      <text class="tab-text">手动填报</text>
    </view>
  </view>

  <!-- 拍照识别模式 -->
  <view class="content-section" wx:if="{{activeTab === 'ocr'}}">
    <!-- 拍摄指南卡片 -->
    <view class="card-group" wx:if="{{!imagePath && !showEditForm}}">
      <view class="card">
        <view class="card-content">
          <view class="guide-row">
            <view class="guide-icon-box">
              <text class="guide-icon">📷</text>
            </view>
            <view class="guide-text">
              <text class="guide-title">拍摄检定证书</text>
              <text class="guide-desc">请确保证书完整、清晰入镜</text>
            </view>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 开始拍摄按钮 - 居中突出 -->
    <view class="photo-action-area" wx:if="{{!imagePath && !showEditForm}}">
      <button class="primary-btn-large" bindtap="takePhoto">
        <text class="btn-icon-large">📷</text>
        <text class="btn-text-large">开始识别</text>
      </button>
    </view>
    
    <!-- 拍摄提示 - 简洁文字 -->
    <view class="tips-simple" wx:if="{{!imagePath && !showEditForm}}">
      <text class="tips-text">拍摄提示：证书平铺 · 光线充足 · 垂直拍摄 · 文字清晰</text>
    </view>

    <!-- 预览区域 -->
    <view class="card-group" wx:if="{{imagePath && !showEditForm}}">
      <view class="card">
        <view class="card-content">
          <text class="section-label">证书预览</text>
          <image src="{{imagePath}}" mode="widthFix" class="preview-img" bindtap="previewImage" />
          
          <view wx:if="{{qualityScore > 0}}" class="quality-section">
            <view class="quality-row">
              <text class="quality-label">图片质量</text>
              <text class="quality-value {{qualityScore >= 0.7 ? 'good' : qualityScore >= 0.5 ? 'ok' : 'poor'}}">
                {{qualityScore >= 0.7 ? '优秀' : qualityScore >= 0.5 ? '良好' : '一般'}}
              </text>
            </view>
            <view class="progress-bar">
              <view class="progress-fill {{qualityScore >= 0.7 ? 'good' : qualityScore >= 0.5 ? 'ok' : 'poor'}}" style="width: {{qualityScore * 100}}%"></view>
            </view>
          </view>
        </view>
      </view>
    </view>
    
    <view class="btn-group" wx:if="{{imagePath && !showEditForm}}">
      <button class="secondary-btn" bindtap="retakePhoto">
        <text class="btn-icon">↺</text>
        <text class="btn-text">重拍</text>
      </button>
      <button class="primary-btn" bindtap="startOCR" loading="{{ocrLoading}}">
        <text class="btn-icon">🔍</text>
        <text class="btn-text">{{ocrLoading ? '识别中' : '开始识别'}}</text>
      </button>
    </view>

    <!-- OCR识别后的表单 -->
    <view class="form-section" wx:if="{{showEditForm}}">
      <view class="card-group">
        <!-- 基本信息 -->
        <view class="card">
          <view class="card-header">
            <text class="card-title">基本信息</text>
          </view>
          <view class="card-content">
            <view class="form-row">
              <text class="form-label">证书编号</text>
              <input class="form-input" value="{{formData.certNo}}" bindinput="onInput" data-field="certNo" placeholder="必填" placeholder-class="placeholder-required" />
            </view>
            <view class="form-row">
              <text class="form-label">出厂编号</text>
              <input class="form-input" value="{{formData.factoryNo}}" bindinput="onInput" data-field="factoryNo" placeholder="必填" placeholder-class="placeholder-required" />
            </view>
            <view class="form-row">
              <text class="form-label">送检单位</text>
              <input class="form-input" value="{{formData.sendUnit}}" bindinput="onInput" data-field="sendUnit" placeholder="选填" />
            </view>
            <view class="form-row">
              <text class="form-label">器具名称</text>
              <input class="form-input" value="{{formData.instrumentName}}" bindinput="onInput" data-field="instrumentName" placeholder="压力表" />
            </view>
            <view class="form-row">
              <text class="form-label">型号规格</text>
              <input class="form-input" value="{{formData.modelSpec}}" bindinput="onInput" data-field="modelSpec" placeholder="选填" />
            </view>
            <view class="form-row last">
              <text class="form-label">制造单位</text>
              <input class="form-input" value="{{formData.manufacturer}}" bindinput="onInput" data-field="manufacturer" placeholder="选填" />
            </view>
          </view>
        </view>
        
        <!-- 检定信息 -->
        <view class="card">
          <view class="card-header">
            <text class="card-title">检定信息</text>
          </view>
          <view class="card-content">
            <view class="form-row">
              <text class="form-label">检定依据</text>
              <input class="form-input" value="{{formData.verificationStd}}" bindinput="onInput" data-field="verificationStd" placeholder="JJG52-2013" />
            </view>
            <view class="form-row">
              <text class="form-label">检定结论</text>
              <picker mode="selector" range="{{['合格', '不合格']}}" value="{{conclusionIndex}}" bindchange="onConclusionChange">
                <view class="form-picker">
                  <text class="picker-value">{{formData.conclusion}}</text>
                  <text class="picker-arrow">›</text>
                </view>
              </picker>
            </view>
            <view class="form-row">
              <text class="form-label">检定日期</text>
              <picker mode="date" value="{{formData.verificationDate}}" bindchange="onDateChange">
                <view class="form-picker">
                  <text class="picker-value">{{formData.verificationDate || '请选择'}}</text>
                  <text class="picker-arrow">›</text>
                </view>
              </picker>
            </view>
            <view class="form-row last">
              <text class="form-label">到期日期</text>
              <text class="form-readonly">{{expiryDateText || '自动计算'}}</text>
            </view>
          </view>
        </view>

        <!-- 所在辖区 -->
        <view class="card">
          <view class="card-header">
            <text class="card-title">所在辖区</text>
          </view>
          <view class="card-content">
            <picker mode="selector" range="{{districtOptions}}" value="{{districtIndex}}" bindchange="onDistrictChange">
            <view class="form-row last">
              <text class="form-label">辖区</text>
              <view class="form-picker">
                <text class="picker-value">{{formData.district || '请选择'}}</text>
                <text class="picker-arrow">›</text>
              </view>
            </view>
          </picker>
          </view>
        </view>

        <!-- 证书图片 -->
        <view class="card" wx:if="{{imagePath}}">
          <view class="card-header">
            <text class="card-title">证书图片</text>
            <text class="card-action" bindtap="previewImage">查看原图</text>
          </view>
          <view class="card-content">
            <image src="{{imagePath}}" mode="aspectFill" class="thumb-img" bindtap="previewImage" />
          </view>
        </view>

        <!-- 安装照片（必填） -->
        <view class="card">
          <view class="card-header">
            <text class="card-title">安装照片</text>
            <text class="card-required">必传</text>
          </view>
          <view class="card-content">
            <view class="upload-area" bindtap="uploadInstallPhoto" wx:if="{{!installPhotoPath}}">
              <text class="upload-icon">🔧</text>
              <text class="upload-text">点击上传安装照片</text>
              <text class="upload-hint">压力表安装现场照片</text>
            </view>
            <view class="image-preview" wx:else>
              <image src="{{installPhotoPath}}" mode="aspectFill" class="preview-thumb" bindtap="previewInstallPhoto" />
              <view class="image-actions">
                <text class="action-text" bindtap="previewInstallPhoto">查看</text>
                <text class="action-text" bindtap="deleteInstallPhoto">删除</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 手动填报模式 -->
  <view class="content-section form-page" wx:if="{{activeTab === 'manual'}}">
    <view class="card-group">
      <!-- 基本信息 -->
      <view class="card">
        <view class="card-header">
          <text class="card-title">基本信息</text>
        </view>
        <view class="card-content">
          <view class="form-row">
            <text class="form-label">证书编号</text>
            <input class="form-input" value="{{formData.certNo}}" bindinput="onInput" data-field="certNo" placeholder="必填" placeholder-class="placeholder-required" />
          </view>
          <view class="form-row">
            <text class="form-label">出厂编号</text>
            <input class="form-input" value="{{formData.factoryNo}}" bindinput="onInput" data-field="factoryNo" placeholder="必填" placeholder-class="placeholder-required" />
          </view>
          <view class="form-row">
            <text class="form-label">送检单位</text>
            <input class="form-input" value="{{formData.sendUnit}}" bindinput="onInput" data-field="sendUnit" placeholder="选填" />
          </view>
          <view class="form-row">
            <text class="form-label">器具名称</text>
            <input class="form-input" value="{{formData.instrumentName}}" bindinput="onInput" data-field="instrumentName" placeholder="压力表" />
          </view>
          <view class="form-row">
            <text class="form-label">型号规格</text>
            <input class="form-input" value="{{formData.modelSpec}}" bindinput="onInput" data-field="modelSpec" placeholder="选填" />
          </view>
          <view class="form-row last">
            <text class="form-label">制造单位</text>
            <input class="form-input" value="{{formData.manufacturer}}" bindinput="onInput" data-field="manufacturer" placeholder="选填" />
          </view>
        </view>
      </view>
      
      <!-- 检定信息 -->
      <view class="card">
        <view class="card-header">
          <text class="card-title">检定信息</text>
        </view>
        <view class="card-content">
          <view class="form-row">
            <text class="form-label">检定依据</text>
            <input class="form-input" value="{{formData.verificationStd}}" bindinput="onInput" data-field="verificationStd" placeholder="JJG52-2013" />
          </view>
          <view class="form-row">
            <text class="form-label">检定结论</text>
            <picker mode="selector" range="{{['合格', '不合格']}}" value="{{conclusionIndex}}" bindchange="onConclusionChange">
              <view class="form-picker">
                <text class="picker-value">{{formData.conclusion}}</text>
                <text class="picker-arrow">›</text>
              </view>
            </picker>
          </view>
          <view class="form-row">
            <text class="form-label">检定日期</text>
            <picker mode="date" value="{{formData.verificationDate}}" bindchange="onDateChange">
              <view class="form-picker">
                <text class="picker-value">{{formData.verificationDate || '请选择'}}</text>
                <text class="picker-arrow">›</text>
              </view>
            </picker>
          </view>
          <view class="form-row last">
            <text class="form-label">到期日期</text>
            <text class="form-readonly">{{expiryDateText || '自动计算'}}</text>
          </view>
        </view>
      </view>

      <!-- 所在辖区 -->
      <view class="card">
        <view class="card-header">
          <text class="card-title">所在辖区</text>
        </view>
        <view class="card-content">
          <picker mode="selector" range="{{districtOptions}}" value="{{districtIndex}}" bindchange="onDistrictChange">
            <view class="form-row last">
              <text class="form-label">辖区</text>
              <view class="form-picker">
                <text class="picker-value">{{formData.district || '请选择'}}</text>
                <text class="picker-arrow">›</text>
              </view>
            </view>
          </picker>
        </view>
      </view>

      <!-- 图片上传（必填） -->
      <view class="card">
        <view class="card-header">
          <text class="card-title">检定表图片</text>
          <text class="card-required">必传</text>
        </view>
        <view class="card-content">
          <view class="upload-area" bindtap="uploadImage" wx:if="{{!imagePath}}">
            <text class="upload-icon">📷</text>
            <text class="upload-text">点击上传检定表</text>
            <text class="upload-hint">作为备查材料</text>
          </view>
          <view class="image-preview" wx:else>
            <image src="{{imagePath}}" mode="aspectFill" class="preview-thumb" bindtap="previewImage" />
            <view class="image-actions">
              <text class="action-text" bindtap="previewImage">查看</text>
              <text class="action-text" bindtap="deleteImage">删除</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 安装照片（必填） -->
      <view class="card">
        <view class="card-header">
          <text class="card-title">安装照片</text>
          <text class="card-required">必传</text>
        </view>
        <view class="card-content">
          <view class="upload-area" bindtap="uploadInstallPhoto" wx:if="{{!installPhotoPath}}">
            <text class="upload-icon">🔧</text>
            <text class="upload-text">点击上传安装照片</text>
            <text class="upload-hint">压力表安装现场照片</text>
          </view>
          <view class="image-preview" wx:else>
            <image src="{{installPhotoPath}}" mode="aspectFill" class="preview-thumb" bindtap="previewInstallPhoto" />
            <view class="image-actions">
              <text class="action-text" bindtap="previewInstallPhoto">查看</text>
              <text class="action-text" bindtap="deleteInstallPhoto">删除</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar" wx:if="{{showEditForm || activeTab === 'manual'}}">
    <button class="secondary-btn" bindtap="resetForm">重置</button>
    <button class="primary-btn" bindtap="saveRecord" loading="{{saving}}">
      {{saving ? '保存中' : '确认存档'}}
    </button>
  </view>

  <!-- 到期提醒弹窗 -->
  <view class="modal-overlay" wx:if="{{showExpiryModal}}" bindtap="closeExpiryModal">
    <view class="modal-content" catchtap>
      <view class="modal-header">
        <text class="modal-icon">⚠️</text>
        <text class="modal-title">到期提醒</text>
      </view>
      
      <view class="modal-body">
        <view class="reminder-summary">
          <view class="summary-item expired" wx:if="{{expiryReminder.expiredCount > 0}}">
            <text class="summary-count">{{expiryReminder.expiredCount}}</text>
            <text class="summary-label">已过期</text>
          </view>
          <view class="summary-item expiring" wx:if="{{expiryReminder.expiringCount > 0}}">
            <text class="summary-count">{{expiryReminder.expiringCount}}</text>
            <text class="summary-label">即将到期</text>
          </view>
        </view>
        
        <view class="record-list" wx:if="{{expiryReminder.expiredList.length > 0}}">
          <text class="list-title">已过期设备</text>
          <view class="record-item" wx:for="{{expiryReminder.expiredList}}" wx:key="_id">
            <text class="record-no">{{item.factoryNo}}</text>
            <text class="record-date expired">{{item.expiryDate}}</text>
          </view>
        </view>
        
        <view class="record-list" wx:if="{{expiryReminder.expiringList.length > 0}}">
          <text class="list-title">即将到期设备</text>
          <view class="record-item" wx:for="{{expiryReminder.expiringList}}" wx:key="_id">
            <text class="record-no">{{item.factoryNo}}</text>
            <text class="record-date expiring">{{item.expiryDate}}</text>
          </view>
        </view>
      </view>
      
      <view class="modal-footer">
        <button class="modal-btn secondary" bindtap="closeExpiryModal">稍后处理</button>
        <button class="modal-btn primary" bindtap="viewExpiryRecords">查看详情</button>
      </view>
    </view>
  </view>
</view>

<!-- 隐私弹窗 -->
<privacy />

<!-- AI悬浮按钮 -->
<ai-float-btn />
