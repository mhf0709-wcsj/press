.camera-page {
  min-height: 100vh;
  background: #f6f7fb;
}

.camera-header {
  position: sticky;
  top: 0;
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  background: rgba(255, 255, 255, 0.94);
  border-bottom: 1rpx solid rgba(15, 23, 42, 0.06);
}

.camera-back,
.camera-placeholder {
  width: 120rpx;
  font-size: 28rpx;
  color: #1f6feb;
}

.camera-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
}

.camera-scroll {
  height: calc(100vh - 132rpx);
}

.camera-content {
  padding: 24rpx;
  padding-bottom: 180rpx;
}

.camera-card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.06);
}

.camera-card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
}

.camera-card-desc {
  margin-top: 12rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #4b5563;
}

.camera-field {
  display: flex;
  align-items: center;
  gap: 20rpx;
  min-height: 92rpx;
  border-bottom: 1rpx solid rgba(15, 23, 42, 0.06);
}

.camera-field.no-border {
  border-bottom: none;
}

.camera-label {
  width: 160rpx;
  flex-shrink: 0;
  font-size: 28rpx;
  color: #6b7280;
}

.camera-input,
.camera-picker,
.camera-static {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  color: #111827;
  text-align: right;
}

.camera-picker {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 12rpx;
}

.camera-arrow {
  color: #9ca3af;
}

.camera-upload {
  margin-top: 20rpx;
  border-radius: 24rpx;
  background: #f8fafc;
  border: 1rpx dashed rgba(15, 23, 42, 0.12);
  overflow: hidden;
}

.camera-image {
  width: 100%;
  height: 320rpx;
  display: block;
}

.camera-upload-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 220rpx;
  font-size: 30rpx;
  color: #4b5563;
}

.camera-footer {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  display: flex;
  gap: 16rpx;
  padding: 16rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.08);
}

.camera-reset,
.camera-save {
  flex: 1;
  min-height: 88rpx;
  border: none;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.camera-reset::after,
.camera-save::after {
  border: none;
}

.camera-reset {
  background: #eef2f7;
  color: #111827;
}

.camera-save {
  background: #1f6feb;
  color: #ffffff;
}

.camera-spacer {
  height: 1rpx;
}
