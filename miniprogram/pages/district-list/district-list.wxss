.container {
  min-height: 100vh;
  background: #F3F4F6;
  padding: 32rpx;
  box-sizing: border-box;
  display: block;
  width: 100%;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 统计概览卡片 */
.summary-card {
  background: linear-gradient(135deg, #3B82F6 0%, #1D4ED8 100%);
  padding: 44rpx 32rpx;
  text-align: center;
  box-shadow: 0 10rpx 28rpx rgba(59, 130, 246, 0.28);
  width: 100%;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}

.summary-title {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.82);
  margin-bottom: 14rpx;
}

.summary-num {
  display: block;
  font-size: 88rpx;
  font-weight: 800;
  color: #fff;
  margin-bottom: 10rpx;
  letter-spacing: -1rpx;
}

.summary-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.75);
}

/* 列表卡片 */
.list-card {
  padding: 28rpx 28rpx 12rpx;
}

/* 辖区列表 */
.district-list {
  background: transparent;
  padding: 0;
  width: 100%;
  box-sizing: border-box;
}

.district-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 0;
  border-bottom: 2rpx solid #EEF2F7;
}

.district-card:last-child {
  border-bottom: none;
}

.district-card:active {
  opacity: 0.9;
}

.district-name {
  font-size: 32rpx;
  color: #111827;
  font-weight: 600;
}

.district-right {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.district-count {
  font-size: 26rpx;
  color: #1D4ED8;
  font-weight: 600;
  background: #EFF6FF;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
}

.district-arrow {
  font-size: 44rpx;
  color: #CBD5E1;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}
