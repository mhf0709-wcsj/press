<view class="page-shell district-page">
  <scroll-view scroll-y class="district-scroll">
    <view class="content-wrapper district-wrapper">
      <view class="panel hero-panel">
        <view class="panel-section">
          <view class="eyebrow">{{text.heroTopline}}</view>
          <view class="page-title hero-title">{{text.heroTitle}}</view>
          <view class="page-subtitle" wx:if="{{text.heroDesc}}">{{text.heroDesc}}</view>
        </view>
      </view>

      <view class="panel summary-panel">
        <view class="panel-section">
          <text class="section-title">{{text.summaryTitle}}</text>
          <text class="summary-number">{{totalEquipments}}</text>
          <text class="section-note" wx:if="{{text.summaryDesc}}">{{text.summaryDesc}}</text>
        </view>
      </view>

      <view class="panel">
        <view class="panel-section">
          <view class="list-block" wx:if="{{districtStats.length}}">
            <view
              class="list-cell district-cell"
              wx:for="{{districtStats}}"
              wx:key="district"
              bindtap="goToDistrictRecords"
              data-district="{{item.district}}"
            >
              <view>
                <text class="cell-title">{{item.district}}</text>
                <text class="cell-subtitle">{{item.percent}}%</text>
              </view>
              <view class="district-side">
                <text class="district-count">{{item.count}} {{text.unit}}</text>
                <text class="entry-arrow">></text>
              </view>
            </view>
          </view>

          <view class="empty-state" wx:if="{{!districtStats.length && !loading}}">
            <text class="empty-text">{{text.empty}}</text>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
