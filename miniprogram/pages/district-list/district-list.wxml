<view class="container">
  <!-- 加载状态 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <view wx:if="{{!loading}}">
    <!-- 统计概览 -->
    <view class="card summary-card">
      <text class="summary-title">设备总数</text>
      <text class="summary-num">{{totalEquipments}}</text>
      <text class="summary-desc">台设备备案</text>
    </view>

    <!-- 辖区列表 -->
    <view class="card list-card">
      <view class="card-title">辖区统计</view>
      <view class="district-list">
        <view class="district-card" wx:for="{{districtStats}}" wx:key="district" bindtap="goToDistrictRecords" data-district="{{item.district}}">
          <text class="district-name">{{item.district}}</text>
          <view class="district-right">
            <text class="district-count">{{item.count}}台</text>
            <text class="district-arrow">›</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{districtStats.length === 0}}" class="empty">
      <text>暂无辖区数据</text>
    </view>
  </view>
</view>
