<view class="container">
  <!-- 拍摄指南卡片 -->
  <view class="card" wx:if="{{!imagePath && !showEditForm}}">
    <view class="card-title">📸 拍摄指南</view>
    
    <view class="guide-list">
      <view class="guide-item">
        <text class="guide-icon">✓</text>
        <text class="guide-text">证书平铺在白色桌面</text>
      </view>
      <view class="guide-item">
        <text class="guide-icon">✓</text>
        <text class="guide-text">手机垂直俯拍</text>
      </view>
      <view class="guide-item">
        <text class="guide-icon">✓</text>
        <text class="guide-text">确保8项参数清晰可见</text>
      </view>
      <view class="guide-item">
        <text class="guide-icon">✓</text>
        <text class="guide-text">光线均匀，无反光</text>
      </view>
    </view>
    
    <view class="guide-button">
      <button class="btn-take" bindtap="takePhoto">
        <text class="btn-icon">📸</text>
        <text class="btn-text">拍摄检定证书</text>
      </button>
    </view>
    
    <view class="guide-footer">
      <text class="guide-note">* 拍摄后将自动检测质量</text>
    </view>
  </view>

  <!-- 预览+识别区域 -->
  <view class="card" wx:elif="{{imagePath && !showEditForm}}">
    <view class="card-title">🖼️ 证书预览</view>
    
    <image src="{{imagePath}}" mode="widthFix" class="preview-img" />
    
    <view class="btn-group" style="margin-top: 20rpx;">
      <button class="btn cancel" bindtap="retakePhoto">↺ 重新拍摄</button>
      <button class="btn ocr" bindtap="startOCR" loading="{{ocrLoading}}">
        {{ocrLoading ? '识别中...' : '🔍 智能识别'}}
      </button>
    </view>
    
    <!-- 质量提示（修正：移除 .toFixed） -->
    <view wx:if="{{qualityScore > 0}}" class="quality-indicator">
      <text class="quality-text">质量: {{qualityScore * 100}}%</text>
      <text wx:if="{{qualityScore >= 0.7}}" class="quality-good">✓ 优秀</text>
      <text wx:elif="{{qualityScore >= 0.4}}" class="quality-ok">⚠️ 可用</text>
      <text wx:else class="quality-poor">✗ 建议重拍</text>
    </view>
  </view>

  <!-- 证书信息卡片 -->
  <view class="card" wx:if="{{showEditForm}}">
    <view class="card-title">📋 证书信息</view>
    
    <view class="form-row">
      <view class="label required">1. 证书编号</view>
      <input class="input" value="{{formData.certNo}}" bindinput="onInput" data-field="certNo" placeholder="" />
    </view>

    <view class="form-row">
      <view class="label required">2. 送检单位</view>
      <input class="input" value="{{formData.sendUnit}}" bindinput="onInput" data-field="sendUnit" placeholder="" />
    </view>

    <view class="form-row">
      <view class="label">3. 计量器具名称</view>
      <input class="input" value="{{formData.instrumentName}}" bindinput="onInput" data-field="instrumentName" placeholder="" />
    </view>

    <view class="form-row">
      <view class="label">4. 型号/规格</view>
      <input class="input" value="{{formData.modelSpec}}" bindinput="onInput" data-field="modelSpec" placeholder="" />
    </view>

    <view class="form-row">
      <view class="label required">5. 出厂编号</view>
      <input class="input" value="{{formData.factoryNo}}" bindinput="onInput" data-field="factoryNo" placeholder="" />
    </view>

    <view class="form-row">
      <view class="label">6. 制造单位</view>
      <input class="input" value="{{formData.manufacturer}}" bindinput="onInput" data-field="manufacturer" placeholder="" />
    </view>

    <view class="form-row">
      <view class="label">7. 检定依据</view>
      <input class="input" value="{{formData.verificationStd}}" bindinput="onInput" data-field="verificationStd" placeholder="" />
    </view>

    <view class="form-row">
      <view class="label required">8. 检定结论</view>
      <picker mode="selector" range="{{['合格', '不合格']}}" value="{{conclusionIndex}}" bindchange="onConclusionChange">
        <view class="picker">
          <text class="picker-text">{{formData.conclusion}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>
  </view>

  <!-- 检定信息卡片 -->
  <view class="card" wx:if="{{showEditForm}}">
    <view class="card-title">📅 检定信息</view>
    
    <view class="form-row">
      <view class="label required">检定日期</view>
      <picker mode="date" value="{{formData.verificationDate}}" bindchange="onDateChange">
        <view class="picker">
          <text class="picker-text">{{formData.verificationDate || '请选择检定日期'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>

    <view class="form-row">
      <view class="label">到期日期</view>
      <view class="readonly-text">{{expiryDateText || '自动计算（检定日期+6个月）'}}</view>
    </view>
  </view>

  <!-- 图片附件卡片 -->
  <view class="card" wx:if="{{showEditForm}}">
    <view class="card-title">📎 证书图片（备注材料）</view>
    
    <view wx:if="{{imagePath}}" class="image-preview">
      <image src="{{imagePath}}" mode="aspectFill" class="preview-image" bindtap="previewImage" />
      <button class="btn-delete" bindtap="deleteImage">🗑️ 删除图片</button>
    </view>
    
    <view wx:else class="image-upload">
      <button class="btn-upload" bindtap="takePhoto">+ 重新拍摄证书</button>
      <text class="upload-tip">图片将作为检定证书的电子存档</text>
    </view>
  </view>

  <!-- 压力表库（近期记录）卡片 -->
  <view class="card" wx:if="{{records.length > 0 && !showEditForm}}">
    <view class="card-title">📦 压力表库 ({{records.length}})</view>
    
    <view class="history-list">
      <block wx:for="{{records}}" wx:key="_id">
        <view class="history-item" bindtap="viewDetail" data-id="{{item._id}}">
          <view class="history-header">
            <text class="history-id">№ {{item.factoryNo || item.certNo || '未编号'}}</text>
            <text class="history-status" wx:if="{{item.conclusion}}">{{item.conclusion}}</text>
          </view>
          
          <view class="history-info">
            <text class="history-date">📅 {{item.verificationDate}}</text>
            <text class="history-expiry" wx:if="{{item.expiryDate}}">→ {{item.expiryDate}}</text>
          </view>
          
          <view wx:if="{{item.fileID}}" class="history-attachment">📎 有证书图片</view>
        </view>
      </block>
    </view>
  </view>
  <!-- 压力表库（近期记录）卡片 -->
<view class="card" wx:if="{{records.length > 0 && !showEditForm}}">
  <view class="card-title">📦 压力表库 ({{records.length}})</view>
  
  <view class="history-list">
    <block wx:for="{{records}}" wx:key="_id">
      <view class="history-item" bindtap="viewDetail" data-id="{{item._id}}">
        <view class="history-header">
          <text class="history-id">№ {{item.factoryNo || item.certNo || '未编号'}}</text>
          <text class="history-status" wx:if="{{item.conclusion}}">{{item.conclusion}}</text>
        </view>
        
        <view class="history-info">
          <text class="history-date">📅 {{item.verificationDate}}</text>
          <text class="history-expiry" wx:if="{{item.expiryDate}}">→ {{item.expiryDate}}</text>
        </view>
        
        <view wx:if="{{item.fileID}}" class="history-attachment">📎 有证书图片</view>
        <view class="history-source">来源: {{item.ocrSource === 'baidu' ? 'OCR识别' : '手动录入'}}</view>
      </view>
    </block>
  </view>
</view>

  <!-- 底部操作栏 -->
  <view class="form-actions" wx:if="{{showEditForm}}">
    <button class="btn secondary" bindtap="retakePhoto">❮ 返回修改</button>
    <button class="btn primary" bindtap="saveRecord" loading="{{saving}}">
      {{saving ? '保存中...' : '✓ 确认存档'}}
    </button>
  </view>
</view>
