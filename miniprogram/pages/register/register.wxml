<view class="page-shell register-page">
  <view class="register-shell">
    <view class="register-card">
      <view class="register-brand">
        <view class="brand-mark">P</view>
        <view class="brand-name">{{text.brandName}}</view>
      </view>

      <view class="register-copy">
        <view class="register-title">{{text.title}}</view>
        <view class="register-desc">{{text.desc}}</view>
      </view>

      <view class="register-form">
        <view class="field-block">
          <view class="field-label">{{text.companyLabel}}</view>
          <input
            class="field-input"
            placeholder="{{text.companyPlaceholder}}"
            value="{{companyName}}"
            bindinput="onInputCompanyName"
            placeholder-class="input-placeholder"
          />
        </view>

        <view class="field-block">
          <view class="field-label">{{text.creditCodeLabel}}</view>
          <input
            class="field-input"
            maxlength="18"
            placeholder="{{text.creditCodePlaceholder}}"
            value="{{creditCode}}"
            bindinput="onInputCreditCode"
            placeholder-class="input-placeholder"
          />
        </view>

        <view class="field-block">
          <view class="field-label">{{text.legalPersonLabel}}</view>
          <input
            class="field-input"
            placeholder="{{text.legalPersonPlaceholder}}"
            value="{{legalPerson}}"
            bindinput="onInputLegalPerson"
            placeholder-class="input-placeholder"
          />
        </view>

        <view class="field-block">
          <view class="field-label">{{text.phoneLabel}}</view>
          <input
            class="field-input"
            type="number"
            maxlength="11"
            placeholder="{{text.phonePlaceholder}}"
            value="{{phone}}"
            bindinput="onInputPhone"
            placeholder-class="input-placeholder"
          />
        </view>

        <view class="field-block">
          <view class="field-label">{{text.districtLabel}}</view>
          <picker mode="selector" range="{{districtOptions}}" value="{{districtIndex}}" bindchange="onDistrictChange">
            <view class="field-input picker-input">
              <text class="{{district ? 'picker-value' : 'picker-placeholder'}}">{{district || text.districtPlaceholder}}</text>
              <text class="picker-arrow">></text>
            </view>
          </picker>
        </view>
      </view>

      <button
        class="btn-primary-solid register-submit {{loading ? 'is-loading' : ''}}"
        bindtap="handleRegister"
        disabled="{{loading}}"
      >
        <text>{{loading ? text.submitting : text.submit}}</text>
      </button>

      <view class="register-actions">
        <view class="assist-row">
          <text class="assist-text">{{text.assistText}}</text>
          <text class="assist-link" bindtap="goBack">{{text.goLogin}}</text>
        </view>
      </view>
    </view>

    <view class="version-text">Version 1.2.0</view>
  </view>
</view>

<privacy />
