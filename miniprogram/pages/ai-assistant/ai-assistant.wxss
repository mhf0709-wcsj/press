.page-scroll {
  height: 100vh;
  box-sizing: border-box;
}

.ai-wrapper {
  padding-top: var(--space-5);
  padding-bottom: 240rpx;
}

.ai-hero,
.ai-chat {
  margin-bottom: var(--space-5);
}

.ai-chat {
  min-height: calc(100vh - 500rpx);
  box-sizing: border-box;
}

.ai-chat .panel-section {
  min-height: calc(100vh - 560rpx);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.ai-title {
  margin-top: var(--space-4);
}

.ai-actions {
  display: flex;
  gap: var(--space-3);
  margin-bottom: var(--space-5);
}

.ai-action {
  flex: 1;
}

.ai-action.is-disabled {
  opacity: 0.58;
  box-shadow: none;
}

.ai-action-text {
  font-size: var(--font-size-footnote);
  font-weight: var(--font-weight-medium);
}

.ai-action-text.is-primary {
  color: var(--color-text-white);
}

.message-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-5);
  flex: 1;
}

.message-item {
  width: 100%;
}

.message-row {
  display: flex;
  align-items: flex-start;
  gap: var(--space-3);
}

.user-row {
  flex-direction: row-reverse;
}

.message-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: var(--font-size-caption);
  font-weight: var(--font-weight-semibold);
}

.assistant-avatar {
  position: relative;
  background: linear-gradient(145deg, #7c6bea, #2f8cff);
  box-shadow: 0 10rpx 22rpx rgba(47, 140, 255, 0.22);
}

.assistant-avatar::before,
.assistant-avatar::after {
  content: "";
  position: absolute;
  top: 8rpx;
  width: 6rpx;
  height: 16rpx;
  border-radius: 6rpx;
  background: #ff6b6b;
}

.assistant-avatar::before {
  left: 16rpx;
}

.assistant-avatar::after {
  right: 16rpx;
}

.bot-face {
  width: 38rpx;
  height: 30rpx;
  border-radius: 10rpx;
  background: rgba(255, 255, 255, 0.96);
  position: relative;
  box-shadow: inset 0 -3rpx 0 rgba(17, 24, 39, 0.08);
}

.bot-eye {
  position: absolute;
  top: 10rpx;
  width: 6rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background: #0f172a;
}

.bot-eye.left {
  left: 10rpx;
}

.bot-eye.right {
  right: 10rpx;
}

.bot-mouth {
  position: absolute;
  left: 14rpx;
  bottom: 7rpx;
  width: 10rpx;
  height: 3rpx;
  border-radius: 3rpx;
  background: rgba(15, 23, 42, 0.55);
}

.user-avatar {
  background: rgba(17, 24, 39, 0.08);
  color: var(--color-text-main);
}

.message-content {
  max-width: 84%;
  display: flex;
  flex-direction: column;
}

.user-content {
  align-items: flex-end;
}

.message-bubble {
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(17, 24, 39, 0.06);
}

.assistant-bubble {
  background: rgba(255, 255, 255, 0.84);
}

.user-bubble {
  background: var(--color-brand);
  border-color: transparent;
}

.message-text {
  font-size: var(--font-size-body);
  line-height: 1.7;
  word-break: break-word;
}

.assistant-bubble .message-text {
  color: var(--color-text-main);
}

.user-bubble .message-text {
  color: var(--color-text-white);
}

.message-time {
  margin-top: 8rpx;
  font-size: var(--font-size-caption);
  color: var(--color-text-tertiary);
}

.image-bubble {
  padding: 12rpx;
}

.chat-image,
.result-image {
  width: 320rpx;
  height: 220rpx;
  border-radius: 18rpx;
  display: block;
}

.image-caption {
  display: block;
  margin-top: 10rpx;
  font-size: var(--font-size-caption);
  color: rgba(255, 255, 255, 0.88);
}

.result-bubble {
  width: 100%;
  box-sizing: border-box;
}

.result-title {
  display: block;
  font-size: var(--font-size-callout);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-main);
}

.result-summary {
  display: block;
  margin-top: 10rpx;
  font-size: var(--font-size-footnote);
  line-height: 1.65;
  color: var(--color-text-secondary);
}

.result-image {
  margin-top: var(--space-4);
}

.result-field-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
  margin-top: var(--space-4);
}

.result-field {
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: rgba(17, 24, 39, 0.03);
}

.result-field-label {
  display: block;
  font-size: var(--font-size-caption);
  color: var(--color-text-tertiary);
}

.result-field-value {
  display: block;
  margin-top: 6rpx;
  font-size: var(--font-size-footnote);
  line-height: 1.55;
  color: var(--color-text-main);
}

.result-action {
  margin-top: var(--space-4);
  min-height: 78rpx;
  border-radius: var(--radius-pill);
  background: var(--color-brand);
  display: flex;
  align-items: center;
  justify-content: center;
}

.result-action-text {
  font-size: var(--font-size-footnote);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-white);
}

.debug-card {
  margin-top: var(--space-4);
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: rgba(0, 122, 255, 0.06);
  border: 1rpx solid rgba(0, 122, 255, 0.1);
}

.debug-toggle {
  margin-top: var(--space-4);
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: rgba(17, 24, 39, 0.03);
  border: 1rpx solid rgba(17, 24, 39, 0.05);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-3);
}

.debug-toggle-text {
  font-size: var(--font-size-caption);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-secondary);
}

.debug-toggle-arrow {
  font-size: var(--font-size-caption);
  color: var(--color-brand);
}

.debug-title {
  display: block;
  font-size: var(--font-size-caption);
  font-weight: var(--font-weight-semibold);
  color: var(--color-brand);
}

.debug-line {
  display: block;
  margin-top: 8rpx;
  font-size: var(--font-size-caption);
  line-height: 1.6;
  color: var(--color-text-secondary);
  word-break: break-word;
}

.crud-item-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
  margin-top: var(--space-4);
}

.crud-item,
.crud-pick {
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: rgba(17, 24, 39, 0.03);
  border: 1rpx solid rgba(17, 24, 39, 0.04);
}

.crud-item-title,
.crud-pick-title {
  display: block;
  font-size: var(--font-size-footnote);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-main);
}

.crud-item-subtitle {
  display: block;
  margin-top: 6rpx;
  font-size: var(--font-size-caption);
  color: var(--color-text-secondary);
}

.crud-actions {
  display: flex;
  gap: var(--space-3);
  margin-top: var(--space-4);
}

.crud-action {
  flex: 1;
  min-height: 78rpx;
  border-radius: var(--radius-pill);
  display: flex;
  align-items: center;
  justify-content: center;
}

.crud-action.primary {
  background: var(--color-brand);
}

.crud-action.secondary {
  background: rgba(17, 24, 39, 0.06);
}

.crud-action-text {
  font-size: var(--font-size-footnote);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-white);
}

.crud-action-text.secondary {
  color: var(--color-text-main);
}

.crud-pick {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.crud-pick-action {
  font-size: var(--font-size-caption);
  font-weight: var(--font-weight-medium);
  color: var(--color-brand);
}

.loading-text {
  font-size: var(--font-size-footnote);
  line-height: 1.6;
  color: var(--color-text-secondary);
}

.empty-chat {
  flex: 1;
  min-height: 520rpx;
  padding: var(--space-4) 0 var(--space-2);
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
}

.empty-chat-title {
  display: block;
  font-size: var(--font-size-callout);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-main);
}

.empty-chat-desc {
  display: block;
  margin-top: 10rpx;
  font-size: var(--font-size-footnote);
  line-height: 1.65;
  color: var(--color-text-secondary);
}

.page-spacer {
  height: 80rpx;
}

.composer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 14rpx 18rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(248, 249, 252, 0.86);
  backdrop-filter: var(--blur-panel);
  border-top: 1rpx solid rgba(17, 24, 39, 0.06);
}

.composer-tools {
  display: flex;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.composer-tool {
  flex: 1;
  min-width: 0;
  height: 60rpx;
  padding: 0 24rpx;
  border-radius: var(--radius-pill);
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(17, 24, 39, 0.06);
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.composer-upload-text {
  font-size: var(--font-size-caption);
  color: var(--color-text-main);
  font-weight: var(--font-weight-medium);
}

.composer-inner {
  display: flex;
  align-items: flex-end;
  gap: var(--space-3);
  padding: 14rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(17, 24, 39, 0.06);
}

.composer-input {
  flex: 1;
  min-height: 48rpx;
  max-height: 180rpx;
  font-size: var(--font-size-body);
  line-height: 1.55;
  color: var(--color-text-main);
}

.composer-send {
  width: 82rpx;
  height: 82rpx;
  border-radius: 41rpx;
  background: rgba(17, 24, 39, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.composer-send.active {
  background: var(--color-brand);
}

.composer-send-text {
  font-size: var(--font-size-caption);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-white);
}

.composer-tip {
  display: block;
  margin-top: 10rpx;
  text-align: center;
  font-size: var(--font-size-caption);
  color: var(--color-text-tertiary);
}
