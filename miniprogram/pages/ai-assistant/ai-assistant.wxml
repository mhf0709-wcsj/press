<view class="page-shell ai-page">
  <scroll-view
    scroll-y
    class="page-scroll"
    scroll-into-view="{{scrollToView}}"
    scroll-with-animation="{{true}}"
  >
    <view class="content-wrapper ai-wrapper">
      <view class="ai-hero panel">
        <view class="panel-section">
          <view class="eyebrow">{{text.heroTopline}}</view>
          <view class="page-title ai-title">{{text.heroTitle}}</view>
          <view class="page-subtitle" wx:if="{{text.heroDesc}}">{{text.heroDesc}}</view>
        </view>
      </view>

      <view class="ai-chat panel">
        <view class="panel-section">
          <view class="message-list" wx:if="{{messages.length > 0 || isLoading || isVisionLoading || isCrudExecuting || isDirectSaving}}">
            <view
              class="message-item"
              wx:for="{{messages}}"
              wx:key="id"
              id="msg-{{item.id}}"
            >
              <view class="message-row" wx:if="{{item.role === 'assistant'}}">
                <view class="message-avatar assistant-avatar">
                  <view class="bot-face">
                    <view class="bot-eye left"></view>
                    <view class="bot-eye right"></view>
                    <view class="bot-mouth"></view>
                  </view>
                </view>
                <view class="message-content">
                  <view class="message-bubble assistant-bubble" wx:if="{{item.kind === 'text'}}">
                    <text class="message-text" user-select>{{item.content}}</text>
                  </view>

                  <view class="message-bubble assistant-bubble result-bubble" wx:if="{{item.kind === 'result'}}">
                    <text class="result-title">{{item.title}}</text>
                    <text class="result-summary">{{item.summary}}</text>
                    <image
                      wx:if="{{item.imagePath}}"
                      class="result-image"
                      src="{{item.imagePath}}"
                      mode="aspectFill"
                      data-image-path="{{item.imagePath}}"
                      bindtap="previewChatImage"
                    />
                    <view class="result-field-list">
                      <view class="result-field" wx:for="{{item.fields}}" wx:key="key">
                        <text class="result-field-label">{{item.label}}</text>
                        <text class="result-field-value">{{item.value}}</text>
                      </view>
                    </view>
                    <view class="result-action" bindtap="goToDraftConfirm">
                      <text class="result-action-text">{{text.confirmDraft}}</text>
                    </view>
                  </view>

                  <view class="message-bubble assistant-bubble result-bubble" wx:if="{{item.kind === 'crud_result'}}">
                    <text class="result-title">{{item.title}}</text>
                    <text class="result-summary">{{item.content}}</text>
                    <view class="debug-toggle" wx:if="{{item.interpretation || item.queryLog}}" data-id="{{item.id}}" bindtap="toggleDebugPanel">
                      <text class="debug-toggle-text">{{debugExpandedMap[item.id] ? text.debugCollapse : text.debugToggle}}</text>
                      <text class="debug-toggle-arrow">{{debugExpandedMap[item.id] ? '收起' : '展开'}}</text>
                    </view>
                    <view class="debug-card" wx:if="{{debugExpandedMap[item.id] && (item.interpretation || item.queryLog)}}">
                      <text class="debug-title">排查信息</text>
                      <text class="debug-line" wx:if="{{item.interpretation}}">{{item.interpretation}}</text>
                      <text class="debug-line" wx:if="{{item.queryLog}}">{{item.queryLog}}</text>
                    </view>
                    <view class="crud-item-list" wx:if="{{item.items.length}}">
                      <view class="crud-item" wx:for="{{item.items}}" wx:key="id">
                        <text class="crud-item-title">{{item.title}}</text>
                        <text class="crud-item-subtitle">{{item.subtitle}}</text>
                      </view>
                    </view>
                  </view>

                  <view class="message-bubble assistant-bubble result-bubble" wx:if="{{item.kind === 'crud_confirm'}}">
                    <text class="result-title">{{item.title}}</text>
                    <text class="result-summary">{{item.content}}</text>
                    <view class="debug-toggle" wx:if="{{item.interpretation || item.queryLog}}" data-id="{{item.id}}" bindtap="toggleDebugPanel">
                      <text class="debug-toggle-text">{{debugExpandedMap[item.id] ? text.debugCollapse : text.debugToggle}}</text>
                      <text class="debug-toggle-arrow">{{debugExpandedMap[item.id] ? '收起' : '展开'}}</text>
                    </view>
                    <view class="debug-card" wx:if="{{debugExpandedMap[item.id] && (item.interpretation || item.queryLog)}}">
                      <text class="debug-title">排查信息</text>
                      <text class="debug-line" wx:if="{{item.interpretation}}">{{item.interpretation}}</text>
                      <text class="debug-line" wx:if="{{item.queryLog}}">{{item.queryLog}}</text>
                    </view>
                    <view class="crud-item-list" wx:if="{{item.items.length}}">
                      <view class="crud-item" wx:for="{{item.items}}" wx:key="id">
                        <text class="crud-item-title">{{item.title}}</text>
                        <text class="crud-item-subtitle">{{item.subtitle}}</text>
                      </view>
                    </view>
                    <view class="crud-actions">
                      <view class="crud-action secondary" bindtap="cancelCrudExecution">
                        <text class="crud-action-text secondary">{{text.cancelExecute}}</text>
                      </view>
                      <view class="crud-action primary" bindtap="confirmCrudExecution">
                        <text class="crud-action-text">{{text.confirmExecute}}</text>
                      </view>
                    </view>
                  </view>

                  <view class="message-bubble assistant-bubble result-bubble" wx:if="{{item.kind === 'crud_select'}}">
                    <text class="result-title">{{item.title}}</text>
                    <text class="result-summary">{{item.content}}</text>
                    <view class="debug-toggle" wx:if="{{item.interpretation || item.queryLog}}" data-id="{{item.id}}" bindtap="toggleDebugPanel">
                      <text class="debug-toggle-text">{{debugExpandedMap[item.id] ? text.debugCollapse : text.debugToggle}}</text>
                      <text class="debug-toggle-arrow">{{debugExpandedMap[item.id] ? '收起' : '展开'}}</text>
                    </view>
                    <view class="debug-card" wx:if="{{debugExpandedMap[item.id] && (item.interpretation || item.queryLog)}}">
                      <text class="debug-title">排查信息</text>
                      <text class="debug-line" wx:if="{{item.interpretation}}">{{item.interpretation}}</text>
                      <text class="debug-line" wx:if="{{item.queryLog}}">{{item.queryLog}}</text>
                    </view>
                    <view class="crud-item-list" wx:if="{{item.items.length}}">
                      <view
                        class="crud-item selectable"
                        wx:for="{{item.items}}"
                        wx:for-item="candidate"
                        wx:key="id"
                      >
                        <view class="crud-item-main">
                          <text class="crud-item-title">{{candidate.title}}</text>
                          <text class="crud-item-subtitle">{{candidate.subtitle}}</text>
                        </view>
                      </view>
                    </view>
                    <view class="crud-item-list" wx:if="{{item.items.length}}">
                      <view
                        class="crud-pick"
                        wx:for="{{item.items}}"
                        wx:for-item="candidate"
                        wx:key="id"
                        data-item="{{candidate}}"
                        data-payload-base="{{candidate.payloadBase}}"
                        bindtap="selectCrudItem"
                      >
                        <text class="crud-pick-title">{{candidate.title}}</text>
                        <text class="crud-pick-action">{{text.useThisOne}}</text>
                      </view>
                    </view>
                  </view>

                  <text class="message-time">{{item.time}}</text>
                </view>
              </view>

              <view class="message-row user-row" wx:if="{{item.role === 'user'}}">
                <view class="message-content user-content">
                  <view class="message-bubble user-bubble" wx:if="{{item.kind === 'text'}}">
                    <text class="message-text">{{item.content}}</text>
                  </view>

                  <view class="message-bubble user-bubble image-bubble" wx:if="{{item.kind === 'image'}}">
                    <image
                      class="chat-image"
                      src="{{item.imagePath}}"
                      mode="aspectFill"
                      data-image-path="{{item.imagePath}}"
                      bindtap="previewChatImage"
                    />
                    <text class="image-caption">{{item.content}}</text>
                  </view>

                  <text class="message-time">{{item.time}}</text>
                </view>
                <view class="message-avatar user-avatar">{{text.me}}</view>
              </view>
            </view>

            <view class="message-item" wx:if="{{isVisionLoading}}" id="msg-vision-loading">
              <view class="message-row">
                <view class="message-avatar assistant-avatar">
                  <view class="bot-face">
                    <view class="bot-eye left"></view>
                    <view class="bot-eye right"></view>
                    <view class="bot-mouth"></view>
                  </view>
                </view>
                <view class="message-content">
                  <view class="message-bubble assistant-bubble loading-bubble">
                    <text class="loading-text">{{text.uploadReceived}}</text>
                  </view>
                </view>
              </view>
            </view>

            <view class="message-item" wx:if="{{isLoading}}" id="msg-loading">
              <view class="message-row">
                <view class="message-avatar assistant-avatar">
                  <view class="bot-face">
                    <view class="bot-eye left"></view>
                    <view class="bot-eye right"></view>
                    <view class="bot-mouth"></view>
                  </view>
                </view>
                <view class="message-content">
                  <view class="message-bubble assistant-bubble loading-bubble">
                    <text class="loading-text">{{text.loadingAnswer}}</text>
                  </view>
                </view>
              </view>
            </view>

            <view class="message-item" wx:if="{{isCrudExecuting}}" id="msg-crud-executing">
              <view class="message-row">
                <view class="message-avatar assistant-avatar">
                  <view class="bot-face">
                    <view class="bot-eye left"></view>
                    <view class="bot-eye right"></view>
                    <view class="bot-mouth"></view>
                  </view>
                </view>
                <view class="message-content">
                  <view class="message-bubble assistant-bubble loading-bubble">
                    <text class="loading-text">{{text.executingAction}}</text>
                  </view>
                </view>
              </view>
            </view>

            <view class="message-item" wx:if="{{isDirectSaving}}" id="msg-direct-saving">
              <view class="message-row">
                <view class="message-avatar assistant-avatar">
                  <view class="bot-face">
                    <view class="bot-eye left"></view>
                    <view class="bot-eye right"></view>
                    <view class="bot-mouth"></view>
                  </view>
                </view>
                <view class="message-content">
                  <view class="message-bubble assistant-bubble loading-bubble">
                    <text class="loading-text">{{text.savingDraft}}</text>
                  </view>
                </view>
              </view>
            </view>
          </view>

          <view class="empty-chat" wx:else>
            <text class="empty-chat-title">{{text.emptyChatTitle}}</text>
            <text class="empty-chat-desc" wx:if="{{text.emptyChatDesc}}">{{text.emptyChatDesc}}</text>
          </view>
        </view>
      </view>

      <view class="page-spacer" id="msg-tail"></view>
    </view>
  </scroll-view>

  <view class="composer">
    <view class="composer-tools">
      <view class="composer-tool" bindtap="onUploadVisionImage">
        <text class="composer-upload-text">{{text.uploadCta}}</text>
      </view>
      <view class="composer-tool" bindtap="goToManualEntry">
        <text class="composer-upload-text">{{text.manualEntry}}</text>
      </view>
    </view>
    <view class="composer-inner">
      <textarea
        class="composer-input"
        placeholder="{{text.inputPlaceholder}}"
        value="{{inputValue}}"
        bindinput="onInput"
        bindconfirm="onSend"
        confirm-type="send"
        auto-height
        maxlength="500"
        show-confirm-bar="{{false}}"
        adjust-position="{{true}}"
        cursor-spacing="20"
      />
      <view class="composer-send {{inputValue ? 'active' : ''}}" bindtap="onSend">
        <text class="composer-send-text">{{text.send}}</text>
      </view>
    </view>
    <view class="composer-tip" wx:if="{{text.composerTip}}">
      <text>{{text.composerTip}}</text>
    </view>
  </view>

  <expiry-reminder-card
    visible="{{reminderVisible}}"
    title="{{reminderCard.title}}"
    summary="{{reminderCard.summary}}"
    items="{{reminderCard.items}}"
    badge-text="到期提醒"
    fallback-subtitle="请尽快处理"
    confirm-text="去处理"
    cancel-text="稍后处理"
    bind:confirm="confirmReminderCard"
    bind:cancel="closeReminderCard"
  />

  <privacy />
</view>


