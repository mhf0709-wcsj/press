<!--index.wxml-->
<view class="container">
  <view class="header">
    <view class="header-title">云开发 QuickStart</view>
    <view class="header-subtitle">免鉴权接口调用 · 免部署后台 · 高并发</view>
  </view>

  <view class="power-list">
    <view class="card power-card" wx:key="title" wx:for="{{powerList}}" wx:for-item="power">
      <view class="power-header" data-index="{{index}}" bindtap="onClickPowerInfo">
        <view class="power-info">
          <view class="power-title">
            {{power.title}}
            <view class="tag" wx:if="{{power.tag}}">{{power.tag}}</view>
          </view>
          <view class="power-desc">{{power.tip}}</view>
        </view>
        <image wx:if="{{power.item.length}}" class="arrow-icon {{power.showItem ? 'expanded' : ''}}" src="../../images/arrow.svg"></image>
      </view>
      
      <view class="power-content {{power.showItem ? 'show' : ''}}" wx:if="{{power.item.length}}">
        <view class="divider"></view>
        <view class="sub-item" wx:key="title" wx:for="{{power.item}}" bindtap="jumpPage" data-type="{{ item.type }}" data-page="{{item.page}}">
          <view class="sub-item-title">{{item.title}}</view>
          <image class="sub-item-arrow" src="../../images/arrow.svg"></image>
        </view>
      </view>
    </view>
  </view>

  <cloud-tip-modal showTipProps="{{showTip}}" title="{{title}}" content="{{content}}"></cloud-tip-modal>
</view>
