page {
  background: #f5f7fb;
}

.legacy-page {
  min-height: 100vh;
  padding: 120rpx 32rpx;
  box-sizing: border-box;
}

.legacy-card {
  background: rgba(255, 255, 255, 0.92);
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(31, 54, 88, 0.08);
}

.legacy-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #1f2937;
}

.legacy-subtitle {
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #6b7280;
}
