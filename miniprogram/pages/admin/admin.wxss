.admin-scroll {
  height: 100vh;
}

.admin-wrapper {
  padding-top: var(--space-5);
  padding-bottom: var(--space-8);
}

.hero-panel,
.filter-panel {
  margin-bottom: var(--space-5);
}

.hero-row {
  display: flex;
  gap: var(--space-4);
  justify-content: space-between;
}

.hero-title {
  margin-top: var(--space-4);
}

.hero-actions {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
  min-width: 180rpx;
}

.mini-action {
  min-height: 76rpx;
}

.hero-back {
  margin-top: var(--space-4);
  font-size: var(--font-size-caption);
  color: var(--color-brand);
}

.mode-toggle {
  display: flex;
  gap: 10rpx;
  padding: 8rpx;
  border-radius: var(--radius-lg);
  background: rgba(17, 24, 39, 0.04);
}

.toggle-item {
  flex: 1;
  min-height: 76rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-footnote);
  color: var(--color-text-secondary);
}

.toggle-item.active {
  background: rgba(255, 255, 255, 0.92);
  color: var(--color-text-main);
  font-weight: var(--font-weight-semibold);
  box-shadow: var(--shadow-sm);
}

.filter-stack {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
  margin-top: var(--space-4);
}

.filter-row {
  display: flex;
  gap: var(--space-3);
}

.search-input {
  width: 100%;
  min-height: 86rpx;
  padding: 0 26rpx;
  box-sizing: border-box;
  border-radius: var(--radius-lg);
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(17, 24, 39, 0.06);
  font-size: var(--font-size-body);
  color: var(--color-text-main);
}

.picker-chip {
  min-height: 78rpx;
  padding: 0 24rpx;
  border-radius: var(--radius-pill);
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(17, 24, 39, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-caption);
  color: var(--color-text-main);
}

.static-chip {
  flex: 1;
}

.filter-row picker {
  flex: 1;
}

.list-block {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.ledger-cell {
  align-items: flex-start;
  min-height: 168rpx;
  padding-top: var(--space-4);
  padding-bottom: var(--space-4);
}

.cell-main {
  flex: 1;
  min-width: 0;
}

.cell-side {
  min-width: 150rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.status-tag,
.badge {
  min-height: 44rpx;
  padding: 0 16rpx;
  border-radius: var(--radius-pill);
  display: inline-flex;
  align-items: center;
  font-size: var(--font-size-caption);
  font-weight: var(--font-weight-medium);
}

.status-tag.pass {
  background: rgba(34, 197, 94, 0.12);
  color: #15803d;
}

.status-tag.fail {
  background: rgba(239, 68, 68, 0.12);
  color: #b91c1c;
}

.badge {
  background: rgba(0, 122, 255, 0.1);
  color: var(--color-brand);
}

.empty-state {
  padding: 56rpx 24rpx;
  border-radius: var(--radius-lg);
  background: rgba(255, 255, 255, 0.74);
  border: 1rpx solid rgba(17, 24, 39, 0.06);
}

.empty-text {
  font-size: var(--font-size-footnote);
  line-height: 1.6;
  color: var(--color-text-secondary);
  text-align: center;
}
