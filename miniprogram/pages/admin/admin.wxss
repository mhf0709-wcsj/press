.container {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

/* 页面头部 */
.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #eee;
}

.header-left {
  display: flex;
  align-items: center;
}

.back-arrow {
  font-size: 40rpx;
  color: #667eea;
  margin-right: 8rpx;
}

.back-text {
  font-size: 28rpx;
  color: #667eea;
}

.page-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.header-right {
  font-size: 36rpx;
  padding: 8rpx 16rpx;
}

/* Tab切换栏 */
.tab-bar {
  display: flex;
  flex-direction: row;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  position: relative;
}

.tab-item.active {
  background: linear-gradient(180deg, rgba(102, 126, 234, 0.1) 0%, transparent 100%);
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background: #667eea;
  border-radius: 3rpx;
}

.tab-icon-wrap {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.tab-icon {
  font-size: 36rpx;
}

.tab-text {
  font-size: 26rpx;
  color: #666;
  white-space: nowrap;
  text-align: center;
  display: block;
  width: 100%;
}

.tab-item.active .tab-text {
  color: #667eea;
  font-weight: 600;
}

/* 页面内容 */
.page-content {
  flex: 1;
  overflow-y: auto;
}

/* 账号设置页滚动区域 */
.account-scroll {
  height: calc(100vh - 220rpx);
}

/* 筛选提示 */
.filter-tip {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #e6f7ff;
  padding: 16rpx 32rpx;
  border-bottom: 1rpx solid #91d5ff;
}

.filter-text {
  font-size: 26rpx;
  color: #1890ff;
}

.filter-clear {
  font-size: 26rpx;
  color: #ff4d4f;
  padding: 4rpx 16rpx;
}

/* 旧的概览卡片样式 - 已废弃 */
.overview-card {
  display: none;
}

.overview-arrow.expanded {
  transform: rotate(180deg);
}

.overview-stats {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
}

.overview-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.overview-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
}

.overview-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

.overview-item.warning .overview-value {
  color: #ffd666;
}

/* 展开的详细数据 */
.overview-detail {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
}

.detail-section {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.detail-section:last-child {
  margin-bottom: 0;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.detail-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}

.detail-refresh {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
}

/* 到期统计 */
.expiry-stats {
  display: flex;
  justify-content: space-around;
  padding: 16rpx 0;
}

.expiry-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}

.expiry-stat.expired .stat-num {
  color: #ff7875;
}

.expiry-stat.expiring .stat-num {
  color: #ffc53d;
}

.expiry-stat.enterprise .stat-num {
  color: #69c0ff;
}

.stat-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 6rpx;
}

/* 企业列表 */
.expiry-enterprises {
  max-height: 300rpx;
  overflow-y: auto;
}

.enterprise-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.enterprise-row:last-child {
  border-bottom: none;
}

.enterprise-text {
  font-size: 26rpx;
  color: #fff;
  flex: 1;
}

.mini-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-left: 8rpx;
}

.mini-tag.expired {
  background: rgba(255, 77, 79, 0.3);
  color: #ff7875;
}

.mini-tag.expiring {
  background: rgba(250, 140, 22, 0.3);
  color: #ffc53d;
}

.no-data {
  text-align: center;
  padding: 20rpx 0;
  color: rgba(255, 255, 255, 0.6);
  font-size: 24rpx;
}

/* 辖区分布 */
.district-dist {
  padding: 8rpx 0;
}

.district-row {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
}

.district-name {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  width: 120rpx;
}

.district-bar-bg {
  flex: 1;
  height: 16rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 8rpx;
  margin: 0 16rpx;
  overflow: hidden;
}

.district-bar {
  height: 100%;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 8rpx;
}

.district-count {
  font-size: 24rpx;
  color: #fff;
  width: 60rpx;
  text-align: right;
}

/* 旧的到期提醒样式 - 保留以兼容 */
.reminder-section {
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.reminder-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.reminder-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.reminder-refresh {
  font-size: 24rpx;
  color: #722ed1;
}

.reminder-stats {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
  margin-bottom: 16rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}

.reminder-stats .stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.reminder-stats .stat-count {
  font-size: 48rpx;
  font-weight: 700;
}

.reminder-stats .stat-item.expired .stat-count {
  color: #ff4d4f;
}

.reminder-stats .stat-item.expiring .stat-count {
  color: #fa8c16;
}

.reminder-stats .stat-item.enterprise .stat-count {
  color: #722ed1;
}

.reminder-stats .stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.enterprise-list {
  max-height: 240rpx;
  overflow-y: auto;
}

.enterprise-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.enterprise-item:last-child {
  border-bottom: none;
}

.enterprise-name {
  font-size: 26rpx;
  color: #333;
}

.enterprise-tags {
  display: flex;
  gap: 12rpx;
}

.tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
}

.tag.expired {
  background: #fff2f0;
  color: #ff4d4f;
}

.tag.expiring {
  background: #fff7e6;
  color: #fa8c16;
}

.reminder-empty {
  text-align: center;
  padding: 20rpx;
  color: #999;
  font-size: 26rpx;
}

.toolbar {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.search-box {
  flex: 1;
  margin-right: 20rpx;
}

.search-input {
  height: 64rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
}

.enterprise-picker {
  padding: 16rpx 24rpx;
  background: #722ed1;
  color: #fff;
  border-radius: 8rpx;
  font-size: 24rpx;
  white-space: nowrap;
  margin-left: 12rpx;
}

.district-picker {
  padding: 16rpx 24rpx;
  background: #52c41a;
  color: #fff;
  border-radius: 8rpx;
  font-size: 24rpx;
  white-space: nowrap;
}

.district-label {
  padding: 16rpx 24rpx;
  background: #667eea;
  color: #fff;
  border-radius: 8rpx;
  font-size: 24rpx;
  white-space: nowrap;
}

.action-bar {
  display: flex;
  padding: 20rpx;
  gap: 20rpx;
}

.btn {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn.add {
  background: #722ed1;
  color: #fff;
}

.btn.logout {
  background: #ff4d4f;
  color: #fff;
}

.record-list {
  padding: 0 20rpx;
  height: calc(100vh - 220rpx);
}

.record-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-factory {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.record-conclusion {
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.pass {
  background: #f6ffed;
  color: #52c41a;
}

.fail {
  background: #fff2f0;
  color: #ff4d4f;
}

.conditional {
  background: #fff7e6;
  color: #fa8c16;
}

.record-body {
  margin-bottom: 16rpx;
}

.record-row {
  display: flex;
  justify-content: space-between;
  padding: 8rpx 0;
  font-size: 26rpx;
}

.record-row .label {
  color: #999;
}

.record-row .value {
  color: #333;
  max-width: 350rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-row .value.phone {
  color: #1890ff;
  font-weight: 500;
}

.record-row .value.expired {
  color: #ff4d4f;
  font-weight: 600;
}

.record-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  font-size: 24rpx;
}

.action-btn.edit {
  background: #722ed1;
  color: #fff;
}

.action-btn.delete {
  background: #ff4d4f;
  color: #fff;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal {
  width: 600rpx;
  max-height: 80vh;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.modal-header {
  padding: 30rpx;
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-body {
  padding: 30rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item .label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.form-item .input {
  height: 72rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 8rpx;
  padding: 0 16rpx;
  font-size: 26rpx;
}

.form-item .picker {
  height: 72rpx;
  line-height: 72rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 8rpx;
  padding: 0 16rpx;
  font-size: 26rpx;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
}

.btn-cancel, .btn-confirm {
  flex: 1;
  height: 88rpx;
  border: none;
  border-radius: 0;
  font-size: 28rpx;
}

.btn-cancel {
  background: #fff;
  color: #666;
  border-right: 1rpx solid #f0f0f0;
}

.btn-confirm {
  background: #722ed1;
  color: #fff;
}

/* 账号设置页面 */
.account-page {
  padding: 24rpx;
  background: #f5f5f5;
}

.account-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.account-header {
  display: flex;
  align-items: center;
}

.account-avatar {
  width: 100rpx;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.avatar-icon {
  font-size: 48rpx;
}

.account-info {
  display: flex;
  flex-direction: column;
}

.account-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

.account-role {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

.info-card {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #333;
}

.form-group {
  padding: 24rpx 28rpx;
}

.form-group .form-item {
  margin-bottom: 20rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.btn-change-password {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 16rpx;
  margin-top: 24rpx;
}

.action-cards {
  display: flex;
  gap: 24rpx;
}

.action-card {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-card.logout-card {
  background: #fff1f0;
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.action-text {
  font-size: 26rpx;
  color: #666;
}

.logout-card .action-text {
  color: #ff4d4f;
}

/* 链接按钮 */
.link-btn {
  background: transparent;
  color: #667eea;
  font-size: 26rpx;
  padding: 0;
  margin: 0;
  line-height: normal;
  border: none;
}

.link-btn::after {
  border: none;
}

/* 新建设备表单 */
.new-device-form {
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-top: 16rpx;
}

/* 小按钮 */
.btn-small {
  font-size: 26rpx;
  padding: 16rpx 32rpx;
  background: #667eea;
  color: #fff;
  border-radius: 8rpx;
  margin-top: 16rpx;
  margin-right: 16rpx;
}

.btn-small::after {
  border: none;
}

.btn-cancel-small {
  background: #f5f5f5;
  color: #666;
}
