<view class="page-shell device-page">
  <view class="content-wrapper device-wrapper">
    <view class="device-hero panel">
      <view class="panel-section">
        <view class="eyebrow">{{text.eyebrow}}</view>
        <view class="page-title device-title">{{text.title}}</view>
      </view>
    </view>

    <view class="device-section panel">
      <view class="panel-section">
        <view class="device-section-head">
          <view>
            <view class="section-title">{{text.dashboardTitle}}</view>
            <view class="section-note" wx:if="{{text.dashboardNote}}">{{text.dashboardNote}}</view>
          </view>
          <view class="device-create" bindtap="goToCreateEquipment">{{text.createEquipment}}</view>
        </view>

        <view class="device-grid">
          <view
            class="device-stat-card {{item.tone}}"
            wx:for="{{summaryCards}}"
            wx:key="key"
            data-key="{{item.key}}"
            bindtap="onTapDashboardCard"
          >
            <text class="device-stat-value">{{item.value}}</text>
            <text class="device-stat-label">{{item.label}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="device-section panel">
      <view class="panel-section">
        <view class="device-section-head">
          <view>
            <view class="section-title">{{text.bindingTitle}}</view>
            <view class="section-note">{{bindingReminder ? bindingReminder.summary : text.bindingEmpty}}</view>
          </view>
          <view class="device-more" bindtap="handleBindingReminder">{{text.bindingManage}}</view>
        </view>

        <view class="device-record-list" wx:if="{{bindingReminder && bindingReminder.items.length > 0}}">
          <view
            class="list-cell"
            wx:for="{{bindingReminder.items}}"
            wx:key="_id"
            data-id="{{item._id}}"
            bindtap="openUnboundEquipment"
          >
            <view class="device-cell-copy">
              <view class="cell-title">{{item.title}}</view>
              <view class="cell-subtitle" wx:if="{{item.subtitle}}">{{item.subtitle}}</view>
            </view>
            <view class="reminder-cell-meta">
              <text class="reminder-cell-tag neutral">{{text.bindingTag}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="device-section panel">
      <view class="panel-section">
        <view class="device-section-head">
          <view class="section-title">{{text.inactiveTitle}}</view>
          <view class="device-more" bindtap="goToInactiveDevices">{{text.inactiveMore}}</view>
        </view>

        <view wx:if="{{inactiveDevices.length > 0}}" class="device-record-list">
          <view
            class="list-cell"
            wx:for="{{inactiveDevices}}"
            wx:key="_id"
            data-id="{{item._id}}"
            bindtap="openInactiveDevice"
          >
            <view class="device-cell-copy">
              <view class="cell-title">{{item.title}}</view>
              <view class="cell-subtitle" wx:if="{{item.subtitle}}">{{item.subtitle}}</view>
            </view>
            <view class="reminder-cell-meta">
              <text class="reminder-cell-tag {{item.status === '报废' ? 'danger' : 'neutral'}}">{{item.status}}</text>
            </view>
          </view>
        </view>

        <view wx:else class="device-empty">{{text.inactiveEmpty}}</view>
      </view>
    </view>
  </view>
</view>

