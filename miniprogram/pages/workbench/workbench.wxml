<view class="page-shell device-page">
  <view class="content-wrapper device-wrapper">
    <view class="device-hero panel">
      <view class="panel-section">
        <view class="eyebrow">{{text.eyebrow}}</view>
        <view class="page-title device-title">{{text.title}}</view>
        <view class="device-identity glass-card">
          <view class="device-company">{{enterpriseUser.companyName || text.companyFallback}}</view>
          <view class="device-tag">{{text.companyTag}}</view>
        </view>
      </view>
    </view>

    <view class="device-section panel">
      <view class="panel-section">
        <view class="section-title">{{text.dashboardTitle}}</view>
        <view class="section-note">{{text.dashboardNote}}</view>

        <view class="device-grid">
          <view
            class="device-stat-card {{item.tone}}"
            wx:for="{{summaryCards}}"
            wx:key="key"
            data-key="{{item.key}}"
            bindtap="onTapDashboardCard"
          >
            <text class="device-stat-value">{{item.value}}</text>
            <text class="device-stat-label">{{item.label}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="device-section panel">
      <view class="panel-section">
        <view class="device-section-head">
          <view class="section-title">{{text.recentTitle}}</view>
          <view class="device-more" bindtap="goToAllRecords">{{text.recentMore}}</view>
        </view>

        <view wx:if="{{recentRecords.length > 0}}" class="device-record-list">
          <view
            class="list-cell"
            wx:for="{{recentRecords}}"
            wx:key="_id"
            data-id="{{item._id}}"
            bindtap="openRecord"
          >
            <view class="device-cell-copy">
              <view class="cell-title">{{item.title}}</view>
              <view class="cell-subtitle">{{item.subtitle}}</view>
            </view>
            <view class="cell-meta">{{item.meta}}</view>
          </view>
        </view>

        <view wx:else class="device-empty">{{text.recentEmpty}}</view>
      </view>
    </view>
  </view>
</view>
