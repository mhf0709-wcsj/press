<view class="page-shell account-settings-page">
  <scroll-view scroll-y class="account-settings-scroll">
    <view class="content-wrapper account-settings-wrapper">
      <view class="panel hero-panel">
        <view class="panel-section">
          <view class="eyebrow">{{text.heroTopline}}</view>
          <view class="page-title hero-title">{{text.heroTitle}}</view>
          <view class="page-subtitle" wx:if="{{text.heroDesc}}">{{text.heroDesc}}</view>
        </view>
      </view>

      <view class="panel">
        <view class="panel-section">
          <text class="section-title">{{text.infoTitle}}</text>
          <view class="info-list">
            <view class="list-cell info-cell">
              <text class="cell-title">{{text.labels.username}}</text>
              <text class="cell-subtitle">{{adminInfo.username || '-'}}</text>
            </view>
            <view class="list-cell info-cell">
              <text class="cell-title">{{text.labels.role}}</text>
              <text class="cell-subtitle">{{displayRole}}</text>
            </view>
            <view class="list-cell info-cell" wx:if="{{!isAdmin}}">
              <text class="cell-title">{{text.labels.district}}</text>
              <text class="cell-subtitle">{{adminDistrict || '-'}}</text>
            </view>
            <view class="list-cell info-cell">
              <text class="cell-title">{{text.labels.loginTime}}</text>
              <text class="cell-subtitle">{{loginTime || '-'}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="panel">
        <view class="panel-section">
          <text class="section-title">{{text.passwordTitle}}</text>
          <text class="section-note" wx:if="{{text.passwordDesc}}">{{text.passwordDesc}}</text>
          <view class="form-stack">
            <input class="form-input" password placeholder="{{text.placeholders.oldPassword}}" value="{{oldPassword}}" bindinput="onInputOldPassword" />
            <input class="form-input" password placeholder="{{text.placeholders.newPassword}}" value="{{newPassword}}" bindinput="onInputNewPassword" />
            <input class="form-input" password placeholder="{{text.placeholders.confirmPassword}}" value="{{confirmPassword}}" bindinput="onInputConfirmPassword" />
            <button class="primary-button submit-button" bindtap="changePassword">{{text.submitPassword}}</button>
          </view>
        </view>
      </view>

      <view class="action-section">
        <button class="ghost-button logout-button" bindtap="logout">{{text.logout}}</button>
      </view>
    </view>
  </scroll-view>
</view>
