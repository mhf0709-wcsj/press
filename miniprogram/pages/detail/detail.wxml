<view class="container">
  <!-- 导航栏 -->
  <view class="nav-bar">
    <view class="nav-left" bindtap="goBack">
      <text class="nav-back">‹</text>
      <text class="nav-back-text">返回</text>
    </view>
    <text class="nav-title">记录详情</text>
    <view class="nav-right"></view>
  </view>

  <!-- 状态标签 -->
  <view class="status-header {{formData.conclusion === '合格' ? 'pass' : formData.conclusion === '不合格' ? 'fail' : 'conditional'}}">
    <text class="status-icon">{{formData.conclusion === '合格' ? '✓' : formData.conclusion === '不合格' ? '✗' : '⚠'}}</text>
    <text class="status-text">{{formData.conclusion || '待检定'}}</text>
  </view>

  <!-- 证书信息 -->
  <view class="card">
    <view class="card-header">
      <text class="card-title">证书信息</text>
    </view>
    <view class="card-content">
      <view class="form-row">
        <text class="form-label">企业</text>
        <text class="form-readonly">{{record.enterpriseName || '-'}}</text>
      </view>
      <view class="form-row">
        <text class="form-label">所属设备</text>
        <text class="form-readonly">{{record.equipmentName || '-'}}</text>
      </view>
      <view class="form-row">
        <text class="form-label">压力表名称</text>
        <text class="form-readonly">{{record.deviceName || '-'}}</text>
      </view>
      <view class="form-row">
        <text class="form-label">压力表编号</text>
        <text class="form-readonly">{{record.deviceNo || '-'}}</text>
      </view>
      <view class="form-row textarea-row">
        <text class="form-label">证书编号</text>
        <view class="form-value">
          <input class="input detail-input" value="{{formData.certNo}}" bindinput="onInput" data-field="certNo" placeholder="必填" placeholder-class="placeholder-required" cursor-spacing="120" confirm-type="done" />
        </view>
      </view>
      <view class="form-row textarea-row">
        <text class="form-label">送检单位</text>
        <view class="form-value">
          <input class="input detail-input" value="{{formData.sendUnit}}" bindinput="onInput" data-field="sendUnit" placeholder="选填" cursor-spacing="120" confirm-type="done" />
        </view>
      </view>
      <view class="form-row textarea-row">
        <text class="form-label">器具名称</text>
        <view class="form-value">
          <input class="input detail-input" value="{{formData.instrumentName}}" bindinput="onInput" data-field="instrumentName" placeholder="压力表" cursor-spacing="120" confirm-type="done" />
        </view>
      </view>
      <view class="form-row textarea-row">
        <text class="form-label">型号规格</text>
        <view class="form-value">
          <input class="input detail-input" value="{{formData.modelSpec}}" bindinput="onInput" data-field="modelSpec" placeholder="选填" cursor-spacing="120" confirm-type="done" />
        </view>
      </view>
      <view class="form-row textarea-row">
        <text class="form-label">出厂编号</text>
        <view class="form-value">
          <input class="input detail-input" value="{{formData.factoryNo}}" bindinput="onInput" data-field="factoryNo" placeholder="必填" placeholder-class="placeholder-required" cursor-spacing="120" confirm-type="done" />
        </view>
      </view>
      <view class="form-row textarea-row">
        <text class="form-label">制造单位</text>
        <view class="form-value">
          <input class="input detail-input" value="{{formData.manufacturer}}" bindinput="onInput" data-field="manufacturer" placeholder="选填" cursor-spacing="120" confirm-type="done" />
        </view>
      </view>
      <view class="form-row textarea-row">
        <text class="form-label">检定依据</text>
        <view class="form-value">
          <input class="input detail-input" value="{{formData.verificationStd}}" bindinput="onInput" data-field="verificationStd" placeholder="JJG52-2013" cursor-spacing="120" confirm-type="done" />
        </view>
      </view>
      <view class="form-row last">
        <text class="form-label">检定结论</text>
        <picker mode="selector" range="{{['合格', '不合格']}}" value="{{conclusionIndex}}" bindchange="onConclusionChange">
          <view class="form-picker">
            <text class="picker-value">{{formData.conclusion}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>
    </view>
  </view>

  <!-- 检定信息 -->
  <view class="card">
    <view class="card-header">
      <text class="card-title">检定信息</text>
    </view>
    <view class="card-content">
      <view class="form-row">
        <text class="form-label">检定日期</text>
        <picker mode="date" value="{{formData.verificationDate}}" bindchange="onDateChange">
          <view class="form-picker">
            <text class="picker-value">{{formData.verificationDate || '请选择'}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>
      <view class="form-row">
        <text class="form-label">到期日期</text>
        <text class="form-readonly">{{expiryDateText || '自动计算'}}</text>
      </view>
      <view class="form-row last">
        <text class="form-label">数据来源</text>
        <text class="form-readonly {{record.ocrSource === 'baidu' || record.ocrSource === 'ai_extract' ? 'ocr' : 'manual'}}">{{record.ocrSource === 'baidu' || record.ocrSource === 'ai_extract' ? 'AI识别' : '手动录入'}}</text>
      </view>
    </view>
  </view>

  <!-- 所在辖区 -->
  <view class="card">
    <view class="card-header">
      <text class="card-title">所在辖区</text>
    </view>
    <view class="card-content">
      <view class="form-row last">
        <text class="form-label">辖区</text>
        <picker mode="selector" range="{{districtOptions}}" value="{{districtIndex}}" bindchange="onDistrictChange">
          <view class="form-picker">
            <text class="picker-value">{{formData.district || '请选择'}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>
    </view>
  </view>

  <!-- 关联设备 -->
  <view class="card">
    <view class="card-header">
      <text class="card-title">关联设备</text>
    </view>
    <view class="card-content">
      <picker mode="selector" range="{{devices}}" range-key="deviceName" value="{{deviceIndex}}" bindchange="onDeviceChange">
        <view class="form-row">
          <text class="form-label">选择设备</text>
          <view class="form-picker">
            <text class="picker-value">{{selectedDeviceName || '请选择（可选）'}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </view>
      </picker>
      <view class="form-row last" wx:if="{{!selectedDeviceId}}">
        <button class="link-btn" bindtap="showNewDeviceForm">+ 新建设备</button>
      </view>
    </view>
  </view>

  <!-- 新建设备表单 -->
  <view class="card" wx:if="{{showNewDevice}}">
    <view class="card-header">
      <text class="card-title">新建设备</text>
      <text class="card-action" bindtap="hideNewDeviceForm">取消</text>
    </view>
    <view class="card-content">
      <view class="form-row">
        <text class="form-label">设备编号</text>
        <input class="form-input" value="{{newDevice.deviceNo}}" bindinput="onNewDeviceInput" data-field="deviceNo" placeholder="选填" />
      </view>
      <view class="form-row">
        <text class="form-label">设备名称</text>
        <input class="form-input" value="{{newDevice.deviceName}}" bindinput="onNewDeviceInput" data-field="deviceName" placeholder="必填" placeholder-class="placeholder-required" />
      </view>
      <view class="form-row last">
        <text class="form-label">设备类型</text>
        <input class="form-input" value="{{newDevice.deviceType}}" bindinput="onNewDeviceInput" data-field="deviceType" placeholder="如：压力表" />
      </view>
      <button class="primary-btn" bindtap="saveNewDevice" style="margin-top: 16rpx;">创建设备</button>
    </view>
  </view>

  <!-- 设备状态 -->
  <view class="card">
    <view class="card-header">
      <text class="card-title">设备状态</text>
    </view>
    <view class="card-content">
      <picker mode="selector" range="{{deviceStatusOptions}}" value="{{deviceStatusIndex}}" bindchange="onDeviceStatusChange">
        <view class="form-row last">
          <text class="form-label">当前状态</text>
          <view class="form-picker">
            <text class="picker-value">{{formData.deviceStatus || '请选择'}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </view>
      </picker>
    </view>
  </view>

  <!-- 证书图片 -->
  <view class="card" wx:if="{{record.fileID}}">
    <view class="card-header">
      <text class="card-title">证书图片</text>
    </view>
    <view class="card-content">
      <view class="thumbnail-box" bindtap="previewImage">
        <image src="{{record.fileID}}" mode="aspectFill" class="thumbnail-image" />
        <view class="thumbnail-mask">
          <text class="mask-icon">🔍</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 安装照片 -->
  <view class="card" wx:if="{{record.installPhotoFileID}}">
    <view class="card-header">
      <text class="card-title">安装照片</text>
    </view>
    <view class="card-content">
      <view class="thumbnail-box" bindtap="previewInstallPhoto">
        <image src="{{record.installPhotoFileID}}" mode="aspectFill" class="thumbnail-image" />
        <view class="thumbnail-mask">
          <text class="mask-icon">🔍</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 照片缺失提示 -->
  <view class="card missing-photo" wx:if="{{!record.fileID && !record.installPhotoFileID}}">
    <view class="card-content center">
      <text class="missing-text">📷 暂无照片</text>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar">
    <button class="delete-btn" bindtap="deleteRecord">删除</button>
    <button class="save-btn" bindtap="saveRecord" loading="{{saving}}">{{saving ? '保存中' : '保存修改'}}</button>
  </view>
</view>
