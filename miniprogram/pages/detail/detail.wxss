.detail-page {
  min-height: 100vh;
}

.detail-nav {
  position: sticky;
  top: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 28rpx;
  background: rgba(255, 255, 255, 0.88);
  border-bottom: 1rpx solid rgba(17, 24, 39, 0.06);
  backdrop-filter: blur(24rpx);
}

.detail-nav-back {
  display: flex;
  align-items: center;
  min-width: 104rpx;
}

.detail-nav-arrow,
.detail-nav-text {
  color: var(--color-brand);
}

.detail-nav-arrow {
  font-size: 40rpx;
}

.detail-nav-text {
  font-size: var(--font-size-footnote);
}

.detail-nav-title {
  font-size: var(--font-size-callout);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-main);
}

.detail-nav-placeholder {
  width: 104rpx;
}

.detail-wrapper {
  padding-bottom: 176rpx;
}

.detail-status {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx 24rpx;
  margin-bottom: 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid rgba(17, 24, 39, 0.06);
}

.detail-status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: var(--color-warning);
}

.status-pass .detail-status-dot {
  background: var(--color-accent);
}

.status-fail .detail-status-dot {
  background: var(--color-danger);
}

.detail-status-text {
  font-size: var(--font-size-footnote);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-main);
}

.detail-card {
  margin-bottom: 24rpx;
}

.detail-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 98rpx;
  padding: 8rpx 0;
  border-bottom: 1rpx solid rgba(17, 24, 39, 0.06);
}

.detail-row.no-border {
  border-bottom: none;
}

.detail-label {
  width: 156rpx;
  flex-shrink: 0;
  font-size: var(--font-size-footnote);
  color: var(--color-text-secondary);
}

.detail-input,
.detail-static,
.detail-picker,
.detail-link {
  flex: 1;
  min-width: 0;
}

.detail-input {
  height: 80rpx;
  font-size: var(--font-size-body);
  color: var(--color-text-main);
  text-align: right;
}

.detail-static {
  font-size: var(--font-size-body);
  line-height: 1.5;
  color: var(--color-text-main);
  text-align: right;
}

.detail-picker {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 12rpx;
}

.detail-picker-value {
  font-size: var(--font-size-body);
  color: var(--color-text-main);
}

.detail-picker-arrow {
  color: var(--color-text-tertiary);
  font-size: 30rpx;
}

.detail-source {
  justify-self: end;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: var(--font-size-caption);
  font-weight: var(--font-weight-medium);
}

.detail-source.ai {
  background: var(--color-brand-soft);
  color: var(--color-brand);
}

.detail-source.manual {
  background: var(--color-warning-soft);
  color: var(--color-warning);
}

.detail-link {
  display: inline-flex;
  justify-content: flex-end;
  padding: 0;
  background: transparent;
  color: var(--color-brand);
  font-size: var(--font-size-body);
  border: none;
}

.detail-link::after {
  border: none;
}

.detail-inline-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.detail-inline-action {
  color: var(--color-brand);
  font-size: var(--font-size-footnote);
}

.detail-create {
  margin-top: 24rpx;
  min-height: 88rpx;
  border: none;
  border-radius: 999rpx;
  background: var(--color-brand);
  color: var(--color-text-white);
  font-size: var(--font-size-callout);
  font-weight: var(--font-weight-semibold);
}

.detail-create::after {
  border: none;
}

.detail-photo-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 20rpx;
}

.detail-photo-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.detail-photo {
  width: 100%;
  height: 240rpx;
  border-radius: var(--radius-lg);
  background: var(--color-bg-subtle);
}

.detail-photo-label {
  font-size: var(--font-size-caption);
  color: var(--color-text-secondary);
}

.detail-bottom-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  display: flex;
  gap: 16rpx;
  padding: 16rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(17, 24, 39, 0.06);
  box-shadow: var(--shadow-md);
  backdrop-filter: blur(24rpx);
}

.detail-delete,
.detail-save {
  border: none;
  border-radius: 999rpx;
  min-height: 88rpx;
  font-size: var(--font-size-callout);
  font-weight: var(--font-weight-semibold);
}

.detail-delete::after,
.detail-save::after {
  border: none;
}

.detail-delete {
  width: 180rpx;
  background: rgba(255, 59, 48, 0.12);
  color: var(--color-danger);
}

.detail-save {
  flex: 1;
  background: var(--color-brand);
  color: var(--color-text-white);
}
