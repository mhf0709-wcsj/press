<view class="page-shell archive-page">
  <view class="content-wrapper archive-wrapper">
    <view class="archive-hero panel">
      <view class="panel-section">
        <text class="eyebrow">设备中心</text>
        <view class="page-title archive-title">设备档案</view>
      </view>
    </view>

    <view class="archive-search panel" wx:if="{{equipments.length > 0}}">
      <view class="panel-section archive-search-section">
        <view class="search-bar">
          <text class="search-icon">搜索</text>
          <input class="search-input" placeholder="设备名称或编号" bindinput="onSearch" />
          <text class="search-count">{{equipments.length}}</text>
        </view>
      </view>
    </view>

    <view class="empty-state panel" wx:if="{{equipments.length === 0}}">
      <view class="panel-section empty-section">
        <view class="empty-badge">+</view>
        <view class="section-title">暂无设备</view>
        <button class="primary-cta" bindtap="createEquipment">新建设备</button>
      </view>
    </view>

    <view class="archive-list" wx:elif="{{equipments.length > 0}}">
      <block wx:for="{{equipments}}" wx:key="_id">
        <view class="swipe-container">
          <view
            class="swipe-content {{swipeIndex === index ? 'swiped' : ''}}"
            bindtouchstart="onTouchStart"
            bindtouchmove="onTouchMove"
            bindtouchend="onTouchEnd"
            data-index="{{index}}"
          >
            <view class="archive-card panel" bindtap="viewDetail" data-id="{{item._id}}">
              <view class="panel-section archive-card-section">
                <view class="archive-card-top">
                  <view class="archive-card-copy">
                    <view class="archive-card-title">{{item.equipmentName || '未命名设备'}}</view>
                    <view class="archive-card-meta">{{item.equipmentNo || '-'}}</view>
                  </view>
                  <view class="archive-pill">{{item.gaugeCount || 0}} 块</view>
                </view>
                <view class="archive-grid">
                  <view class="archive-grid-item">
                    <text class="archive-grid-label">位置</text>
                    <text class="archive-grid-value">{{item.location || '-'}}</text>
                  </view>
                  <view class="archive-grid-item">
                    <text class="archive-grid-label">辖区</text>
                    <text class="archive-grid-value">{{item.district || '-'}}</text>
                  </view>
                </view>
                <view class="archive-card-footer">
                  <text class="archive-time">{{item.createTime}}</text>
                  <text class="archive-arrow">></text>
                </view>
              </view>
            </view>
          </view>
          <view
            class="swipe-delete {{swipeIndex === index ? 'open' : ''}}"
            bindtap="confirmDelete"
            data-id="{{item._id}}"
            data-index="{{index}}"
          >
            <text class="swipe-delete-text">删除</text>
          </view>
        </view>
      </block>
    </view>
  </view>

  <view class="archive-bottom-bar" wx:if="{{equipments.length > 0}}">
    <button class="bottom-ghost" bindtap="loadEquipments">刷新</button>
    <button class="bottom-primary" bindtap="createEquipment">新建</button>
  </view>
</view>
