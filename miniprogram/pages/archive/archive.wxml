<view class="container">
  <!-- 大标题区域 -->
  <view class="header-section">
    <view class="header-content">
      <text class="large-title">设备库</text>
      
    </view>
  </view>

  

  <!-- 空状态 -->
  <view wx:if="{{equipments.length === 0}}" class="empty-section">
    <view class="empty-icon-wrap">
      <text class="empty-icon">📋</text>
    </view>
    <text class="empty-title">暂无设备档案</text>
    <text class="empty-desc">先创建设备，再在设备下绑定压力表</text>
    <button class="primary-btn" bindtap="createEquipment">
      <text class="btn-icon">📷</text>
      <text class="btn-text">新建设备</text>
    </button>
  </view>

  <!-- 记录列表 -->
  <view wx:elif="{{equipments.length > 0}}" class="records-section">
    <block wx:for="{{equipments}}" wx:key="_id">
      <view class="swipe-container">
        <!-- 滑动内容区 -->
        <view 
          class="swipe-content {{swipeIndex === index ? 'swiped' : ''}}" 
          bindtouchstart="onTouchStart" 
          bindtouchmove="onTouchMove" 
          bindtouchend="onTouchEnd"
          data-index="{{index}}"
        >
          <view class="card" bindtap="viewDetail" data-id="{{item._id}}">
            <view class="card-content">
              <view class="record-header">
                <view class="record-left">
                  <text class="record-no">{{item.equipmentName || '未命名设备'}}</text>
                </view>
                <view class="record-right">
                  <text class="device-status-tag in-use">{{item.gaugeCount || 0}} 台压力表</text>
                  <text class="arrow">›</text>
                </view>
              </view>
              <view class="record-info">
                <view class="info-item">
                  <text class="info-label">设备编号</text>
                  <text class="info-value">{{item.equipmentNo || '-'}}</text>
                </view>
                <view class="info-item">
                  <text class="info-label">安装位置</text>
                  <text class="info-value">{{item.location || '-'}}</text>
                </view>
                <view class="info-item" wx:if="{{item.district}}">
                  <text class="info-label">辖区</text>
                  <text class="info-value">{{item.district}}</text>
                </view>
              </view>
              <view class="record-footer">
                <text class="footer-time">{{item.createTime}}</text>
              </view>
            </view>
          </view>
        </view>
        <!-- 删除按钮 -->
        <view class="swipe-delete" bindtap="confirmDelete" data-id="{{item._id}}" data-index="{{index}}">
          <text class="delete-icon">🗑️</text>
          <text class="delete-text">删除</text>
        </view>
      </view>
    </block>
  </view>

  <!-- 底部搜索和统计 -->
  <view class="bottom-search-section" wx:if="{{equipments.length > 0}}">
    <view class="search-bar">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="搜索设备名称/编号" bindinput="onSearch" />
    </view>
    <text class="record-count">共 {{equipments.length}} 条</text>
  </view>

  <!-- 底部操作 -->
  <view class="bottom-bar" wx:if="{{equipments.length > 0}}">
    <button class="secondary-btn" bindtap="loadEquipments">
      <text class="btn-icon">🔄</text>
      <text class="btn-text">刷新</text>
    </button>
    <button class="primary-btn" bindtap="createEquipment">
      <text class="btn-icon">📤</text>
      <text class="btn-text">新建</text>
    </button>
  </view>
</view>

<!-- AI悬浮按钮 -->
