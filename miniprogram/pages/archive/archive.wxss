.archive-page {
  min-height: 100vh;
}

.archive-wrapper {
  padding-bottom: 176rpx;
}

.archive-hero,
.archive-search,
.archive-card,
.empty-state {
  margin-bottom: 24rpx;
}

.archive-title {
  margin-top: 20rpx;
}

.archive-search-section {
  padding-top: 24rpx;
  padding-bottom: 24rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 88rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid rgba(17, 24, 39, 0.06);
}

.search-icon {
  color: var(--color-text-tertiary);
  font-size: 26rpx;
}

.search-input {
  flex: 1;
  font-size: var(--font-size-body);
  color: var(--color-text-main);
}

.search-count {
  font-size: var(--font-size-caption);
  color: var(--color-text-tertiary);
}

.empty-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding-top: 64rpx;
  padding-bottom: 64rpx;
}

.empty-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 108rpx;
  height: 108rpx;
  margin-bottom: 24rpx;
  border-radius: 36rpx;
  background: var(--color-brand-soft);
  color: var(--color-brand);
  font-size: 56rpx;
  font-weight: var(--font-weight-medium);
}

.primary-cta,
.bottom-primary,
.bottom-ghost {
  border: none;
  border-radius: 999rpx;
}

.primary-cta::after,
.bottom-primary::after,
.bottom-ghost::after {
  border: none;
}

.primary-cta {
  min-width: 280rpx;
  margin-top: 30rpx;
  padding: 0 36rpx;
  min-height: 88rpx;
  background: var(--color-brand);
  color: var(--color-text-white);
  font-size: var(--font-size-callout);
  font-weight: var(--font-weight-semibold);
}

.swipe-container {
  position: relative;
  margin-bottom: 20rpx;
  overflow: hidden;
  border-radius: var(--radius-xl);
  width: 100%;
}

.swipe-content {
  position: relative;
  z-index: 2;
  width: 100%;
  display: block;
  transition: transform 180ms ease;
  will-change: transform;
}

.swipe-content.swiped {
  transform: translateX(-148rpx);
}

.swipe-delete {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 0;
  opacity: 0;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
  pointer-events: none;
  transition: width 180ms ease, opacity 180ms ease;
}

.swipe-delete.open {
  width: 148rpx;
  opacity: 1;
  pointer-events: auto;
}

.swipe-delete::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 0 var(--radius-xl) var(--radius-xl) 0;
  background: linear-gradient(180deg, #ef4444, #d92d20);
}

.swipe-delete-text {
  position: relative;
  z-index: 1;
  color: #fff;
  font-size: var(--font-size-footnote);
  font-weight: var(--font-weight-semibold);
}

.archive-card-section {
  padding-top: 28rpx;
  padding-bottom: 28rpx;
}

.archive-card-top {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  align-items: flex-start;
}

.archive-card-copy {
  min-width: 0;
  flex: 1;
}

.archive-card-title {
  font-size: var(--font-size-title3);
  line-height: 1.2;
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-main);
}

.archive-card-meta {
  margin-top: 10rpx;
  font-size: var(--font-size-footnote);
  color: var(--color-text-secondary);
}

.archive-pill {
  flex-shrink: 0;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: var(--color-brand-soft);
  color: var(--color-brand);
  font-size: var(--font-size-caption);
  font-weight: var(--font-weight-medium);
}

.archive-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 24rpx;
}

.archive-grid-item {
  padding: 20rpx;
  border-radius: var(--radius-md);
  background: rgba(247, 248, 251, 0.96);
}

.archive-grid-label {
  display: block;
  font-size: var(--font-size-caption);
  color: var(--color-text-tertiary);
}

.archive-grid-value {
  display: block;
  margin-top: 10rpx;
  font-size: var(--font-size-footnote);
  line-height: 1.5;
  color: var(--color-text-main);
}

.archive-card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 24rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid rgba(17, 24, 39, 0.06);
}

.archive-time {
  font-size: var(--font-size-caption);
  color: var(--color-text-tertiary);
}

.archive-arrow {
  color: var(--color-text-tertiary);
  font-size: 34rpx;
}

.archive-bottom-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  display: flex;
  gap: 16rpx;
  padding: 16rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(17, 24, 39, 0.06);
  box-shadow: var(--shadow-md);
  backdrop-filter: blur(24rpx);
}

.bottom-ghost,
.bottom-primary {
  flex: 1;
  min-height: 88rpx;
  font-size: var(--font-size-callout);
  font-weight: var(--font-weight-semibold);
}

.bottom-ghost {
  background: rgba(242, 245, 250, 0.96);
  color: var(--color-text-main);
}

.bottom-primary {
  background: var(--color-brand);
  color: var(--color-text-white);
}
