/* iOS 26 Style - Archive Page */
page {
  background: #f2f2f7;
}

.container {
  min-height: 100vh;
  padding-bottom: 240rpx;
}

/* 大标题区域 */
.header-section {
  background: #f2f2f7;
  padding: 0 32rpx 24rpx;
}

.header-content {
  display: flex;
  flex-direction: column;
}

.large-title {
  font-size: 60rpx;
  font-weight: 700;
  color: #000;
  letter-spacing: -1rpx;
}

.header-subtitle {
  font-size: 28rpx;
  color: #8e8e93;
  margin-top: 8rpx;
}

/* 搜索栏 */
.search-section {
  padding: 0 32rpx;
  margin-bottom: 16rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  background: #e5e5ea;
  border-radius: 20rpx;
  padding: 0 24rpx;
  height: 80rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #000;
}

.search-input::placeholder {
  color: #8e8e93;
}

/* 空状态 */
.empty-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  background: #e5e5ea;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.empty-icon {
  font-size: 56rpx;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #000;
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #8e8e93;
  margin-bottom: 32rpx;
}

/* 按钮 */
.primary-btn {
  width: 100%;
  max-width: 400rpx;
  height: 104rpx;
  background: #007AFF;
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 24rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.primary-btn::after {
  border: none;
}

.secondary-btn {
  height: 104rpx;
  background: #e5e5ea;
  color: #000;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 24rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
}

.secondary-btn::after {
  border: none;
}

.btn-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.btn-text {
  font-size: 34rpx;
  font-weight: 600;
}

/* 滑动删除 */
.swipe-container {
  position: relative;
  margin-bottom: 20rpx;
  overflow: hidden;
  border-radius: 24rpx;
}

.swipe-content {
  position: relative;
  z-index: 2;
  background: #fff;
  transition: transform 0.25s ease-out;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.swipe-content.swiped {
  transform: translateX(-140rpx);
}

.swipe-delete {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 140rpx;
  background: #f2f2f7;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 1;
  border-radius: 0 24rpx 24rpx 0;
}

.delete-icon {
  width: 64rpx;
  height: 64rpx;
  background: #ff3b30;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
  font-size: 32rpx;
}

.delete-text {
  font-size: 22rpx;
  color: #ff3b30;
  font-weight: 500;
}

/* 记录列表 */
.records-section {
  padding: 0 24rpx;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.card-content {
  padding: 28rpx 32rpx;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.record-left {
  flex: 1;
}

.record-no {
  font-size: 34rpx;
  font-weight: 600;
  color: #000;
}

.record-right {
  display: flex;
  align-items: center;
}

.status-tag {
  font-size: 26rpx;
  font-weight: 600;
  padding: 10rpx 20rpx;
  border-radius: 12rpx;
  margin-right: 12rpx;
}

.status-tag.pass {
  background: #d1fae5;
  color: #059669;
}

.status-tag.fail {
  background: #fee2e2;
  color: #dc2626;
}

.status-tag.conditional {
  background: #fef3c7;
  color: #d97706;
}

.arrow {
  font-size: 40rpx;
  color: #c7c7cc;
}

.record-info {
  display: flex;
  flex-wrap: wrap;
  border-top: 1rpx solid #e5e5ea;
  padding-top: 20rpx;
  gap: 12rpx 0;
}

.info-item {
  width: 50%;
  display: flex;
  flex-direction: column;
  padding: 8rpx 0;
}

.info-label {
  font-size: 24rpx;
  color: #8e8e93;
  margin-bottom: 4rpx;
}

.info-value {
  font-size: 28rpx;
  color: #000;
  font-weight: 500;
}

.record-footer {
  display: flex;
  justify-content: space-between;
  padding-top: 16rpx;
  margin-top: 16rpx;
  border-top: 1rpx solid #e5e5ea;
}

.footer-text {
  font-size: 24rpx;
  color: #007AFF;
  background: rgba(0, 122, 255, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.footer-time {
  font-size: 24rpx;
  color: #8e8e93;
}

/* 底部搜索和统计 */
.bottom-search-section {
  position: fixed;
  bottom: calc(124rpx + env(safe-area-inset-bottom));
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 16rpx 32rpx;
  background: #f2f2f7;
}

.bottom-search-section .search-bar {
  flex: 1;
}

.record-count {
  font-size: 26rpx;
  color: #8e8e93;
  white-space: nowrap;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 16rpx;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #f2f2f7;
}

.bottom-bar .secondary-btn {
  flex: 0 0 auto;
  width: 180rpx;
}

.bottom-bar .primary-btn {
  flex: 1;
  max-width: none;
}
