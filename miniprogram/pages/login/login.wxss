.login-page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(210, 225, 255, 0.85), transparent 34%),
    radial-gradient(circle at bottom right, rgba(235, 242, 255, 0.96), transparent 36%),
    #f7f9fc;
}

.login-shell {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 72rpx 40rpx 48rpx;
}

.login-card {
  width: 100%;
  max-width: 680rpx;
  padding: 52rpx 42rpx 38rpx;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(214, 222, 235, 0.9);
  box-shadow: 0 22rpx 70rpx rgba(28, 48, 86, 0.08);
}

.login-brand {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.brand-mark {
  width: 76rpx;
  height: 76rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #1a73e8 0%, #1358bf 100%);
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 700;
  box-shadow: 0 12rpx 28rpx rgba(26, 115, 232, 0.2);
}

.brand-name {
  font-size: 24rpx;
  line-height: 1;
  color: #5f6368;
}

.login-copy {
  margin-top: 34rpx;
}

.login-title {
  font-size: 58rpx;
  line-height: 1.12;
  font-weight: 700;
  color: #202124;
}

.login-desc {
  margin-top: 14rpx;
  font-size: 28rpx;
  color: #5f6368;
}

.login-form {
  margin-top: 36rpx;
}

.wechat-submit {
  margin-top: 34rpx;
}

.wechat-hint {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #5f6368;
  text-align: center;
}

.manual-toggle {
  margin-top: 28rpx;
  min-height: 72rpx;
  border-radius: 999rpx;
  background: #f2f6fc;
  border: 1rpx solid #d8e2f1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #1a73e8;
  font-weight: 600;
}

.manual-submit {
  margin-top: 28rpx;
}

.field-block + .field-block {
  margin-top: 22rpx;
}

.field-label {
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: #3c4043;
  font-weight: 500;
}

.field-input {
  width: 100%;
  min-height: 96rpx;
  padding: 0 26rpx;
  border-radius: 22rpx;
  border: 2rpx solid #dadce0;
  background: #ffffff;
  font-size: 28rpx;
  color: #202124;
  box-sizing: border-box;
}

.field-input:focus {
  border-color: #1a73e8;
}

.input-placeholder {
  color: #9aa0a6;
}

.login-submit {
  width: 100%;
  margin-top: 32rpx;
  border-radius: 999rpx;
}

.login-submit.is-loading {
  opacity: 0.82;
}

.login-actions {
  margin-top: 30rpx;
}

.assist-row {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.assist-text {
  font-size: 24rpx;
  color: #5f6368;
}

.assist-link {
  font-size: 24rpx;
  color: #1a73e8;
  font-weight: 600;
}

.admin-entry {
  min-height: auto;
  padding: 0;
  color: #3c4043;
  font-size: 24rpx;
}

.version-text {
  margin-top: 28rpx;
  font-size: 22rpx;
  color: #9aa0a6;
}
