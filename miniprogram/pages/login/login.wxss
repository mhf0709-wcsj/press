/* iOS 16 Style - Login Page */
page {
  background: linear-gradient(180deg, #f0f5ff 0%, #e6f0ff 50%, #f5f7fa 100%);
}

.container {
  min-height: 100vh;
  padding: 0 32rpx;
  padding-top: 120rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

/* 背景装饰 */
.bg-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 600rpx;
  overflow: hidden;
}

.circle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.6;
}

.circle-1 {
  width: 400rpx;
  height: 400rpx;
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  top: -150rpx;
  right: -100rpx;
  filter: blur(60rpx);
}

.circle-2 {
  width: 300rpx;
  height: 300rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  top: 100rpx;
  left: -80rpx;
  filter: blur(50rpx);
}

.circle-3 {
  width: 200rpx;
  height: 200rpx;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  top: 300rpx;
  right: 60rpx;
  filter: blur(40rpx);
}

/* Logo区域 */
.logo-section {
  text-align: center;
  margin-bottom: 60rpx;
  position: relative;
  z-index: 10;
}

.logo-icon {
  width: 140rpx;
  height: 140rpx;
  margin: 0 auto 24rpx;
  background: linear-gradient(135deg, #007AFF 0%, #5856D6 100%);
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 20rpx 60rpx rgba(0, 122, 255, 0.3);
}

.icon-text {
  font-size: 64rpx;
  color: #fff;
  font-weight: 700;
}

.app-name {
  font-size: 44rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.app-slogan {
  font-size: 26rpx;
  color: #8e8e93;
  letter-spacing: 1rpx;
}

/* 登录卡片 */
.login-card {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20px);
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.08);
  position: relative;
  z-index: 10;
}

.card-header {
  margin-bottom: 40rpx;
}

.card-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 16rpx;
}

.card-line {
  width: 48rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #007AFF 0%, #5856D6 100%);
  border-radius: 3rpx;
}

/* 表单区域 */
.form-section {
  margin-bottom: 32rpx;
}

.input-group {
  display: flex;
  align-items: center;
  background: #f5f5f7;
  border-radius: 20rpx;
  padding: 0 24rpx;
  margin-bottom: 24rpx;
  height: 100rpx;
  transition: all 0.3s ease;
}

.input-group:focus-within {
  background: #fff;
  box-shadow: 0 0 0 4rpx rgba(0, 122, 255, 0.15);
}

.input-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.iconfont {
  font-size: 36rpx;
}

.input-field {
  flex: 1;
  height: 100rpx;
  font-size: 30rpx;
  color: #1a1a1a;
}

.placeholder-style {
  color: #c7c7cc;
  font-size: 30rpx;
}

/* 登录按钮 */
.login-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #007AFF 0%, #5856D6 100%);
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 24rpx;
  border: none;
  margin-top: 16rpx;
  box-shadow: 0 12rpx 32rpx rgba(0, 122, 255, 0.25);
  transition: all 0.3s ease;
}

.login-btn:active {
  transform: scale(0.98);
  box-shadow: 0 6rpx 20rpx rgba(0, 122, 255, 0.2);
}

.login-btn.disabled {
  background: linear-gradient(135deg, #a8a8a8 0%, #8e8e93 100%);
  box-shadow: none;
}

/* 链接区域 */
.links-section {
  margin-top: 32rpx;
  text-align: center;
}

.link-item {
  display: flex;
  align-items: center;
  justify-content: center;
}

.link-text {
  font-size: 28rpx;
  color: #8e8e93;
}

.link-highlight {
  font-size: 28rpx;
  color: #007AFF;
  font-weight: 500;
  margin-left: 8rpx;
}

/* 底部链接 */
.footer-link {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 48rpx;
  padding: 24rpx;
  position: relative;
  z-index: 10;
}

.footer-text {
  font-size: 28rpx;
  color: #8e8e93;
}

.arrow {
  font-size: 36rpx;
  color: #8e8e93;
  margin-left: 8rpx;
}

/* 版本信息 */
.version-info {
  text-align: center;
  margin-top: 60rpx;
  padding-bottom: 40rpx;
}

.version-info text {
  font-size: 24rpx;
  color: #c7c7cc;
}
