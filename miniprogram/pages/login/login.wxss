.login-page {
  min-height: 100vh;
}

.login-wrapper {
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-height: 100vh;
  padding-top: 48rpx;
  padding-bottom: 48rpx;
}

.login-hero {
  position: relative;
  z-index: 1;
  margin-bottom: 28rpx;
  padding: 16rpx 8rpx 0;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.78);
  border: 2rpx solid rgba(219, 228, 240, 0.9);
  color: var(--color-brand);
  font-size: var(--font-size-xs);
  letter-spacing: 1rpx;
}

.hero-mark {
  width: 132rpx;
  height: 132rpx;
  margin-top: 24rpx;
  border-radius: 38rpx;
  background: linear-gradient(145deg, #10284b 0%, var(--color-brand) 62%, #6da8ff 100%);
  box-shadow: var(--shadow-lg);
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-mark-text {
  color: var(--color-text-white);
  font-size: 64rpx;
  font-weight: var(--font-weight-bold);
}

.hero-copy {
  margin-top: 28rpx;
}

.hero-title {
  font-size: 54rpx;
  line-height: 1.12;
  font-weight: var(--font-weight-bold);
  color: var(--color-text-main);
}

.hero-desc {
  margin-top: 18rpx;
  font-size: var(--font-size-base);
  line-height: 1.7;
  color: var(--color-text-secondary);
}

.hero-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 26rpx;
}

.meta-chip {
  padding: 16rpx 18rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.84);
  border: 2rpx solid rgba(219, 228, 240, 0.9);
}

.meta-label {
  display: block;
  font-size: var(--font-size-xs);
  color: var(--color-text-muted);
}

.meta-value {
  display: block;
  margin-top: 6rpx;
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-main);
}

.login-panel {
  width: 100%;
}

.panel-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.panel-tag {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: var(--color-accent-soft);
  color: var(--color-warning);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-medium);
}

.input-placeholder {
  color: var(--color-text-muted);
}

.login-submit {
  width: 100%;
  margin-top: 20rpx;
}

.login-submit.is-loading {
  opacity: 0.78;
}

.assist-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-top: 28rpx;
}

.assist-text {
  color: var(--color-text-secondary);
  font-size: var(--font-size-sm);
}

.assist-link {
  color: var(--color-brand);
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
}

.login-footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  margin-top: 28rpx;
}

.admin-entry {
  min-height: auto;
}

.version-text {
  color: var(--color-text-muted);
  font-size: var(--font-size-xs);
}
