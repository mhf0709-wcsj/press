<view class="page-shell login-page">
  <view class="content-wrapper login-wrapper">
    <view class="login-hero">
      <view class="hero-badge">压力表智能助手</view>
      <view class="hero-mark">
        <text class="hero-mark-text">P</text>
      </view>
      <view class="hero-copy">
        <view class="hero-title">鍘嬪姏琛ㄦ瀹氭櫤鑳戒綋</view>
        <view class="hero-desc">浼佷笟绔揩閫熺櫥褰曪紝杩涘叆鎷嶇収璇嗗埆銆佽澶囧瓨妗ｄ笌鍒版湡鎻愰啋娴佺▼銆?/view>
      </view>
      <view class="hero-meta">
        <view class="meta-chip">
          <text class="meta-label">瀹氫綅</text>
          <text class="meta-value">浼佷笟鍏ュ彛</text>
        </view>
        <view class="meta-chip">
          <text class="meta-label">鑳藉姏</text>
          <text class="meta-value">璇嗗埆 / 寤烘。 / 绠＄悊</text>
        </view>
      </view>
    </view>

    <view class="panel login-panel">
      <view class="panel-section">
        <view class="panel-title-row">
          <view>
            <view class="section-title">浼佷笟鐧诲綍</view>
            <view class="section-desc">浣跨敤浼佷笟鍚嶇О鍜岃仈绯讳汉鎵嬫満鍙疯繘鍏ヤ笟鍔″彴銆?/view>
          </view>
          <view class="panel-tag">蹇嵎鍏ュ彛</view>
        </view>

        <view class="field-block">
          <view class="field-label">浼佷笟鍚嶇О</view>
          <input
            class="field-input"
            placeholder="璇疯緭鍏ヤ紒涓氬悕绉?
            value="{{companyName}}"
            bindinput="onInputCompanyName"
            placeholder-class="input-placeholder"
          />
        </view>

        <view class="field-block">
          <view class="field-label">鎵嬫満鍙风爜</view>
          <input
            class="field-input"
            type="number"
            maxlength="11"
            placeholder="璇疯緭鍏ヨ仈绯讳汉鎵嬫満鍙?
            value="{{phone}}"
            bindinput="onInputPhone"
            placeholder-class="input-placeholder"
          />
        </view>

        <button
          class="btn-primary-solid login-submit {{loading ? 'is-loading' : ''}}"
          bindtap="handleLogin"
          disabled="{{loading}}"
        >
          <text>{{loading ? '鐧诲綍涓?..' : '杩涘叆宸ヤ綔鍙?}}</text>
