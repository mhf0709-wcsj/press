          <view class="assist-link" bindtap="goToRegister">绔嬪嵆娉ㄥ唽</view>
        </view>
      </view>
    </view>

    <view class="login-footer">
      <button class="btn-ghost-link admin-entry" bindtap="goToAdminLogin">鍒囨崲鍒扮鐞嗙鐧诲綍</button>
      <view class="version-text">Version 1.2.0</view>
    </view>
