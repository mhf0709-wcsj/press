<view class="page-shell login-page">
  <view class="content-wrapper login-wrapper">
    <view class="login-hero">
      <view class="hero-badge">Pressure Gauge AI</view>
      <view class="hero-mark">
        <text class="hero-mark-text">P</text>
      </view>
      <view class="hero-copy">
        <view class="hero-title">压力表检定智能体</view>
        <view class="hero-desc">企业端快速登录，进入拍照识别、设备存档与到期提醒流程。</view>
      </view>
      <view class="hero-meta">
        <view class="meta-chip">
          <text class="meta-label">定位</text>
          <text class="meta-value">企业入口</text>
        </view>
        <view class="meta-chip">
          <text class="meta-label">能力</text>
          <text class="meta-value">识别 / 建档 / 管理</text>
        </view>
      </view>
    </view>

    <view class="panel login-panel">
      <view class="panel-section">
        <view class="panel-title-row">
          <view>
            <view class="section-title">企业登录</view>
            <view class="section-desc">使用企业名称和联系人手机号进入业务台。</view>
          </view>
          <view class="panel-tag">快捷入口</view>
        </view>

        <view class="field-block">
          <view class="field-label">企业名称</view>
          <input
            class="field-input"
            placeholder="请输入企业名称"
            value="{{companyName}}"
            bindinput="onInputCompanyName"
            placeholder-class="input-placeholder"
          />
        </view>

        <view class="field-block">
          <view class="field-label">手机号码</view>
          <input
            class="field-input"
            type="number"
            maxlength="11"
            placeholder="请输入联系人手机号"
            value="{{phone}}"
            bindinput="onInputPhone"
            placeholder-class="input-placeholder"
          />
        </view>

        <button
          class="btn-primary-solid login-submit {{loading ? 'is-loading' : ''}}"
          bindtap="handleLogin"
          disabled="{{loading}}"
        >
          <text>{{loading ? '登录中...' : '进入工作台'}}</text>
        </button>

        <view class="assist-row">
          <view class="assist-text">还没有企业账号？</view>
          <view class="assist-link" bindtap="goToRegister">立即注册</view>
        </view>
      </view>
    </view>

    <view class="login-footer">
      <button class="btn-ghost-link admin-entry" bindtap="goToAdminLogin">切换到管理端登录</button>
      <view class="version-text">Version 1.2.0</view>
    </view>
  </view>
</view>

<privacy />
