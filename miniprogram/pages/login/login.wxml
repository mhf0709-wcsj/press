<view class="page-shell login-page">
  <view class="login-shell">
    <view class="login-card">
      <view class="login-brand">
        <view class="brand-mark">P</view>
        <view class="brand-name">{{text.brandName}}</view>
      </view>

      <view class="login-copy">
        <view class="login-title">{{text.title}}</view>
        <view class="login-desc">{{text.desc}}</view>
      </view>

      <button
        class="btn-primary-solid login-submit wechat-submit {{loading ? 'is-loading' : ''}}"
        bindtap="handleWechatLogin"
        disabled="{{loading}}"
      >
        <text>{{loading ? text.wechatSubmitting : text.wechatSubmit}}</text>
      </button>

      <view class="wechat-hint">{{text.wechatHint}}</view>

      <view class="manual-toggle" bindtap="toggleManualLogin">
        <text>{{text.manualToggle}}</text>
      </view>

      <view class="login-form" wx:if="{{manualVisible}}">
        <view class="field-block">
          <view class="field-label">{{text.companyLabel}}</view>
          <input
            class="field-input"
            placeholder="{{text.companyPlaceholder}}"
            value="{{companyName}}"
            bindinput="onInputCompanyName"
            placeholder-class="input-placeholder"
          />
        </view>

        <view class="field-block">
          <view class="field-label">{{text.phoneLabel}}</view>
          <input
            class="field-input"
            type="number"
            maxlength="11"
            placeholder="{{text.phonePlaceholder}}"
            value="{{phone}}"
            bindinput="onInputPhone"
            placeholder-class="input-placeholder"
          />
        </view>

        <button
          class="btn-primary-solid login-submit manual-submit {{loading ? 'is-loading' : ''}}"
          bindtap="handleLogin"
          disabled="{{loading}}"
        >
          <text>{{loading ? text.submitting : text.submit}}</text>
        </button>
      </view>

      <view class="login-actions">
        <view class="assist-row">
          <text class="assist-text">{{text.assistText}}</text>
          <text class="assist-link" bindtap="goToRegister">{{text.register}}</text>
        </view>
        <button class="btn-ghost-link admin-entry" bindtap="goToAdminLogin">{{text.adminLogin}}</button>
      </view>
    </view>

    <view class="version-text">Version 1.2.0</view>
  </view>
</view>

<privacy />
