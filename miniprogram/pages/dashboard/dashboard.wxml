<view class="page-shell admin-home-page">
  <scroll-view scroll-y class="admin-home-scroll">
    <view class="content-wrapper admin-home-wrapper">
      <view class="panel hero-panel">
        <view class="panel-section">
          <view class="eyebrow">{{adminName}}</view>
          <view class="page-title hero-title">{{text.heroTitle}}</view>
          <view class="page-subtitle">{{text.heroDesc}}</view>
        </view>
      </view>

      <view class="panel">
        <view class="panel-section">
          <text class="section-title">{{text.summaryTitle}}</text>
          <text class="section-note">{{text.summaryDesc}}</text>
          <view class="stats-grid">
            <view class="stat-card" bindtap="onTapSummary" data-type="records">
              <text class="stat-value">{{overviewData.totalRecords}}</text>
              <text class="stat-label">{{text.totalRecords}}</text>
            </view>
            <view class="stat-card tint-green" bindtap="onTapSummary" data-type="enterprises">
              <text class="stat-value">{{overviewData.totalEnterprises}}</text>
              <text class="stat-label">{{text.totalEnterprises}}</text>
            </view>
            <view class="stat-card tint-amber" bindtap="onTapSummary" data-type="districts">
              <text class="stat-value">{{overviewData.totalDistricts}}</text>
              <text class="stat-label">{{text.totalDistricts}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="panel">
        <view class="panel-section">
          <text class="section-title">{{text.riskTitle}}</text>
          <text class="section-note">{{text.riskDesc}}</text>
          <view class="risk-grid">
            <view class="risk-card risk-danger" bindtap="onTapRisk" data-filter="expired">
              <text class="risk-value">{{expirySummary.expiredCount}}</text>
              <text class="risk-label">{{text.expiredCount}}</text>
            </view>
            <view class="risk-card risk-warning" bindtap="onTapRisk" data-filter="expiring">
              <text class="risk-value">{{expirySummary.expiringCount}}</text>
              <text class="risk-label">{{text.expiringCount}}</text>
            </view>
            <view class="risk-card risk-calm" bindtap="onTapRisk" data-filter="enterprise">
              <text class="risk-value">{{expirySummary.enterpriseCount}}</text>
              <text class="risk-label">{{text.enterpriseCount}}</text>
            </view>
          </view>

          <view class="enterprise-focus" wx:if="{{expiryEnterprises.length}}">
            <view class="enterprise-focus-header">
              <text class="focus-title">{{text.enterpriseRiskTitle}}</text>
              <text class="focus-action" bindtap="openRiskEnterpriseList">{{text.viewAll}}</text>
            </view>
            <swiper
              class="focus-swiper"
              vertical
              circular
              autoplay="{{expiryEnterprises.length > 1}}"
              interval="2600"
              duration="500"
            >
              <swiper-item wx:for="{{expiryEnterprises}}" wx:key="enterpriseName">
                <view class="list-cell focus-cell" bindtap="openRiskEnterpriseList">
                  <view>
                    <text class="cell-title">{{item.enterpriseName}}</text>
                    <text class="cell-subtitle">{{item.phone || text.noPhone}}</text>
                  </view>
                  <view class="focus-meta">
                    <text class="focus-tag danger" wx:if="{{item.expiredCount > 0}}">{{item.expiredCount}}过期</text>
                    <text class="focus-tag warning" wx:if="{{item.expiringCount > 0}}">{{item.expiringCount}}即将到期</text>
                  </view>
                </view>
              </swiper-item>
            </swiper>
          </view>

          <view class="empty-state" wx:else>
            <text class="empty-text">{{text.emptyRisk}}</text>
          </view>
        </view>
      </view>

      <view class="panel">
        <view class="panel-section">
          <text class="section-title">{{text.entryTitle}}</text>
          <text class="section-note">{{text.entryDesc}}</text>
          <view class="entry-list">
            <view
              class="list-cell entry-cell"
              wx:for="{{quickEntries}}"
              wx:key="key"
              data-action="{{item.action}}"
              bindtap="onTapEntry"
            >
              <view>
                <text class="cell-title">{{item.title}}</text>
                <text class="cell-subtitle">{{item.subtitle}}</text>
              </view>
              <text class="entry-arrow">></text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <privacy />
</view>
