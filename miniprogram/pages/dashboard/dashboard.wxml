<view class="page-shell admin-home-page">
  <scroll-view scroll-y class="admin-home-scroll">
    <view class="content-wrapper admin-home-wrapper">
      <view class="panel hero-panel">
        <view class="panel-section">
          <view class="eyebrow">{{adminName}}</view>
          <view class="page-title hero-title">{{text.heroTitle}}</view>
        </view>
      </view>

      <view class="panel">
        <view class="panel-section">
          <text class="section-title">{{text.summaryTitle}}</text>
          <view class="stats-grid summary-grid">
            <view class="stat-card" bindtap="onTapSummary" data-type="records">
              <text class="stat-value">{{overviewData.totalRecords}}</text>
              <text class="stat-label">{{text.totalRecords}}</text>
            </view>
            <view class="risk-card risk-danger" bindtap="onTapRisk" data-filter="expired">
              <text class="risk-value">{{expirySummary.expiredCount}}</text>
              <text class="risk-label">{{text.expiredCount}}</text>
            </view>
            <view class="risk-card risk-warning" bindtap="onTapRisk" data-filter="expiring">
              <text class="risk-value">{{expirySummary.expiringCount}}</text>
              <text class="risk-label">{{text.expiringCount}}</text>
            </view>
            <view class="stat-card tint-green" bindtap="onTapRisk" data-filter="enterprise">
              <text class="stat-value">{{expirySummary.enterpriseCount}}</text>
              <text class="stat-label">{{text.enterpriseCount}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="panel" wx:if="{{isAdmin}}">
        <view class="panel-section">
          <view class="district-head">
            <view>
              <text class="section-title">{{text.districtStatsTitle}}</text>
              <text class="section-note district-note">{{text.districtStatsDesc}}</text>
            </view>
            <text class="focus-action" bindtap="openDistrictList">{{text.viewAll}}</text>
          </view>

          <view class="district-inline-list" wx:if="{{districtStats.length}}">
            <view
              class="list-cell district-inline-cell"
              wx:for="{{districtStats}}"
              wx:key="district"
              bindtap="openDistrictList"
            >
              <view>
                <text class="cell-title">{{item.district}}</text>
                <text class="cell-subtitle">{{item.percent}}%</text>
              </view>
              <view class="district-inline-side">
                <text class="district-count">{{item.count}} 台</text>
                <text class="entry-arrow">></text>
              </view>
            </view>
          </view>

          <view class="empty-state" wx:else>
            <text class="empty-text">{{text.emptyDistrictStats}}</text>
          </view>
        </view>
      </view>

      <view class="panel">
        <view class="panel-section">
          <text class="section-title">{{text.riskTitle}}</text>

          <view class="enterprise-focus" wx:if="{{expiryEnterprises.length}}">
            <view class="enterprise-focus-header">
              <text class="focus-title">{{text.enterpriseRiskTitle}}</text>
              <text class="focus-action" bindtap="openRiskEnterpriseList">{{text.viewAll}}</text>
            </view>
            <swiper
              class="focus-swiper"
              vertical
              circular
              autoplay="{{expiryEnterprises.length > 1}}"
              interval="2600"
              duration="500"
            >
              <swiper-item wx:for="{{expiryEnterprises}}" wx:key="enterpriseName">
                <view class="list-cell focus-cell" bindtap="openRiskEnterpriseList">
                  <view>
                    <text class="cell-title">{{item.enterpriseName}}</text>
                    <text class="cell-subtitle">{{item.phone || text.noPhone}}</text>
                  </view>
                  <view class="focus-meta">
                    <text class="focus-tag danger" wx:if="{{item.expiredCount > 0}}">{{item.expiredCount}}{{text.focusExpiredSuffix}}</text>
                    <text class="focus-tag warning" wx:if="{{item.expiringCount > 0}}">{{item.expiringCount}}{{text.focusExpiringSuffix}}</text>
                  </view>
                </view>
              </swiper-item>
            </swiper>
          </view>

          <view class="empty-state" wx:else>
            <text class="empty-text">{{text.emptyRisk}}</text>
          </view>
        </view>
      </view>

    </view>
  </scroll-view>

  <expiry-reminder-card
    visible="{{reminderVisible}}"
    title="{{reminderCard.title}}"
    summary="{{reminderCard.summary}}"
    items="{{reminderCard.items}}"
    badge-text="{{text.entryReminderBadge}}"
    fallback-subtitle="{{text.entryReminderFallbackSubtitle}}"
    confirm-text="{{text.entryReminderConfirm}}"
    cancel-text="{{text.entryReminderCancel}}"
    bind:confirm="confirmReminderCard"
    bind:cancel="closeReminderCard"
  />

  <view class="admin-bottom-switch">
    <view class="mode-switch">
      <view class="mode-pill active">
        <text>{{text.switchPreview}}</text>
      </view>
      <view class="mode-pill" bindtap="goToAdminWorkbench">
        <text>{{text.switchWorkbench}}</text>
      </view>
    </view>
  </view>

  <privacy />
</view>
