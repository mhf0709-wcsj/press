.admin-home-scroll {
  height: 100vh;
}

.admin-home-wrapper {
  padding-top: var(--space-5);
  padding-bottom: 160rpx;
}

.hero-panel {
  margin-bottom: var(--space-5);
}

.hero-title {
  margin-top: var(--space-4);
}

.mode-switch {
  display: flex;
  gap: 8rpx;
  padding: 6rpx;
  border-radius: var(--radius-pill);
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(17, 24, 39, 0.06);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.6);
}

.mode-pill {
  flex: 1;
  min-height: 64rpx;
  border-radius: var(--radius-pill);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-size-caption);
  color: var(--color-text-secondary);
  font-weight: var(--font-weight-medium);
  transition: background var(--transition-fast), color var(--transition-fast), box-shadow var(--transition-fast);
}

.mode-pill.active {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(234, 243, 255, 0.96));
  color: var(--color-brand);
  font-weight: var(--font-weight-semibold);
  box-shadow: 0 8rpx 20rpx rgba(0, 122, 255, 0.12);
}

.mode-pill:not(.active):active {
  background: rgba(17, 24, 39, 0.04);
}

.admin-bottom-switch {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  padding: 14rpx;
  padding-bottom: calc(14rpx + env(safe-area-inset-bottom));
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(17, 24, 39, 0.06);
  box-shadow: var(--shadow-md);
  backdrop-filter: blur(24rpx);
  z-index: 20;
}

.stats-grid,
.risk-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: var(--space-3);
  margin-top: var(--space-5);
}

.summary-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.stat-card,
.risk-card {
  min-height: 172rpx;
  padding: 26rpx 22rpx;
  border-radius: var(--radius-lg);
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(17, 24, 39, 0.06);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.stat-card.tint-green {
  background: rgba(236, 253, 245, 0.92);
}

.stat-card.tint-amber {
  background: rgba(255, 251, 235, 0.92);
}

.stat-value,
.risk-value {
  font-size: 54rpx;
  line-height: 1;
  font-weight: var(--font-weight-bold);
  color: var(--color-text-main);
}

.stat-label,
.risk-label {
  margin-top: 14rpx;
  font-size: var(--font-size-caption);
  line-height: 1.45;
  color: var(--color-text-secondary);
}

.risk-danger {
  background: linear-gradient(180deg, rgba(255, 239, 239, 0.98), rgba(255, 225, 225, 0.96));
  border-color: rgba(239, 68, 68, 0.18);
}

.risk-warning {
  background: rgba(255, 247, 237, 0.94);
}

.risk-calm {
  background: rgba(239, 246, 255, 0.94);
}

.enterprise-focus {
  margin-top: var(--space-5);
}

.enterprise-focus-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-3);
}

.focus-title {
  font-size: var(--font-size-callout);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-main);
}

.focus-action {
  font-size: var(--font-size-caption);
  color: var(--color-brand);
}

.focus-swiper {
  height: 132rpx;
  margin-top: var(--space-2);
}

.focus-cell {
  min-height: 120rpx;
}

.focus-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.focus-tag {
  min-height: 40rpx;
  padding: 0 16rpx;
  border-radius: var(--radius-pill);
  display: inline-flex;
  align-items: center;
  font-size: var(--font-size-caption);
  font-weight: var(--font-weight-medium);
}

.focus-tag.danger {
  background: rgba(239, 68, 68, 0.16);
  color: #b42318;
}

.focus-tag.warning {
  background: rgba(245, 158, 11, 0.14);
  color: #b45309;
}

.empty-state {
  margin-top: var(--space-5);
  padding: 32rpx 24rpx;
  border-radius: var(--radius-lg);
  background: rgba(255, 255, 255, 0.76);
  border: 1rpx solid rgba(17, 24, 39, 0.06);
}

.empty-text {
  font-size: var(--font-size-footnote);
  line-height: 1.6;
  color: var(--color-text-secondary);
}
