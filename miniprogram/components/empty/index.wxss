/**
 * 空数据占位组件样式
 */

.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 32rpx;
  min-height: 400rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 32rpx;
  opacity: 0.8;
}

.empty-text {
  font-size: 30rpx;
  color: #999999;
  margin-bottom: 16rpx;
  text-align: center;
}

.empty-description {
  font-size: 26rpx;
  color: #c0c0c0;
  text-align: center;
  max-width: 500rpx;
  line-height: 1.5;
}

.empty-button {
  margin-top: 40rpx;
  padding: 20rpx 48rpx;
  font-size: 28rpx;
  color: #ffffff;
  background: #1890ff;
  border-radius: 12rpx;
  border: none;
}

.empty-button::after {
  border: none;
}

.empty-button:active {
  background: #096dd9;
}

/* 小尺寸 */
.empty-small .empty-icon {
  font-size: 64rpx;
  margin-bottom: 20rpx;
}

.empty-small .empty-text {
  font-size: 26rpx;
}

.empty-small .empty-button {
  padding: 16rpx 32rpx;
  font-size: 24rpx;
}
