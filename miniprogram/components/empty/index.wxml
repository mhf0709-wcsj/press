<!-- 空数据占位组件 -->
<view class="empty-container">
  <view class="empty-icon">{{icons[type]}}</view>
  <text class="empty-text">{{text}}</text>
  <text class="empty-description" wx:if="{{description}}">{{description}}</text>
  <button 
    class="empty-button" 
    wx:if="{{buttonText}}"
    bindtap="onButtonTap"
  >{{buttonText}}</button>
  <slot></slot>
</view>
