.movable-area {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 999;
}

.float-btn-container {
  width: 120rpx;
  height: 120rpx;
  pointer-events: auto;
}

.float-btn {
  width: 120rpx;
  height: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: transform 0.2s, box-shadow 0.2s;
}

.float-btn.moving {
  transform: scale(1.1);
}

.float-btn:active {
  transform: scale(0.95);
}

.btn-inner {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

.btn-icon {
  font-size: 48rpx;
}

.btn-label {
  position: absolute;
  bottom: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0, 0, 0, 0.7);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  white-space: nowrap;
}

.btn-label text {
  font-size: 20rpx;
  color: #fff;
}
