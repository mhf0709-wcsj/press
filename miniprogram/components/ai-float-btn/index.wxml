<movable-area class="movable-area">
  <movable-view 
    class="float-btn-container"
    direction="all"
    x="{{x}}"
    y="{{y}}"
    damping="50"
    friction="5"
    bindchange="onMove"
    bindtouchend="onTouchEnd"
  >
    <view class="float-btn {{isMoving ? 'moving' : ''}}" bindtap="goToAI">
      <view class="btn-inner">
        <text class="btn-icon">🤖</text>
      </view>
      <view class="btn-label" wx:if="{{showLabel}}">
        <text>AI助手</text>
      </view>
    </view>
  </movable-view>
</movable-area>
