/**
 * 附件上传组件样式
 */

.uploader-container {
  width: 100%;
}

/* 文件列表 */
.uploader-files {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

/* 单个文件项 */
.uploader-item {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f5f5f5;
}

.uploader-image {
  width: 100%;
  height: 100%;
}

.uploader-image.error {
  opacity: 0.5;
}

/* 上传状态 */
.uploader-status {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.5);
}

.uploader-loading {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #ffffff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.uploader-error {
  background: rgba(255, 77, 79, 0.8);
}

.uploader-error-icon {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
}

/* 删除按钮 */
.uploader-delete {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
}

.uploader-delete-icon {
  font-size: 28rpx;
  color: #ffffff;
  line-height: 1;
}

/* 添加按钮 */
.uploader-add {
  width: 160rpx;
  height: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border: 2rpx dashed #d9d9d9;
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.uploader-add:active {
  background: #f0f0f0;
  border-color: #1890ff;
}

.uploader-add-icon {
  font-size: 48rpx;
  color: #999999;
  line-height: 1;
}

.uploader-add-text {
  font-size: 22rpx;
  color: #999999;
  margin-top: 8rpx;
}

/* 上传进度 */
.uploader-progress {
  margin-top: 16rpx;
  padding: 16rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.uploader-progress-bar {
  height: 8rpx;
  background: #e8e8e8;
  border-radius: 4rpx;
  overflow: hidden;
}

.uploader-progress-fill {
  height: 100%;
  background: #1890ff;
  transition: width 0.3s ease;
}

.uploader-progress-text {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #666666;
  text-align: center;
}
