<!-- 附件上传组件 -->
<view class="uploader-container">
  <!-- 已上传文件列表 -->
  <view class="uploader-files">
    <view 
      class="uploader-item" 
      wx:for="{{files}}" 
      wx:key="index"
    >
      <image 
        class="uploader-image {{item.status === 'error' ? 'error' : ''}}" 
        src="{{item.fileID || item.localPath}}" 
        mode="aspectFill"
        bindtap="previewImage"
        data-index="{{index}}"
      />
      
      <!-- 上传状态 -->
      <view class="uploader-status" wx:if="{{item.status === 'uploading'}}">
        <view class="uploader-loading"></view>
      </view>
      <view class="uploader-status uploader-error" wx:if="{{item.status === 'error'}}" bindtap="retryUpload" data-index="{{index}}">
        <text class="uploader-error-icon">!</text>
      </view>
      
      <!-- 删除按钮 -->
      <view class="uploader-delete" wx:if="{{!disabled}}" bindtap="deleteImage" data-index="{{index}}">
        <text class="uploader-delete-icon">×</text>
      </view>
    </view>
  </view>
  
  <!-- 上传按钮 -->
  <view 
    class="uploader-add" 
    wx:if="{{files.length < maxCount && !disabled}}"
    bindtap="chooseImage"
  >
    <text class="uploader-add-icon">+</text>
    <text class="uploader-add-text">添加图片</text>
  </view>
  
  <!-- 上传进度 -->
  <view class="uploader-progress" wx:if="{{uploading}}">
    <view class="uploader-progress-bar">
      <view class="uploader-progress-fill" style="width: {{uploadProgress}}%"></view>
    </view>
    <text class="uploader-progress-text">上传中 {{uploadProgress}}%</text>
  </view>
</view>
