.reminder-overlay {
  position: fixed;
  inset: 0;
  z-index: 999;
  background: rgba(15, 23, 42, 0.34);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 32rpx 24rpx calc(32rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.reminder-dialog {
  position: relative;
  width: 100%;
  max-width: 690rpx;
  padding: 24rpx 24rpx 24rpx;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(17, 24, 39, 0.06);
  box-shadow: 0 24rpx 70rpx rgba(15, 23, 42, 0.18);
  backdrop-filter: blur(28rpx);
  overflow: hidden;
}

.reminder-glow {
  position: absolute;
  top: -60rpx;
  right: -10rpx;
  width: 220rpx;
  height: 220rpx;
  background: radial-gradient(circle, rgba(255, 59, 48, 0.16) 0%, rgba(255, 59, 48, 0) 70%);
}

.reminder-priority {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-height: 88rpx;
  padding: 18rpx 20rpx;
  border-radius: 26rpx;
  margin-bottom: 16rpx;
}

.reminder-priority.danger {
  background: linear-gradient(180deg, rgba(255, 236, 234, 0.98), rgba(255, 220, 218, 0.96));
  color: #b42318;
  border: 1rpx solid rgba(220, 38, 38, 0.14);
}

.reminder-priority.warning {
  background: linear-gradient(180deg, rgba(255, 249, 237, 0.98), rgba(255, 241, 214, 0.96));
  color: #b45309;
  border: 1rpx solid rgba(217, 119, 6, 0.12);
}

.reminder-priority-main {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.reminder-priority-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 7rpx;
  background: currentColor;
}

.reminder-priority-text {
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 0.4rpx;
}

.reminder-priority-note {
  font-size: 22rpx;
  line-height: 1.5;
  opacity: 0.88;
}

.reminder-header {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.reminder-badge {
  min-height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 59, 48, 0.1);
  color: #c62828;
  display: inline-flex;
  align-items: center;
  font-size: 22rpx;
  font-weight: 600;
}

.reminder-close {
  width: 52rpx;
  height: 52rpx;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  color: #8a94a6;
  background: rgba(17, 24, 39, 0.04);
}

.reminder-title {
  position: relative;
  z-index: 1;
  margin-top: 14rpx;
  font-size: 40rpx;
  line-height: 1.15;
  font-weight: 700;
  color: #111827;
}

.reminder-summary {
  position: relative;
  z-index: 1;
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #5b6472;
  white-space: pre-line;
}

.reminder-list {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 24rpx;
}

.reminder-section {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding: 0 4rpx;
}

.reminder-section-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #111827;
}

.reminder-section-hint {
  font-size: 22rpx;
  line-height: 1.5;
  color: #6b7280;
}

.reminder-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  padding: 22rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(248, 250, 252, 0.9);
  border: 1rpx solid rgba(17, 24, 39, 0.05);
}

.reminder-item-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.reminder-item-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.reminder-item-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
  flex: 1;
  min-width: 0;
}

.reminder-item-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.reminder-item-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
}

.reminder-meta-chip {
  min-height: 36rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  background: rgba(17, 24, 39, 0.05);
  color: #6b7280;
  font-size: 20rpx;
  font-weight: 500;
}

.reminder-meta-chip.danger {
  background: rgba(239, 68, 68, 0.12);
  color: #b42318;
}

.reminder-meta-chip.warning {
  background: rgba(245, 158, 11, 0.14);
  color: #b45309;
}

.reminder-item-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
  min-width: 132rpx;
}

.reminder-tag {
  min-height: 40rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  font-size: 22rpx;
  font-weight: 600;
}

.reminder-tag.danger {
  background: rgba(239, 68, 68, 0.16);
  color: #b42318;
}

.reminder-tag.warning {
  background: rgba(245, 158, 11, 0.14);
  color: #b45309;
}

.reminder-actions {
  position: relative;
  z-index: 1;
  display: flex;
  gap: 16rpx;
  margin-top: 26rpx;
}

.reminder-action {
  flex: 1;
  min-height: 84rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
}

.reminder-action.secondary {
  background: rgba(17, 24, 39, 0.06);
  color: #374151;
}

.reminder-action.primary {
  background: #007aff;
  color: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(0, 122, 255, 0.22);
}
