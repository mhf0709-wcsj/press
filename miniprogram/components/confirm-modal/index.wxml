<!-- 确认弹窗组件 -->
<view class="modal-mask" wx:if="{{show}}" bindtap="onMaskTap">
  <view class="modal-container" catchtap="stopPropagation">
    <!-- 标题 -->
    <view class="modal-header" wx:if="{{title}}">
      <text class="modal-title">{{title}}</text>
    </view>
    
    <!-- 内容 -->
    <view class="modal-body">
      <text class="modal-content">{{content}}</text>
      <slot></slot>
    </view>
    
    <!-- 按钮 -->
    <view class="modal-footer">
      <button 
        class="modal-btn modal-btn-cancel" 
        wx:if="{{showCancel}}"
        bindtap="onCancel"
      >{{cancelText}}</button>
      <button 
        class="modal-btn {{danger ? 'modal-btn-danger' : 'modal-btn-confirm'}}" 
        bindtap="onConfirm"
        loading="{{loading}}"
        disabled="{{loading}}"
      >{{confirmText}}</button>
    </view>
  </view>
</view>
