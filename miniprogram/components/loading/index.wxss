/**
 * 加载动画组件样式
 */

.loading-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 2000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.3);
}

.loading-container.transparent .loading-mask {
  background: transparent;
}

.loading-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 48rpx;
  background: rgba(0, 0, 0, 0.7);
  border-radius: 16rpx;
}

/* 菊花加载动画 */
.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  position: relative;
}

.spinner-dot {
  position: absolute;
  width: 12rpx;
  height: 12rpx;
  background: #ffffff;
  border-radius: 50%;
  animation: spinner-fade 1.2s linear infinite;
}

.spinner-dot:nth-child(1) { top: 0; left: 50%; transform: translateX(-50%); animation-delay: 0s; }
.spinner-dot:nth-child(2) { top: 8rpx; right: 8rpx; animation-delay: 0.1s; }
.spinner-dot:nth-child(3) { top: 50%; right: 0; transform: translateY(-50%); animation-delay: 0.2s; }
.spinner-dot:nth-child(4) { bottom: 8rpx; right: 8rpx; animation-delay: 0.3s; }
.spinner-dot:nth-child(5) { bottom: 0; left: 50%; transform: translateX(-50%); animation-delay: 0.4s; }
.spinner-dot:nth-child(6) { bottom: 8rpx; left: 8rpx; animation-delay: 0.5s; }
.spinner-dot:nth-child(7) { top: 50%; left: 0; transform: translateY(-50%); animation-delay: 0.6s; }
.spinner-dot:nth-child(8) { top: 8rpx; left: 8rpx; animation-delay: 0.7s; }
.spinner-dot:nth-child(9) { top: 0; left: 50%; transform: translateX(-50%); animation-delay: 0.8s; }
.spinner-dot:nth-child(10) { top: 8rpx; right: 8rpx; animation-delay: 0.9s; }
.spinner-dot:nth-child(11) { top: 50%; right: 0; transform: translateY(-50%); animation-delay: 1s; }
.spinner-dot:nth-child(12) { bottom: 8rpx; right: 8rpx; animation-delay: 1.1s; }

@keyframes spinner-fade {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 1; }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: #ffffff;
}

/* 内联加载样式 */
.loading-inline {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
}

.loading-inline .loading-spinner {
  width: 40rpx;
  height: 40rpx;
}

.loading-inline .spinner-dot {
  width: 8rpx;
  height: 8rpx;
  background: #1890ff;
}

.loading-inline .loading-text {
  color: #666666;
  font-size: 26rpx;
}
