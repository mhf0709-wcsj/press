@import './styles/variables.wxss';
@import './styles/design-system.wxss';
@import './styles/buttons.wxss';
@import './styles/forms.wxss';
@import './styles/lists.wxss';

page {
  background: var(--color-bg-page);
  color: var(--color-text-main);
  font-size: var(--font-size-base);
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
}

.container {
  padding: 32rpx;
  min-height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.card {
  width: 100%;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
  margin-bottom: 32rpx;
  padding: 40rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 2rpx solid rgba(219, 228, 240, 0.8);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-md);
  transition: transform var(--transition-fast), box-shadow var(--transition-fast);
}

.card:active {
  transform: scale(0.996);
}

.card-title {
  position: relative;
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
  padding-left: 24rpx;
  font-size: 34rpx;
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-main);
}

.card-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 32rpx;
  border-radius: 4rpx;
  background: linear-gradient(180deg, var(--color-brand) 0%, var(--color-accent) 100%);
}

.btn {
  padding: 24rpx 48rpx;
  border: none;
  border-radius: 20rpx;
  background: linear-gradient(135deg, var(--color-brand) 0%, #3f8cff 100%);
  color: var(--color-text-white);
  font-size: 30rpx;
  font-weight: var(--font-weight-medium);
  text-align: center;
  box-shadow: 0 14rpx 32rpx rgba(31, 111, 235, 0.22);
  transition: transform var(--transition-fast), opacity var(--transition-fast), box-shadow var(--transition-fast);
}

.btn::after {
  border: none;
}

.btn:active {
  transform: translateY(2rpx);
  opacity: 0.96;
}

.btn.secondary {
  background: var(--color-brand-soft);
  color: var(--color-brand);
  box-shadow: none;
}

.btn.secondary:active {
  background: #dce9ff;
}

.btn.outline {
  background: transparent;
  border: 2rpx solid var(--color-brand);
  color: var(--color-brand);
  box-shadow: none;
}

.form-row {
  margin-bottom: 32rpx;
}

.label {
  display: block;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  font-weight: var(--font-weight-medium);
  color: var(--color-text-secondary);
}

.label.required::after {
  content: '*';
  margin-left: 8rpx;
  color: var(--color-danger);
}

.input {
  width: 100%;
  padding: 24rpx 32rpx;
  box-sizing: border-box;
  border: 2rpx solid var(--color-border);
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.96);
  color: var(--color-text-main);
  font-size: 28rpx;
  transition: border-color var(--transition-fast), box-shadow var(--transition-fast), background var(--transition-fast);
}

.input:focus {
  background: #ffffff;
  border-color: var(--color-brand);
  box-shadow: 0 0 0 6rpx rgba(31, 111, 235, 0.1);
}

.picker {
  width: 100%;
  padding: 24rpx 32rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border: 2rpx solid var(--color-border);
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.96);
  transition: background var(--transition-fast), border-color var(--transition-fast);
}

.picker:active {
  background: var(--color-bg-subtle);
}

.picker-text {
  font-size: 28rpx;
  color: var(--color-text-main);
}

.picker-text.placeholder {
  color: var(--color-text-muted);
}

.picker-arrow {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
