@import './styles/variables.wxss';
@import './styles/design-system.wxss';
@import './styles/buttons.wxss';
@import './styles/forms.wxss';
@import './styles/lists.wxss';

page {
  background: var(--color-bg-page);
  color: var(--color-text-main);
  font-size: var(--font-size-body);
  line-height: 1.45;
  -webkit-font-smoothing: antialiased;
}

.container {
  padding: var(--space-6);
  min-height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.card {
  width: 100%;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
  margin-bottom: var(--space-6);
  padding: var(--space-6);
  background: var(--color-bg-panel);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
  backdrop-filter: var(--blur-panel);
  transition: transform var(--transition-fast), box-shadow var(--transition-fast);
}

.card:active {
  transform: scale(0.994);
}

.card-title {
  position: relative;
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding-left: 0;
  font-size: var(--font-size-title3);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-main);
}

.btn {
  padding: 22rpx 42rpx;
  border: none;
  border-radius: var(--radius-pill);
  background: var(--color-brand);
  color: var(--color-text-white);
  font-size: var(--font-size-callout);
  font-weight: var(--font-weight-medium);
  text-align: center;
  box-shadow: 0 10rpx 28rpx rgba(0, 122, 255, 0.22);
  transition: transform var(--transition-fast), opacity var(--transition-fast), box-shadow var(--transition-fast);
}

.btn::after {
  border: none;
}

.btn:active {
  transform: translateY(2rpx);
  opacity: 0.96;
}

.btn.secondary {
  background: rgba(255, 255, 255, 0.8);
  color: var(--color-text-main);
  box-shadow: none;
  border: 1rpx solid rgba(17, 24, 39, 0.06);
}

.btn.secondary:active {
  background: var(--color-bg-subtle);
}

.btn.outline {
  background: transparent;
  border: 1rpx solid var(--color-border-strong);
  color: var(--color-brand);
  box-shadow: none;
}

.form-row {
  margin-bottom: 32rpx;
}

.label {
  display: block;
  margin-bottom: 16rpx;
  font-size: var(--font-size-footnote);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-secondary);
}

.label.required::after {
  content: '*';
  margin-left: 8rpx;
  color: var(--color-danger);
}

.input {
  width: 100%;
  padding: 22rpx 28rpx;
  box-sizing: border-box;
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  background: rgba(255, 255, 255, 0.96);
  color: var(--color-text-main);
  font-size: var(--font-size-body);
  transition: border-color var(--transition-fast), box-shadow var(--transition-fast), background var(--transition-fast);
}

.input:focus {
  background: #ffffff;
  border-color: var(--color-brand);
  box-shadow: 0 0 0 6rpx rgba(0, 122, 255, 0.1);
}

.picker {
  width: 100%;
  padding: 22rpx 28rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  background: rgba(255, 255, 255, 0.96);
  transition: background var(--transition-fast), border-color var(--transition-fast);
}

.picker:active {
  background: var(--color-bg-subtle);
}

.picker-text {
  font-size: var(--font-size-body);
  color: var(--color-text-main);
}

.picker-text.placeholder {
  color: var(--color-text-muted);
}

.picker-arrow {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
