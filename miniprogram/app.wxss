/* 全局基础样式 */
page {
  background: linear-gradient(135deg, #f8f9fa, #e9ecef);
  font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
}

.container {
  padding: 20rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 卡片通用样式 */
.card {
  background: white;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  margin: 20rpx 0;
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.08);
  max-width: 650rpx;
  width: 100%;
  position: relative;
  overflow: hidden;
}

.card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 4rpx;
  background: linear-gradient(90deg, #1890ff, #096dd9);
}

.card-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-title::before {
  margin-right: 16rpx;
}

/* 按钮通用样式 */
.btn {
  padding: 24rpx 0;
  border-radius: 16rpx;
  font-size: 28rpx;
  border: none;
  display: block;
  width: 100%;
  text-align: center;
  font-weight: 600;
  transition: all 0.3s ease;
}

.btn:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 15rpx rgba(0, 0, 0, 0.15);
}

/* 表单通用样式 */
.form-row {
  margin-bottom: 40rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.label.required::after {
  content: '*';
  color: #ff4d4f;
  margin-left: 8rpx;
  font-size: 32rpx;
}

.input {
  width: 100%;
  padding: 24rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background: #fafafa;
  transition: all 0.3s ease;
}

.input:focus {
  border-color: #1890ff;
  background: white;
  box-shadow: 0 0 0 2rpx rgba(24, 144, 255, 0.2);
}

.picker {
  width: 100%;
  padding: 24rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fafafa;
  transition: all 0.3s ease;
}

.picker:focus {
  border-color: #1890ff;
  box-shadow: 0 0 0 2rpx rgba(24, 144, 255, 0.2);
}

.picker-text {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.picker-arrow {
  font-size: 40rpx;
  color: #999;
  margin-left: 10rpx;
}

.readonly-text {
  font-size: 28rpx;
  color: #666;
  padding: 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* tabBar 样式 */
.tabbar {
  background: white;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1);
}

/* 响应式优化 */
@media screen and (max-width: 750px) {
  .card {
    padding: 30rpx 20rpx;
  }
  
  .form-row {
    margin-bottom: 30rpx;
  }
  
  .label {
    font-size: 26rpx;
  }
  
  .input, .picker {
    padding: 20rpx;
    font-size: 26rpx;
  }
}