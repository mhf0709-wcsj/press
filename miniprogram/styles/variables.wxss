page {
  --color-brand: #007aff;
  --color-brand-pressed: #0062cc;
  --color-brand-soft: #eaf3ff;
  --color-accent: #34c759;
  --color-accent-soft: #ebfbf0;
  --color-warning: #ff9f0a;
  --color-warning-soft: #fff6e5;
  --color-danger: #ff3b30;
  --color-danger-soft: #fff0ef;

  --color-text-main: #111827;
  --color-text-secondary: #5b6472;
  --color-text-tertiary: #8a94a6;
  --color-text-white: #ffffff;

  --color-bg-page: #f5f5f7;
  --color-bg-elevated: rgba(255, 255, 255, 0.92);
  --color-bg-panel: rgba(255, 255, 255, 0.78);
  --color-bg-subtle: #eff2f7;
  --color-fill-soft: rgba(120, 136, 163, 0.12);
  --color-fill-strong: rgba(17, 24, 39, 0.06);

  --color-border: rgba(17, 24, 39, 0.08);
  --color-border-strong: rgba(17, 24, 39, 0.12);

  --font-size-caption: 22rpx;
  --font-size-footnote: 24rpx;
  --font-size-body: 28rpx;
  --font-size-callout: 30rpx;
  --font-size-title3: 34rpx;
  --font-size-title2: 40rpx;
  --font-size-title1: 52rpx;

  --font-weight-regular: 400;
  --font-weight-medium: 500;
  --font-weight-semibold: 600;
  --font-weight-bold: 700;

  --space-1: 8rpx;
  --space-2: 12rpx;
  --space-3: 16rpx;
  --space-4: 20rpx;
  --space-5: 24rpx;
  --space-6: 32rpx;
  --space-7: 40rpx;
  --space-8: 48rpx;

  --radius-sm: 16rpx;
  --radius-md: 22rpx;
  --radius-lg: 28rpx;
  --radius-xl: 36rpx;
  --radius-pill: 999rpx;

  --shadow-sm: 0 8rpx 24rpx rgba(15, 23, 42, 0.05);
  --shadow-md: 0 18rpx 44rpx rgba(15, 23, 42, 0.08);

  --blur-panel: blur(24rpx);
  --transition-fast: 160ms ease;
}
