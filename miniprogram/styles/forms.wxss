/**
 * 通用表单样式
 * 包含表单组、输入框、选择器、校验提示等
 */

/* ==================== 表单容器 ==================== */

.form-container {
  padding: 32rpx;
}

.form-section {
  background: #ffffff;
  border-radius: 24rpx;
  margin-bottom: 32rpx;
  overflow: hidden;
  box-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.05);
}

.form-section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  padding: 32rpx;
  border-bottom: 2rpx solid #F3F4F6;
  background: #ffffff;
}

/* ==================== 表单组 ==================== */

.form-group {
  padding: 32rpx;
  border-bottom: 2rpx solid #F3F4F6;
}

.form-group:last-child {
  border-bottom: none;
}

.form-group-error {
  background: #FEF2F2;
}

/* ==================== 表单标签 ==================== */

.form-label {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #374151;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.form-label.required::before {
  content: '*';
  color: #EF4444;
  margin-right: 8rpx;
  font-size: 32rpx;
  line-height: 1;
}

.form-label-optional {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-left: 12rpx;
  font-weight: 400;
}

/* ==================== 输入框 ==================== */

.form-input {
  width: 100%;
  padding: 24rpx 32rpx;
  font-size: 28rpx;
  color: #1F2937;
  background: #F9FAFB;
  border: 2rpx solid #E5E7EB;
  border-radius: 16rpx;
  box-sizing: border-box;
  transition: all 0.2s ease;
}

.form-input:focus {
  background: #ffffff;
  border-color: #3B82F6;
  box-shadow: 0 0 0 4rpx rgba(59, 130, 246, 0.1);
}

.form-input::placeholder {
  color: #9CA3AF;
}

.form-input-error {
  background: #FEF2F2;
  border-color: #EF4444;
}

.form-input-error:focus {
  box-shadow: 0 0 0 4rpx rgba(239, 68, 68, 0.1);
}

.form-input-disabled {
  background: #F3F4F6;
  color: #9CA3AF;
  border-color: #E5E7EB;
  cursor: not-allowed;
}

/* ==================== 文本域 ==================== */

.form-textarea {
  min-height: 200rpx;
  line-height: 1.6;
  padding: 24rpx 32rpx;
}

/* ==================== 选择器 ==================== */

.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: #F9FAFB;
  border: 2rpx solid #E5E7EB;
  border-radius: 16rpx;
  transition: all 0.2s ease;
}

.form-picker:active {
  background: #F3F4F6;
}

.form-picker-value {
  font-size: 28rpx;
  color: #1F2937;
  flex: 1;
}

.form-picker-placeholder {
  color: #9CA3AF;
}

.form-picker-arrow {
  font-size: 32rpx;
  color: #9CA3AF;
  margin-left: 16rpx;
}

/* ==================== 日期选择器 ==================== */

.form-date-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: #F9FAFB;
  border: 2rpx solid #E5E7EB;
  border-radius: 16rpx;
}

.form-date-value {
  font-size: 28rpx;
  color: #1F2937;
}

/* ==================== 错误提示 ==================== */

.form-error-text {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #EF4444;
}

.form-error-text::before {
  content: '!';
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 24rpx;
  height: 24rpx;
  background: #EF4444;
  color: #ffffff;
  border-radius: 50%;
  font-size: 18rpx;
  font-weight: bold;
  margin-right: 12rpx;
}

/* ==================== 帮助提示 ==================== */

.form-help-text {
  font-size: 24rpx;
  color: #6B7280;
  margin-top: 12rpx;
  line-height: 1.5;
}

/* ==================== 只读展示 ==================== */

.form-readonly {
  padding: 24rpx 32rpx;
  font-size: 28rpx;
  color: #4B5563;
  background: #F3F4F6;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
}

.form-readonly-highlight {
  color: #3B82F6;
  background: #EFF6FF;
  border-color: #BFDBFE;
}

/* ==================== 开关 ==================== */

.form-switch {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
}

/* ==================== 复选框/单选框 ==================== */

.form-checkbox-group,
.form-radio-group {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  padding-top: 16rpx;
}

.form-checkbox-item,
.form-radio-item {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #374151;
  padding: 12rpx 24rpx;
  background: #F9FAFB;
  border-radius: 12rpx;
  border: 2rpx solid #E5E7EB;
  transition: all 0.2s ease;
}

.form-checkbox-item.checked,
.form-radio-item.checked {
  background: #EFF6FF;
  border-color: #3B82F6;
  color: #3B82F6;
}

/* ==================== 表单分割线 ==================== */

.form-divider {
  height: 2rpx;
  background: #F3F4F6;
  margin: 32rpx;
}

/* ==================== 表单操作区 ==================== */

.form-actions {
  padding: 40rpx 32rpx;
  background: transparent;
}

.form-actions-fixed {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #ffffff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

/* ==================== 表单校验动画 ==================== */

@keyframes shake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-8rpx); }
  75% { transform: translateX(8rpx); }
}

.form-shake {
  animation: shake 0.3s ease;
}
