page {
  font-family: "SF Pro Text", "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: var(--font-size-body);
  line-height: 1.45;
  color: var(--color-text-main);
  background:
    radial-gradient(circle at top, rgba(0, 122, 255, 0.06), transparent 38%),
    linear-gradient(180deg, #fafafc 0%, var(--color-bg-page) 100%);
}

.page-shell {
  min-height: 100vh;
  position: relative;
}

.content-wrapper {
  position: relative;
  padding: var(--space-6);
  box-sizing: border-box;
}

.panel {
  background: var(--color-bg-panel);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
  backdrop-filter: var(--blur-panel);
}

.panel-section {
  padding: var(--space-6);
}

.eyebrow {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 18rpx;
  border-radius: var(--radius-pill);
  background: rgba(255, 255, 255, 0.72);
  color: var(--color-text-secondary);
  font-size: var(--font-size-caption);
  font-weight: var(--font-weight-medium);
  letter-spacing: 0.4rpx;
}

.page-title {
  font-size: var(--font-size-title1);
  line-height: 1.08;
  font-weight: var(--font-weight-bold);
  color: var(--color-text-main);
}

.page-subtitle {
  margin-top: 14rpx;
  font-size: var(--font-size-body);
  line-height: 1.65;
  color: var(--color-text-secondary);
}

.glass-card {
  background: var(--color-bg-elevated);
  border: 1rpx solid rgba(255, 255, 255, 0.78);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  backdrop-filter: var(--blur-panel);
}

.section-title {
  font-size: var(--font-size-title3);
  line-height: 1.2;
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-main);
}

.section-note {
  margin-top: 10rpx;
  font-size: var(--font-size-footnote);
  line-height: 1.5;
  color: var(--color-text-secondary);
}

.list-cell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-4);
  min-height: 108rpx;
  padding: 0 var(--space-5);
  border-radius: var(--radius-md);
  background: rgba(255, 255, 255, 0.76);
  border: 1rpx solid rgba(17, 24, 39, 0.06);
}

.list-cell:active {
  background: rgba(240, 244, 251, 0.96);
}

.cell-title {
  font-size: var(--font-size-callout);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-main);
}

.cell-subtitle {
  margin-top: 8rpx;
  font-size: var(--font-size-footnote);
  line-height: 1.55;
  color: var(--color-text-secondary);
}

.cell-meta {
  font-size: var(--font-size-caption);
  color: var(--color-text-tertiary);
}

.soft-button,
.primary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  padding: 0 var(--space-5);
  border-radius: var(--radius-pill);
  transition: transform var(--transition-fast), opacity var(--transition-fast), background var(--transition-fast);
}

.soft-button {
  background: rgba(255, 255, 255, 0.76);
  border: 1rpx solid rgba(17, 24, 39, 0.06);
  color: var(--color-text-main);
}

.primary-button {
  background: var(--color-brand);
  color: var(--color-text-white);
  box-shadow: 0 10rpx 28rpx rgba(0, 122, 255, 0.22);
}

.soft-button:active,
.primary-button:active {
  transform: scale(0.985);
}
